#!/usr/bin/env bash
# backlog-agent — drive and inspect this project's queue.
#
# Subcommands:
#   backlog-agent             Status: open count, next [ ]/[!] item, in-flight
#                       tick (if any), last completed tick age.
#   backlog-agent run         Worker: fswatch on backlog file + 30-min heartbeat,
#                       tick on either. Idle ticks (no open items) skip the
#                       claude invocation — only the status file is updated.
#                       Runs until Ctrl-C.
#   backlog-agent tick        Single tick, exit.
#   backlog-agent watch       Heartbeat-only loop (no fswatch). Fast-start:
#                       first 4 ticks at 5-min intervals, then 30-min.
#   backlog-agent log         tail -F the worker log (recent context + live).
#   backlog-agent unblock     List [?] blocked items. With `<N>` flip the Nth to
#                       [!] (answered, ready to retry); with `--all` flip
#                       every [?] to [!]. Write your answers inline first
#                       (e.g. `[user] in-memory is fine`); the worker reads
#                       the item body on next tick.
#   backlog-agent compact     Archive done items: moves all `- [x]` from ## Done to
#                       ## Archive. Looks for scripts/backlog-agent-compact.mjs
#                       (per-project), falls back to the shared copy at
#                       ~/dev/projects/active/backlog-infra/bin/backlog-agent-compact.mjs.
#   backlog-agent install-daemon
#                       Template a launchd plist for the current project
#                       (label com.$USER.<project>.backlog-agent), drop it in
#                       ~/Library/LaunchAgents, and bootstrap it. Idempotent
#                       refresh: if a plist already exists for this project,
#                       it's booted out and replaced.
#   backlog-agent uninstall-daemon
#                       Boot out and remove this project's launchd plist.
#
# Queue file: prefers docs/Backlog.md (new), falls back to backlog.txt
# (legacy) during the migration. Operates on the current working directory
# — run from a project root.
#
# Never run alongside an interactive /watch-backlog session — they race
# for the same items. A .claude/watch-backlog.ping sentinel (touched by
# the slash command each iteration) guards against accidental overlap;
# run/tick/watch refuse to start if the ping is < 3 min old.

set -euo pipefail
LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$LIB_DIR/_lib.sh"

# --- file discovery (polyglot during Phase 1 migration) ---
# Canonical location is docs/Backlog.md. Also accept Backlog.md at the
# repo root (an intermediate form some projects adopted) and the original
# backlog.txt. Lock/log paths track the convention so the two stacks
# don't stomp on each other if both happen to run.
if [[ -f docs/Backlog.md ]]; then
  BACKLOG_FILE="docs/Backlog.md"
  LOCK_DIR=".claude/backlog-agent.lock"
  LOG_FILE=".claude/backlog-agent.log"
  EVENT_LOG_FILE=".claude/backlog-agent-events.jsonl"
  INFLIGHT_FILE=".claude/backlog-agent-tick.inflight"
elif [[ -f Backlog.md ]]; then
  BACKLOG_FILE="Backlog.md"
  LOCK_DIR=".claude/backlog-agent.lock"
  LOG_FILE=".claude/backlog-agent.log"
  EVENT_LOG_FILE=".claude/backlog-agent-events.jsonl"
  INFLIGHT_FILE=".claude/backlog-agent-tick.inflight"
elif [[ -f backlog.txt ]]; then
  BACKLOG_FILE="backlog.txt"
  LOCK_DIR=".claude/backlog-agent.lock"
  LOG_FILE=".claude/backlog-agent.log"
  EVENT_LOG_FILE=".claude/backlog-agent-events.jsonl"
  INFLIGHT_FILE=".claude/backlog-agent-tick.inflight"
else
  # Allow status/help to run from anywhere; only fail on commands that
  # actually need a backlog.
  BACKLOG_FILE=""
  LOCK_DIR=""
  LOG_FILE=""
  EVENT_LOG_FILE=""
  INFLIGHT_FILE=""
fi

HOOK=""
if [[ -f scripts/backlog-agent-status.mjs ]]; then
  HOOK="scripts/backlog-agent-status.mjs"
elif [[ -f scripts/loop-status.mjs ]]; then
  HOOK="scripts/loop-status.mjs"
elif [[ -f "$HOME/dev/projects/active/backlog-infra/bin/backlog-agent-status.mjs" ]]; then
  # Shared fallback — used by projects that haven't (or won't) ship a
  # per-project copy. Derives REPO_ROOT from cwd; relies on the driver
  # running the hook from the project root.
  HOOK="$HOME/dev/projects/active/backlog-infra/bin/backlog-agent-status.mjs"
fi

HEARTBEAT_SECONDS=1800
FAST_TICKS=4
FAST_SECONDS=300
DEBOUNCE_SECONDS=2
# Wall-clock caps so a hung external call can't wedge a tick. A tick holds the
# tick lock; if it wedges there's no heartbeat (STALE-while-alive) and the reaper
# fail-safes rather than reclaiming it. Enforced by pure-bash watchdogs (no
# coreutils `timeout` dependency) at the claude + status-hook call sites.
CLAUDE_TIMEOUT_SECS="${CLAUDE_TIMEOUT_SECS:-3600}"
HOOK_TIMEOUT_SECS="${HOOK_TIMEOUT_SECS:-120}"
# Escalating idle sleep: when tick_once finds no open items, the daemon
# progressively backs off. Resets to fast-start as soon as work appears.
# Format: space-separated seconds at each streak level (1st idle, 2nd, …).
ESCALATING_IDLE_SLEEP="30 60 120 300 600 1800"
STATE_DIR=".claude"
# Per-tick mutex (distinct from the daemon-lifetime process lock LOCK_DIR).
# do_run drives tick_once from two contexts — the polling loop and the
# fswatch subshell — so a single live daemon can otherwise run two ticks
# at once. Held only for the duration of one tick. See tick_once.
TICK_LOCK_DIR="${STATE_DIR}/backlog-agent.tick.lock"
# Layer 2 (docs/multi-agent-design.md): when a tick hits the Anthropic
# plan/session-limit, pause claude invocations for this long. The rolling
# window resets on its own; after the cooldown expires we retry, and if
# still limited the signature re-arms it.
COOLDOWN_SECONDS=3600
COOLDOWN_FILE="${STATE_DIR}/agent-cooldown.json"
# Opt-in cooldown alerts (docs/multi-agent-design.md, Layer 2). When a
# cooldown is armed, notify_cooldown reads this file and fires a Slack
# and/or email alert. Absent file / empty keys → silent no-op.
NOTIFY_CONFIG="${HOME}/.claude/agent-notify.json"

# Layer 3 (docs/multi-agent-design.md): opt-in alternative-agent fallback.
# When a plan-limit cooldown is active (Layer 2) the daemon would normally
# idle. If this opt-in config is present AND the configured agent is
# available, the daemon instead runs the SAME prompt through a non-Claude
# coding agent (e.g. OpenCode driving DeepSeek) so simple items keep making
# progress during the cooldown. Shape:
#   { "fallback": {
#       "command": ["opencode","run","--yolo","--model","...","{prompt}"],
#       "available_when": "command -v opencode >/dev/null && [[ -n \"${OPENROUTER_API_KEY:-}\" ]]",
#       "name": "opencode" } }
# `{prompt}` is substituted with the tick prompt; `name` is optional
# (defaults to the basename of command[0]). Requires jq. Absent file / no jq /
# `available_when` non-zero / empty command → no fallback, Layer 2 idle.
AGENT_FALLBACK_FILE="${HOME}/.claude/agent-fallback.json"

# Per-item circuit breaker (W2). Track consecutive failures per item title in
# a JSON state file. After CIRCUIT_BREAKER_THRESHOLD consecutive failed ticks
# for the SAME item (claude exit != 0 → unclaimed), stop re-claiming it: flip
# it [ ]/[!] → [?] with an inline note and let the user weigh in. The counter
# resets when the item completes ([x]) or a tick succeeds. Per-host ephemeral
# state, gitignored like the event log.
CIRCUIT_BREAKER_THRESHOLD=3
FAILCOUNTS_FILE="${STATE_DIR}/backlog-agent-failcounts.json"

# Dead-man's-switch — repeated status-hook failure (W2, docs/dead-mans-switch.md).
# [notify-channel consumer] The status hook does the tick's git ops (fetch / rebase
# / push) + telemetry every tick. When it fails N consecutive ticks the daemon is
# ALIVE but not syncing or committing — exactly the cooldown-add incident, where the
# hook's git op failed every tick for ~8h, the dashboard showed STALE, and nothing
# escalated. This is the DRIVER half of the switch (the daemon can alert about
# ITSELF here because it's alive, just failing; the OUTSIDE-the-daemon staleness
# half — a dead daemon can't alert about itself — lives in `backlog-agents monitor`).
# Count consecutive status_fail in a per-host JSON state file ({count, alerted});
# at the threshold fire ONE notify_send, then THROTTLE (the `alerted` flag) so a
# persistent failure doesn't re-alert every tick. status_ok clears the state (resets
# the streak AND the alerted flag, so the NEXT incident can alert again). Per-host
# ephemeral state, gitignored like the failcounts / event log.
DMS_HOOKFAIL_THRESHOLD="${DMS_HOOKFAIL_THRESHOLD:-3}"
HOOKFAIL_STATE_FILE="${STATE_DIR}/backlog-agent-hookfail.json"

# Diff-size guardrail (W2). After a work tick, inspect the commit(s) claude
# pushed. If a single tick touched more than DIFF_SIZE_MAX_FILES files or
# DIFF_SIZE_MAX_LINES changed lines, it's likely a runaway edit — log_event
# diff_oversize and emit a loud warning so the user can review. We do NOT
# auto-revert; the commit stands, we just flag it.
DIFF_SIZE_MAX_FILES=20
DIFF_SIZE_MAX_LINES=400

# Protected-path guardrail (W2). If a tick's changes touch any of these
# load-bearing infra files, log_event protected_path_touched and flag for
# review. Belt-and-suspenders against an automated tick rewriting its own
# machinery or release/ignore config. Space-separated repo-relative paths.
PROTECTED_PATHS="bin/backlog-agent bin/backlog-agent-status.mjs release.mjs CLAUDE.md .gitignore"

# Fleet control: freeze / pause / stop (W3, docs/fleet-freeze.md). Because bin/ is
# SHARED, a fleet-affecting infra change in flight should hold the REST of the
# fleet to heartbeat-only rather than have it work on mid-flight / unverified
# machinery (freeze). The same top-of-tick gate also carries the MANUAL siblings
# pause (heartbeat-only hold) and stop (full halt — the daemon exits its loop).
# All three are singleton rows in ONE D1 table (fleet_control), and the GET
# endpoint resolves the EFFECTIVE control by precedence stop > pause > freeze and
# returns it as "mode" — so the daemon does ONE read at top-of-tick (the same
# structural slot as cooldown_active) and never has to reconcile competing flags.
# Reads are DEPENDENCY-LIGHT + FAIL-OPEN: D1 unreachable ⇒ treat as no-control (a
# control-plane outage must not become a fleet-wide stall; `launchctl bootout` is
# the hard manual backstop for a real halt).
#   - FREEZE_PROJECT: the project whose OWN daemon is EXEMPT from the freeze (it
#     must keep ticking to land + verify the fix, else the freeze never clears →
#     deadlock). For the exempt daemon the flag means "evaluate the clear".
#   - FREEZE_CACHE: last-seen state, written on every successful read. Purely
#     observational (surfaced by `backlog-agents`); the gate itself fail-opens.
#   - FLEET_AFFECTING_PREFIX: a committed path under here (the shared driver dir)
#     arms the freeze when the EXEMPT daemon commits it (auto-arm).
# Arm/clear WRITES + the fleet-wide clear EVALUATION live in `backlog-agents`
# (it already speaks jq + computes version-skew); the driver only does the cheap
# jq-free read here and delegates the rest.
FREEZE_URL="${FREEZE_URL:-https://kash-backlogs.pages.dev/api/fleet-control}"
FREEZE_PROJECT="${FREEZE_PROJECT:-backlog-infra}"
FREEZE_CACHE="${STATE_DIR}/fleet-freeze.cache"
FLEET_AFFECTING_PREFIX="bin/"
# Set to 1 in tests / to hard-disable the freeze read (skips the D1 GET).
FREEZE_DISABLE="${FREEZE_DISABLE:-0}"

# Account-level shared cooldown (W2, scope=fleet; rides the D1 bus). The Anthropic
# plan limit is PER-ACCOUNT — shared across every machine + project — but
# start_cooldown arms a LOCAL per-project cooldown file. So when one daemon hits
# the cap, the other 11 daemon×project combos (6 projects × 2 machines) each have
# to independently fail a claude call before arming their own cooldown — a
# fleet-wide burst of wasted failing calls every time the cap is hit. The fix is a
# single account-level cooldown signal on D1 (a dedicated /api/cooldown row
# carrying the reset `until_epoch`) that every tick consults FIRST, so the WHOLE
# FLEET stands down at once the moment ANY daemon detects the limit — and resumes
# together at the reset. The read is jq-free + FAIL-OPEN (D1 unreachable ⇒ fall
# back to the local per-project cooldown, never a fleet stall); the local Layer-2/3
# cooldown stays intact as that fallback. The signal AUTO-EXPIRES at until_epoch
# (no manual clear needed — the first daemon past the reset proceeds and it
# lapses). docs/account-cooldown.md.
COOLDOWN_URL="${COOLDOWN_URL:-https://kash-backlogs.pages.dev/api/cooldown}"
# Set to 1 in tests / to hard-disable the account-cooldown read + publish.
ACCOUNT_COOLDOWN_DISABLE="${ACCOUNT_COOLDOWN_DISABLE:-0}"

# Per-tick outcome verification (W2; Guard 4 — the FIRST *vetoing* tick-guard;
# Guards 1/2/3 are the circuit-breaker + diff-size + protected-path siblings).
# `claude -p` exiting 0 + flipping an item to [x] is NOT proof the project's gate
# is green — claude can declare done while typecheck/tests are broken and the
# daemon records silent "progress". After an exit-0 tick that CLAIMED COMPLETION,
# the daemon independently runs the project's gate on the committed HEAD; on
# failure it REOPENS the item ([x]→[ ]) + bumps the failcount (feeding the Guard-1
# circuit breaker → [?] after K) rather than recording success. Like Guards 2/3 it
# does NOT auto-revert (the commit stands, flagged — auto-reverting an already-
# pushed commit is a cross-machine hazard). docs/per-tick-verification.md.
#   Gate source (resolve_gate, in precedence order):
#     1. .claude/backlog-gate.json  {"gate": ["npm","run","verify"]}  (array=argv,
#        or a string run via `bash -c`);
#     2. package.json fallback: a "verify" script, else "typecheck" && "test"
#        chained (npm's default "no test specified" placeholder is ignored so a
#        project that never set up tests is not falsely failed);
#     3. no gate defined ⇒ FAIL-OPEN (skip verification = current behaviour).
# A gate that overruns GATE_TIMEOUT_SECS is killed and counts as a FAILURE (a gate
# that can't finish in budget is not green) — the breaker surfaces a chronically
# slow/broken gate as [?] rather than letting it pass silently.
GATE_FILE="${STATE_DIR}/backlog-gate.json"
GATE_TIMEOUT_SECS="${GATE_TIMEOUT_SECS:-600}"
# Set to 1 in tests / to hard-disable verification (forces the fail-open path).
GATE_DISABLE="${GATE_DISABLE:-0}"

# --- Secret-scanning pre-push gate (W2; docs/secret-scan.md) ---
# Unlike Guards 1-4 (all POST-push: flag/reopen an already-pushed commit), a
# secret gate must run BEFORE the push — a published key can't be un-published.
# Since the daemon does NOT mediate claude's `git push`, prevention lives in a
# per-clone git `pre-push` HOOK that runs the scanner and rejects the push on a
# hit. The driver's job is keeping that hook installed + current (ensure-on-tick,
# below) — NOT scanning post-hoc. A belt-and-suspenders POST-push scan (Guard 5,
# in the Guards 2/3 block) still DETECTS + alerts if a clone is missing the hook
# (fresh machine pre-first-tick, hand-edited .git/hooks, `push --no-verify`).
#   - SECRET_SCAN_BIN: the standalone scanner (ONE source of truth for the regex
#     set), resolved next to this driver. Shared by the hook, Guard 5, the CLI.
#   - PREPUSH_HOOK_VERSION / PREPUSH_HOOK_MARKER / prepush_hook_body: defined in
#     _lib.sh (shared with the CLI). ensure_prepush_hook + doctor rewrite any
#     clone whose hook marker differs; a hook NOT carrying our marker is a
#     FOREIGN user hook — left untouched (never clobbered).
SECRET_SCAN_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)/backlog-secret-scan"
# Set to 1 in tests / to hard-disable the secret gate (skips ensure + Guard 5).
SECRET_SCAN_DISABLE="${SECRET_SCAN_DISABLE:-0}"

# --- Per-project budget enforcement (W2; docs/per-project-budget.md) ---
# [pause-primitive consumer, scope=project] A self-imposed *spend* cap, distinct
# from the account-level plan-limit cooldown (Anthropic's hard cap, Layer 2): if
# THIS project's own rolling token spend exceeds a per-project cap, the daemon
# pauses to heartbeat-only (and alerts ONCE), then resumes on its own as the
# rolling window drains back under the cap — stopping one runaway project from
# burning the shared account budget. The signal is LOCAL + per-project: it's a
# plain sum over this project's own ledger (`backlog-history.jsonl`), which is
# git-TRACKED, so the window sum already spans every host (= project-total spend,
# not just this machine's). No D1 round-trip — dependency-light + fail-open by
# construction. Caps live in BUDGETS_FILE's optional `projects` map; a project
# with no entry is UNCAPPED (today's behaviour = opt-in enforcement). Both the
# rolling-5h and rolling-week windows enforce (pause if EITHER is over cap).
# backlog-infra's OWN daemon is EXEMPT (operated interactively; see freeze_exempt).
BUDGETS_FILE="${BUDGETS_FILE:-${HOME}/.claude/backlog-budgets.json}"
# Per-host alert-once state ({alerted:bool}); fire ONE notify_send on entering
# budget-pause, throttle while it persists, reset on resume. Ephemeral, gitignored.
BUDGET_STATE_FILE="${STATE_DIR}/backlog-agent-budget.json"
# Set to 1 in tests / to hard-disable budget enforcement (no per-project pause).
BUDGET_DISABLE="${BUDGET_DISABLE:-0}"

# --- Per-item token/turn/spend ceiling (W2; docs/per-item-ceiling.md) ---
# [pause-primitive consumer, scope=ITEM] The finest-grained pause primitive: a
# single hard item can spiral (many turns, huge spend) WITHIN one tick, BELOW the
# per-project budget's rolling-window radar (the budget caps a project's *rolling*
# spend; one expensive tick can run away before it trips). Two layers:
#   * PREVENTIVE (saves spend): when a per-item USD cap is set, pass claude
#     `--max-budget-usd` so it self-stops before overspending. NB: this claude CLI
#     has NO `--max-turns` flag, so the only native preventive cap is the dollar
#     one; turns/tokens are enforced POST-HOC (below). Fallback agents get no flag.
#   * POST-HOC (catches the runaway): after the tick, read THIS session's actual
#     turns + tokens from claude's newest transcript (the same source the status
#     hook parses — no change to the `claude -p` text invocation) and, if over the
#     ceiling on an INCOMPLETE item, REOPEN it ([~]→[ ]) with an inline note +
#     failcount_bump, composing with the Guard-1 circuit breaker (→ [?] after K
#     consecutive). A COMPLETED item ([x]) that ran hot is LOGGED, not reopened
#     (reopening finished work would only re-spend it). Keep any commit (mirror
#     Guards 2/3/4 — no auto-revert of an already-pushed commit). NOT infra-exempt:
#     a runaway TASK is a bug-catch, not a deliberate policy pause (unlike the
#     budget/freeze fleet holds), and a spiraling infra item is the most dangerous.
# Inert/opt-in: absent ⇒ uncapped (env defaults 0). Per-project + per-item caps in
# CEILINGS_FILE override the env defaults. FAIL-OPEN: unparseable usage ⇒ no
# enforcement (today's behaviour). node (a hard dep) does the JSON; no jq.
CEILINGS_FILE="${STATE_DIR}/backlog-ceilings.json"
MAX_TURNS_PER_TICK="${MAX_TURNS_PER_TICK:-0}"            # 0 = uncapped
# Token sum is input+output+cache_creation (excludes cache_read) — IDENTICAL to
# the budget ledger's `tokens` headline, so the two caps measure the same thing.
MAX_TOKENS_PER_TICK="${MAX_TOKENS_PER_TICK:-0}"          # 0 = uncapped
MAX_BUDGET_USD_PER_TICK="${MAX_BUDGET_USD_PER_TICK:-0}"  # 0 = no --max-budget-usd
# Set to 1 in tests / to hard-disable the ceiling (no preventive flag, no post-hoc).
CEILING_DISABLE="${CEILING_DISABLE:-0}"

# Match worker-eligible items: `[ ] foo` (new), `- [ ] foo` (GFM new),
# or the same with `[!]` (answered, ready to retry after a `[?]` round-trip).
# Bare `[ ]` (no leading `- `) is the legacy form, still accepted.
ITEM_REGEX='^(- )?\[[ !]\] '
strip_marker() { sed -E 's/^(- )?\[[ !]\] //'; }

# Plan/session-limit rejection signatures Claude prints when the Anthropic
# rolling-window cap is exhausted. Verified against a real failure in
# .claude/backlog.log: "You've hit your session limit · resets 5:30pm".
# Matched case-insensitively against claude's captured output (Layer 2).
PLAN_LIMIT_REGEX='hit your (session|usage|weekly) limit|usage limit reached'

require_backlog() {
  if [[ -z "$BACKLOG_FILE" ]]; then
    echo "error: no docs/Backlog.md or backlog.txt in $(pwd). expected to run from a project root." >&2
    exit 1
  fi
}

# Auto-create a backlog file if none exists. Only used by subcommands that
# actively produce work (run/tick/watch/unblock/install-daemon/compact);
# read-only subcommands (status/log) use require_backlog instead, so they
# don't accidentally scaffold in the wrong directory.
ensure_backlog() {
  if [[ -n "$BACKLOG_FILE" ]]; then
    return 0
  fi
  local project_name
  project_name="$(basename "$(pwd)")"
  echo "backlog-agent: no backlog file found; auto-creating docs/Backlog.md" >&2
  mkdir -p docs
  cat > docs/Backlog.md <<BACKLOG_EOF
# ${project_name} — Backlog

A running list of work to do. Mark items \`- [x]\` when done and move
them to the Done section, \`- [ ]\` when open, \`- [~]\` when in progress,
\`- [?]\` when blocked on a design decision the user needs to weigh in
on, and \`- [!]\` once you've written answers inline and want the worker
to retry. The autonomous worker (see \`/watch-backlog\` or \`backlog-agent
run\`) picks \`- [ ]\` and \`- [!]\` items and skips \`- [?]\`; surface those
to the user when waking them.

## Open
(none)

## In progress
(none)

## Blocked
(none)

## Done
(none)
BACKLOG_EOF
  # Re-detect file paths since BACKLOG_FILE was empty at script start.
  BACKLOG_FILE="docs/Backlog.md"
  LOCK_DIR=".claude/backlog-agent.lock"
  LOG_FILE=".claude/backlog-agent.log"
  EVENT_LOG_FILE=".claude/backlog-agent-events.jsonl"
  INFLIGHT_FILE=".claude/backlog-agent-tick.inflight"
  # HOOK was already set at script start (it doesn't depend on BACKLOG_FILE).
  echo "backlog-agent: scaffolded docs/Backlog.md for ${project_name}" >&2
}

# Check if a backlog launchd daemon is already installed for this project.
# If not (and we're running interactively, not under launchd), auto-install
# one so the daemon survives reboots. Skips if a plist already exists (new
# .backlog or legacy .backlog-loop label).
maybe_install_daemon() {
  local project_root project label plist_path
  { read -r project_root; read -r project; read -r label; read -r plist_path; read -r _bin; } < <(daemon_paths 2>/dev/null)
  if [[ -z "${plist_path:-}" ]]; then
    return 0  # can't derive paths (not a git repo); skip
  fi
  if [[ -f "$plist_path" ]]; then
    return 0  # new-label plist already exists
  fi
  local old_plist="$HOME/Library/LaunchAgents/com.${USER}.${project}.backlog.plist"
  if [[ -f "$old_plist" ]]; then
    return 0  # old-label plist exists
  fi
  local legacy_plist="$HOME/Library/LaunchAgents/com.${USER}.${project}.backlog-loop.plist"
  if [[ -f "$legacy_plist" ]]; then
    return 0  # legacy plist exists
  fi
  echo "backlog-agent: no launchd daemon installed for ${project}; auto-installing now (survives reboots)." >&2
  do_install_daemon
  # The daemon is now running and holds the lock — we must not proceed
  # to acquire_lock in do_run/do_watch or we'd race ourselves.
  echo "backlog-agent: daemon installed and running. exiting — the daemon will pick up work from here." >&2
  exit 0
}

# GNU awk (gawk) supports `-i inplace`; BSD awk does not. Detect and
# fall back to a tempfile + mv so the claim/unclaim blocks don't
# silently no-op on macOS that ships with BSD awk.
_local_awk_inplace() {
  local file="$1" script="$2"; shift 2
  # Remaining args ("$@") are passed verbatim to awk *before* the program — e.g.
  # `-v owner="…"` — so callers can inject values without string-splicing them
  # into the awk source. Empty "$@" expands to nothing (safe under set -u).
  if command -v gawk >/dev/null 2>&1; then
    gawk -i inplace "$@" "$script" "$file"
  else
    local tmpfile
    tmpfile="$(mktemp 2>/dev/null || echo "${STATE_DIR}/.awk-tmp.$$")"
    awk "$@" "$script" "$file" > "$tmpfile" && mv "$tmpfile" "$file"
  fi
}

# --- structured event log (W0) ---
# A second, machine-readable stream alongside the freeform $LOG_FILE. One
# JSON object per line (JSONL) for the key tick lifecycle events
# (tick_start, claim, claim_lost, claude_exit, cooldown_armed,
# status_ok/status_fail, tick_done). The freeform log stays as-is for human
# `backlog-agent log` tailing; this file is what the monitor, metrics, digest,
# and dead-man's-switch consume instead of regex-on-prose. Per-host and
# ephemeral (gitignored), like $LOG_FILE.

# Minimal JSON string escaper — backslash first, then quote and the common
# control chars. Dependency-free on purpose: logging must never fail because
# jq is missing. Item titles are the only untrusted input and rarely contain
# control chars beyond these.
_json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

# Append one structured event. Usage: log_event <event> [key value]...
# Always stamps ts (UTC ISO-8601), event, project, host, pid. Extra args are
# consumed in key/value pairs; a value that looks numeric or boolean is emitted
# bare (so exit_code/counts/flags are real JSON numbers/bools), otherwise it's a
# JSON string. Best-effort: a missing $EVENT_LOG_FILE or a write failure is a
# silent no-op — never aborts a tick.
log_event() {
  [[ -z "${EVENT_LOG_FILE:-}" ]] && return 0
  local event="$1"; shift || true
  local ts proj host line
  ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo '')"
  proj="$(basename "$PWD" 2>/dev/null || echo '?')"
  host="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo '?')"
  line="{\"ts\":\"${ts}\",\"event\":\"$(_json_escape "$event")\""
  line+=",\"project\":\"$(_json_escape "$proj")\",\"host\":\"$(_json_escape "$host")\",\"pid\":$$"
  local k v
  while (( $# >= 2 )); do
    k="$1"; v="$2"; shift 2
    if [[ "$v" =~ ^-?[0-9]+$ || "$v" == "true" || "$v" == "false" ]]; then
      line+=",\"$(_json_escape "$k")\":${v}"
    else
      line+=",\"$(_json_escape "$k")\":\"$(_json_escape "$v")\""
    fi
  done
  line+="}"
  printf '%s\n' "$line" >> "$EVENT_LOG_FILE" 2>/dev/null || true
}

# --- per-item circuit breaker (W2) ---
# A flat JSON object { "<item title>": <consecutive-fail-count>, ... } in
# $FAILCOUNTS_FILE. Keyed by the exact item title (same string log_event
# carries), so quotes/backslashes in titles must round-trip safely — hence
# node for parse/serialize rather than grep/sed. node is already a hard
# dependency (the status hook and compactor are .mjs). Best-effort: a missing
# file or write failure is a silent no-op so the breaker can never abort a tick.

# Echo the current consecutive-failure count for an item title (0 if absent or
# the file is missing/unreadable/malformed).
failcount_get() {
  local item="$1"
  [[ -z "${FAILCOUNTS_FILE:-}" ]] && { echo 0; return 0; }
  [[ -f "$FAILCOUNTS_FILE" ]] || { echo 0; return 0; }
  node -e '
    const fs = require("fs");
    const [file, item] = [process.argv[1], process.argv[2]];
    let obj = {};
    try { obj = JSON.parse(fs.readFileSync(file, "utf8")) || {}; } catch { obj = {}; }
    const n = Number.isInteger(obj[item]) ? obj[item] : 0;
    process.stdout.write(String(n));
  ' "$FAILCOUNTS_FILE" "$item" 2>/dev/null || echo 0
}

# Increment the consecutive-failure count for an item title; echoes the new
# count. Creates the file on first failure.
failcount_bump() {
  local item="$1"
  [[ -z "${FAILCOUNTS_FILE:-}" ]] && { echo 0; return 0; }
  mkdir -p "$STATE_DIR" 2>/dev/null || true
  node -e '
    const fs = require("fs");
    const [file, item] = [process.argv[1], process.argv[2]];
    let obj = {};
    try { obj = JSON.parse(fs.readFileSync(file, "utf8")) || {}; } catch { obj = {}; }
    const n = (Number.isInteger(obj[item]) ? obj[item] : 0) + 1;
    obj[item] = n;
    try { fs.writeFileSync(file, JSON.stringify(obj) + "\n"); } catch {}
    process.stdout.write(String(n));
  ' "$FAILCOUNTS_FILE" "$item" 2>/dev/null || echo 0
}

# Drop an item from the failcount map (called when it completes or a tick
# succeeds). Silent no-op if there's no file or no such key.
failcount_reset() {
  local item="$1"
  [[ -z "${FAILCOUNTS_FILE:-}" ]] && return 0
  [[ -f "$FAILCOUNTS_FILE" ]] || return 0
  node -e '
    const fs = require("fs");
    const [file, item] = [process.argv[1], process.argv[2]];
    let obj = {};
    try { obj = JSON.parse(fs.readFileSync(file, "utf8")) || {}; } catch { obj = {}; }
    if (item in obj) { delete obj[item]; try { fs.writeFileSync(file, JSON.stringify(obj) + "\n"); } catch {} }
  ' "$FAILCOUNTS_FILE" "$item" 2>/dev/null || true
}

# --- helpers ---
acquire_lock() {
  mkdir -p "$STATE_DIR"
  if mkdir "$LOCK_DIR" 2>/dev/null; then
    printf '%s\n' "$$" > "$LOCK_DIR/pid"
    return 0
  fi
  # Lock dir already exists. Check whether the recorded PID is still alive.
  # If it isn't, the previous daemon was SIGKILL'd before its EXIT trap
  # could fire (e.g. `launchctl kickstart -k` escalating past SIGTERM,
  # or a crash). Reclaim the lock and any orphaned inflight sentinel
  # rather than refusing to start — otherwise the daemon stays down
  # until somebody notices and manually `rmdir`s the lock.
  local lock_pid=""
  [[ -f "$LOCK_DIR/pid" ]] && lock_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
  if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
    echo "lock held at $LOCK_DIR by live PID $lock_pid — exiting." >&2
    exit 1
  fi
  echo "lock at $LOCK_DIR is stale (recorded PID '${lock_pid:-?}' is gone); reclaiming." >&2
  rm -rf "$LOCK_DIR" 2>/dev/null
  # A SIGKILL'd daemon skips release_lock, so a per-tick lock can survive it.
  # Clear it here too or every future tick would mkdir-fail and skip forever.
  [[ -n "${TICK_LOCK_DIR:-}" ]] && rm -rf "$TICK_LOCK_DIR" 2>/dev/null
  [[ -n "${INFLIGHT_FILE:-}" ]] && rm -f "$INFLIGHT_FILE" 2>/dev/null
  # Flip any orphaned [~] items back to [ ] so the daemon picks them up on
  # its next tick. These are items that were mid-tick when the previous daemon
  # crashed or was killed (e.g. by a sync restart or machine reboot).
  if [[ -n "${BACKLOG_FILE:-}" ]] && [[ -f "$BACKLOG_FILE" ]]; then
    local orphaned
    orphaned="$(grep -c -E '^(- )?\[\~\] ' "$BACKLOG_FILE" 2>/dev/null || true)"
    orphaned="${orphaned:-0}"
    if (( orphaned > 0 )); then
      # Flip [~]->[ ] and drop the owner stamp. First expr handles stamped
      # claims (strip the trailing tag), second handles legacy unstamped ones.
      if [[ "$(uname)" == "Darwin" ]]; then
        sed -i '' -E -e 's|^((- )?)\[\~\] (.*) +<!-- @[^>]*-->[[:space:]]*$|\1[ ] \3|g' -e 's|^(- )?\[\~\] |\1[ ] |g' "$BACKLOG_FILE"
      else
        sed -i -E -e 's|^((- )?)\[\~\] (.*) +<!-- @[^>]*-->[[:space:]]*$|\1[ ] \3|g' -e 's|^(- )?\[\~\] |\1[ ] |g' "$BACKLOG_FILE"
      fi
      echo "auto-unclaimed $orphaned orphaned [~] item(s) (stale lock recovery)" >&2
    fi
  fi
  if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    echo "lock at $LOCK_DIR contested during reclaim — exiting." >&2
    exit 1
  fi
  printf '%s\n' "$$" > "$LOCK_DIR/pid"
}
release_lock() {
  rm -rf "$LOCK_DIR" 2>/dev/null || true
  # Drop any per-tick lock too, so a daemon that exits mid-tick (errexit or
  # SIGTERM) doesn't leave a lock that blocks every tick of the next daemon.
  [[ -n "${TICK_LOCK_DIR:-}" ]] && rm -rf "$TICK_LOCK_DIR" 2>/dev/null || true
  # If a tick was mid-flight when we got signaled, drop the sentinel so
  # `backlog-agent` doesn't report a phantom in-flight tick after the daemon exits.
  [[ -n "${INFLIGHT_FILE:-}" ]] && rm -f "$INFLIGHT_FILE" 2>/dev/null || true
  if [[ -n "${WATCH_PID:-}" ]]; then
    # WATCH_PID is the wrapping subshell of `( fswatch | while read; do …
    # done ) &`. fswatch and the while-read bash are peers in the
    # pipeline, not descendants of the subshell in the SIGTERM-propagation
    # sense — killing only WATCH_PID orphans them to launchd. Kill the
    # children first so the whole tree exits.
    pkill -P "$WATCH_PID" 2>/dev/null || true
    kill "$WATCH_PID" 2>/dev/null || true
  fi
  if [[ -n "${SLEEP_PID:-}" ]]; then
    kill "$SLEEP_PID" 2>/dev/null || true
  fi
}

# Check if an interactive /watch-backlog session appears to be active.
# The slash command touches .claude/watch-backlog.ping on each iteration;
# if the file is younger than 3 minutes (2× debounce window + guard
# band), refuse to start a headless driver — they race for the same
# items.
check_interactive_worker() {
  local ping_file="${STATE_DIR}/watch-backlog.ping"
  if [[ ! -f "$ping_file" ]]; then
    return 0
  fi
  local now mtime age
  now="$(date +%s)"
  mtime="$(stat -f %m "$ping_file" 2>/dev/null || echo 0)"
  age=$(( now - mtime ))
  if (( age < 180 )); then
    echo "error: an interactive /watch-backlog session appears to be active" >&2
    echo "  (${ping_file} is ${age}s old)." >&2
    echo "  stop the /watch-backlog session first, or wait for the ping to stale." >&2
    exit 1
  fi
}

# Heartbeat sleep that's interruptible by signals. A bare `sleep N` blocks
# bash from running the EXIT/TERM trap until the sleep returns (so
# `launchctl bootout` had to escalate to SIGKILL after a 5s timeout,
# leaving the mkdir lock behind). Running the sleep as a background job
# and `wait`ing on it lets the trap fire immediately on SIGTERM/SIGINT.
sleep_interruptible() {
  sleep "$1" &
  SLEEP_PID=$!
  wait "$SLEEP_PID" 2>/dev/null || true
  SLEEP_PID=""
}

# Auto-flip blocked items: scan the backlog for [?] items that have a [user]
# answer inline (on any line between this item and the next section header or
# item marker). Flip the marker from [?] to [!] so the worker picks it up on
# the next tick without manual `backlog-agent unblock <N>`.  The round-trip becomes
#   [ ] → (worker hits blocker) → [?] → (user writes [user] answer) → [!] → [x]
# with no manual unblock step needed as long as the answer is present.
auto_flip_blocked() {
  local line_num
  while IFS=: read -r line_num _; do
    local has_user=1
    awk -v start="$line_num" '
      NR < start  { next }
      NR == start { next }
      /^## /      { exit }
      /^(- )?\[/  { exit }
      /^[[:space:]]*\[user\]/  { found=1; exit }
      END { exit found ? 0 : 1 }
    ' "$BACKLOG_FILE" 2>/dev/null || has_user=0
    if (( has_user )); then
      # Best-effort: a transiently unwritable backlog must not abort the daemon
      # (set -e). The flip is retried on the next tick if this write is lost.
      sed -i '' "${line_num}s/\[?\]/[!]/" "$BACKLOG_FILE" || true
    fi
  done < <(grep -nE '^(- )?\[\?\] ' "$BACKLOG_FILE" 2>/dev/null || true)
}

# --- D1 heartbeat liveness (docs/reaper-switch-design.md) ---
# Derive the (project, host) keys EXACTLY as backlog-agent-status.mjs writes
# them, so the heartbeat read hits the same health_status row the push updates.
#   project: package.json .name if present, else basename of CWD
#   host:    hostname with a trailing ".local" stripped (matches the mjs)
_health_project() {
  local name=""
  if [[ -f "$PWD/package.json" ]]; then
    # jq-free: first "name": "<value>" in package.json.
    name="$(grep -oE '"name"[[:space:]]*:[[:space:]]*"[^"]*"' "$PWD/package.json" 2>/dev/null \
            | head -n1 | sed -E 's/.*"name"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/' || true)"
  fi
  [[ -z "$name" ]] && name="$(basename "$PWD")"
  printf '%s' "$name"
}

_health_host() {
  hostname 2>/dev/null | sed -E 's/\.local$//' || echo "?"
}

# Owner stamp appended to a [~] claim line so the cross-machine reaper can probe
# the CLAIMING host's heartbeat, not the local host's. Rendered as a trailing
# HTML comment: invisible in rendered GFM, and a line *suffix* so the many
# `^(- )?\[~\] ` prefix matchers are unaffected. Stripped again on unclaim.
_owner_tag() { printf ' <!-- @%s -->' "$(_health_host)"; }

# Echo the owning host parsed from a [~] line's owner stamp (empty for an
# unstamped / legacy claim — the reaper treats that as unattributable).
_claim_owner() {
  printf '%s' "$1" | sed -nE 's|^(- )?\[~\] .*<!-- @([^ >]+) *-->[[:space:]]*$|\2|p'
}

# URL-encode the few characters that legitimately appear in a project/host:
# space and the few punctuation chars. Project names are git-repo-safe in
# practice (no `&`, `?`, `#`), so a minimal encoder is enough; spaces are the
# realistic case. Keeps us curl-clean without pulling in a dependency.
_urlencode() {
  local s="$1" out="" c i
  for (( i=0; i<${#s}; i++ )); do
    c="${s:$i:1}"
    case "$c" in
      [a-zA-Z0-9._~-]) out+="$c" ;;
      *) out+="$(printf '%%%02X' "'$c")" ;;
    esac
  done
  printf '%s' "$out"
}

# Fetch heartbeat_epoch for THIS (project, host) from the D1 telemetry bus.
# Echoes the integer epoch on success; echoes NOTHING on any failure
# (unreachable, non-200, found:false, null heartbeat, malformed body).
# Bearer auth is optional for the read endpoint, but we send it when the
# health key is present so the endpoint can be locked down later w/o a client
# change. Short -m timeout so a slow/unreachable dashboard never stalls a tick.
_d1_heartbeat_epoch() {
  # $1 (optional): host to probe. Defaults to the local host. The reaper passes
  # the CLAIMING host parsed off each [~] line so it reads the right liveness row.
  local host_arg="${1:-}"
  command -v curl >/dev/null 2>&1 || return 0
  local key_file="$HOME/.config/backlog/health-key"
  local auth=() key
  if [[ -f "$key_file" ]]; then
    key="$(tr -d '[:space:]' < "$key_file" 2>/dev/null || true)"
    [[ -n "$key" ]] && auth=(-H "Authorization: Bearer $key")
  fi
  local project host url body http_code
  project="$(_urlencode "$(_health_project)")"
  host="$(_urlencode "${host_arg:-$(_health_host)}")"
  url="https://kash-backlogs.pages.dev/api/heartbeat?project=${project}&host=${host}"

  # -s silent, -m 5 hard cap, -w to capture the HTTP status separately so we can
  # require a 200 before trusting the body. On curl failure $? != 0 -> empty.
  # ${auth[@]+"${auth[@]}"} expands to nothing when auth is empty (no health
  # key) — the plain "${auth[@]}" form is an "unbound variable" error under
  # `set -u` in bash 3.2 (the daemon's interpreter), which would spew to the log
  # on every keyless tick. This idiom is safe for both empty and filled arrays.
  body="$(curl -s -m 5 ${auth[@]+"${auth[@]}"} -w $'\n%{http_code}' "$url" 2>/dev/null)" || return 0
  http_code="$(printf '%s' "$body" | tail -n1)"
  body="$(printf '%s' "$body" | sed '$d')"   # strip the trailing status line
  [[ "$http_code" == "200" ]] || return 0
  # Require found:true before reading the epoch (404 returns found:false).
  printf '%s' "$body" | grep -q '"found"[[:space:]]*:[[:space:]]*true' || return 0
  # jq-free integer extract, same idiom as cooldown_active.
  local epoch
  epoch="$(printf '%s' "$body" \
           | grep -oE '"heartbeat_epoch"[[:space:]]*:[[:space:]]*[0-9]+' \
           | grep -oE '[0-9]+$' | head -n1 || true)"
  [[ -n "$epoch" ]] && printf '%s' "$epoch"
  return 0
}

# --- Fleet control read (freeze / pause / stop; docs/fleet-freeze.md §3) ---
# Read the combined fleet-control state from the D1 telemetry bus. The endpoint
# resolves the EFFECTIVE control by precedence (stop > pause > freeze) and
# returns it as "mode" (one of: none|freeze|pause|stop). Echoes "<mode>\t<reason>"
# for an active control; echoes NOTHING on any failure (unreachable, non-200,
# malformed) OR when nothing is active — FAIL-OPEN: the caller treats "no answer"
# as no-control, so a control-plane outage never stalls the fleet (true for stop
# too — DECISION: stop fail-opens like freeze/pause; `launchctl bootout` is the
# hard backstop). Same curl idiom + bash-3.2-safe auth expansion as
# _d1_heartbeat_epoch. On a successful read it refreshes FREEZE_CACHE
# (observational only; the gate fail-opens).
#
# BACK-COMPAT: against a control plane that predates "mode" (returns only
# "frozen"), it derives mode=freeze from frozen==1 — so a freshly-rolled driver
# still honors a freeze through the deploy window before the new endpoint ships.
_d1_control_get() {
  [[ "$FREEZE_DISABLE" == "1" ]] && return 0
  command -v curl >/dev/null 2>&1 || return 0
  local key_file="$HOME/.config/backlog/health-key"
  local auth=() key
  if [[ -f "$key_file" ]]; then
    key="$(tr -d '[:space:]' < "$key_file" 2>/dev/null || true)"
    [[ -n "$key" ]] && auth=(-H "Authorization: Bearer $key")
  fi
  local body http_code mode reason frozen
  body="$(curl -s -m 5 ${auth[@]+"${auth[@]}"} -w $'\n%{http_code}' "$FREEZE_URL" 2>/dev/null)" || return 0
  http_code="$(printf '%s' "$body" | tail -n1)"
  body="$(printf '%s' "$body" | sed '$d')"
  [[ "$http_code" == "200" ]] || return 0
  # jq-free string extract (same idiom as cooldown_active / heartbeat).
  mode="$(printf '%s' "$body" \
          | grep -oE '"mode"[[:space:]]*:[[:space:]]*"[^"]*"' \
          | sed -E 's/.*:[[:space:]]*"([^"]*)".*/\1/' | head -n1 || true)"
  if [[ -z "$mode" ]]; then
    # Pre-"mode" endpoint: derive from the freeze flag (frozen==1 ⇒ freeze).
    frozen="$(printf '%s' "$body" \
              | grep -oE '"frozen"[[:space:]]*:[[:space:]]*[0-9]+' \
              | grep -oE '[0-9]+$' | head -n1 || true)"
    [[ "$frozen" == "1" ]] && mode="freeze" || mode="none"
  fi
  [[ -z "$mode" || "$mode" == "none" ]] && { printf '%s\t\n' "none" > "$FREEZE_CACHE" 2>/dev/null || true; return 0; }
  # Prefer the effective control's reason (mode_reason); fall back to the
  # freeze-row "reason" (the only one a pre-"mode" endpoint exposes).
  reason="$(printf '%s' "$body" \
            | grep -oE '"mode_reason"[[:space:]]*:[[:space:]]*"[^"]*"' \
            | sed -E 's/.*:[[:space:]]*"([^"]*)".*/\1/' | head -n1 || true)"
  [[ -z "$reason" ]] && reason="$(printf '%s' "$body" \
            | grep -oE '"reason"[[:space:]]*:[[:space:]]*"[^"]*"' \
            | sed -E 's/.*:[[:space:]]*"([^"]*)".*/\1/' | head -n1 || true)"
  # Refresh the observational cache (best-effort; never blocks the gate).
  printf '%s\t%s\n' "$mode" "$reason" > "$FREEZE_CACHE" 2>/dev/null || true
  printf '%s\t%s' "$mode" "$reason"
  return 0
}

# --- Account-level cooldown read (W2; docs/account-cooldown.md) ---
# Echo the account cooldown's `until_epoch` from the D1 bus (dedicated
# /api/cooldown row), or NOTHING on any failure / when no cooldown is active —
# FAIL-OPEN: the caller treats "no answer" as "no account cooldown" and falls back
# to the local per-project cooldown, so a control-plane outage never stalls the
# fleet. The endpoint already gates `active` server-side (until_epoch present AND
# in the future), but we ALSO re-check now<until_epoch with the LOCAL clock (same
# idiom as cooldown_active) so edge clock-skew can't pin the fleet. Same curl + the
# bash-3.2-safe auth expansion as _d1_heartbeat_epoch / _d1_control_get.
_d1_account_cooldown_epoch() {
  [[ "$ACCOUNT_COOLDOWN_DISABLE" == "1" ]] && return 0
  command -v curl >/dev/null 2>&1 || return 0
  local key_file="$HOME/.config/backlog/health-key"
  local auth=() key
  if [[ -f "$key_file" ]]; then
    key="$(tr -d '[:space:]' < "$key_file" 2>/dev/null || true)"
    [[ -n "$key" ]] && auth=(-H "Authorization: Bearer $key")
  fi
  local body http_code epoch now
  body="$(curl -s -m 5 ${auth[@]+"${auth[@]}"} -w $'\n%{http_code}' "$COOLDOWN_URL" 2>/dev/null)" || return 0
  http_code="$(printf '%s' "$body" | tail -n1)"
  body="$(printf '%s' "$body" | sed '$d')"
  [[ "$http_code" == "200" ]] || return 0
  # jq-free integer extract, same idiom as cooldown_active / heartbeat. A null /
  # absent until_epoch finds nothing -> empty -> fail-open (no account cooldown).
  epoch="$(printf '%s' "$body" \
           | grep -oE '"until_epoch"[[:space:]]*:[[:space:]]*[0-9]+' \
           | grep -oE '[0-9]+$' | head -n1 || true)"
  [[ -n "$epoch" ]] || return 0
  now="$(date +%s)"
  (( now < epoch )) || return 0   # expired ⇒ no account cooldown (auto-expiry)
  printf '%s' "$epoch"
  return 0
}

# True (0) iff THIS project's daemon is the freeze-exempt one (backlog-infra's
# own daemon). The exempt daemon must keep ticking while frozen to land + verify
# the fix — for it the flag is a signal to EVALUATE the clear, never to stop.
freeze_exempt() {
  [[ "$(_health_project)" == "$FREEZE_PROJECT" ]]
}

# Reclaim stale [~] items that were claimed but never completed.
# Liveness is the D1 telemetry heartbeat (`heartbeat_epoch`) of the CLAIMING
# host — parsed from the owner stamp on each [~] line — NOT the local host's. So
# one host's stale-self heartbeat can never reclaim another host's live work
# (the split-brain hazard from docs/driver-audit-2026-05-28.md §3). Per claim:
# if the owner's heartbeat is older than the stale threshold the owning daemon
# is dead -> flip the item back to [ ] and strip its owner stamp. If D1 is
# unreachable / has no row / the heartbeat is null, OR the claim is unstamped
# (legacy, unattributable), the reaper FAILS SAFE and skips it (DECISION 1) —
# the unconditional startup reclaim cleans it on the next daemon (re)start.
# On startup (STARTUP_RECLAIM=1) every [~] is a dead incarnation's orphan and is
# reclaimed unconditionally, no probe. Sets RECLAIMED_COUNT to items flipped.
reclaim_stale_claims() {
  RECLAIMED_COUNT=0
  local stale_secs=5400 now line line_num item_title owner hb_epoch reason startup=0

  now="$(date +%s)"
  # Plain "are we in a git repo?" guard — output discarded.
  [[ -z "$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null || true)" ]] && return

  [[ "${STARTUP_RECLAIM:-0}" == "1" ]] && startup=1
  STARTUP_RECLAIM=0

  while IFS= read -r line; do
    line_num="$(echo "$line" | cut -d: -f1)"
    # Bare title: strip the marker prefix AND the trailing owner stamp.
    item_title="$(echo "$line" | cut -d: -f2- | sed -E 's/^(- )?\[~\] //; s/ +<!-- @[^>]*-->[[:space:]]*$//')"

    if (( startup )); then
      reason="startup reclaim of orphaned claim"
    else
      # Probe the CLAIMING host's heartbeat. Unstamped (legacy) claims are
      # unattributable -> fail safe (skip); startup reclaim cleans them later.
      owner="$(_claim_owner "$(echo "$line" | cut -d: -f2-)")"
      [[ -z "$owner" ]] && continue
      hb_epoch="$(_d1_heartbeat_epoch "$owner")"
      [[ -z "$hb_epoch" ]] && continue                 # DECISION 1 fail-safe
      (( now - hb_epoch <= stale_secs )) && continue   # owner alive -> keep
      reason="no D1 heartbeat from ${owner} in $(( (now - hb_epoch) / 60 ))m"
    fi

    # Flip [~]->[ ] and strip the owner stamp on just this line: stamped expr
    # first, then a plain flip for an unstamped (startup) orphan. Best-effort
    # (|| true) so a transiently read-only backlog can't abort the daemon.
    sed -i '' -E "${line_num}s|^((- )?)\[~\] (.*) +<!-- @[^>]*-->[[:space:]]*\$|\1[ ] \3|" "$BACKLOG_FILE" 2>/dev/null || true
    sed -i '' -E "${line_num}s|^(- )?\[~\] |\1[ ] |" "$BACKLOG_FILE" 2>/dev/null || true
    echo "  [reclaim] stale [~] item '${item_title}' (${reason})" | tee -a "$LOG_FILE" || true
    RECLAIMED_COUNT=$((RECLAIMED_COUNT + 1))
  done < <(grep -nE '^(- )?\[~\] ' "$BACKLOG_FILE" 2>/dev/null || true)
}

# Post-tick maintenance: log rotation and auto-compact, so the daemon
# self-heals without manual intervention.
_post_tick_cleanup() {
  # Log rotation — keep under 10 MB.
  local max_log_bytes=$((10 * 1024 * 1024))
  if [[ -f "$LOG_FILE" ]]; then
    local log_size
    log_size="$(wc -c < "$LOG_FILE" 2>/dev/null || echo 0)"
    if (( log_size > max_log_bytes )); then
      tail -n 5000 "$LOG_FILE" > "${LOG_FILE}.tmp" && mv "${LOG_FILE}.tmp" "$LOG_FILE"
      echo "[$(date '+%Y-%m-%d %H:%M:%S')] log rotated (was ~$((log_size/1048576)) MB)" | tee -a "$LOG_FILE"
    fi
  fi

  # Same rotation for the structured event stream — keep the most recent lines.
  if [[ -n "${EVENT_LOG_FILE:-}" ]] && [[ -f "$EVENT_LOG_FILE" ]]; then
    local event_log_size
    event_log_size="$(wc -c < "$EVENT_LOG_FILE" 2>/dev/null || echo 0)"
    if (( event_log_size > max_log_bytes )); then
      tail -n 5000 "$EVENT_LOG_FILE" > "${EVENT_LOG_FILE}.tmp" && mv "${EVENT_LOG_FILE}.tmp" "$EVENT_LOG_FILE"
      log_event log_rotated bytes_before "$event_log_size"
    fi
  fi

  # Auto-compact — archive Done items when they pile up.
  local done_count
  # grep -c prints "0" AND exits 1 on no matches; `|| echo 0` would then append a
  # SECOND "0", yielding "0\n0" and a `[[: 0 0: syntax error`. Use `|| true` to
  # keep grep's own count and normalize empty (missing file) to 0.
  done_count="$(grep -cE '^(- )?\[x\] ' "$BACKLOG_FILE" 2>/dev/null || true)"
  done_count="${done_count:-0}"
  if [[ "$done_count" -gt 20 ]] && [[ -f "$HOME/dev/projects/active/backlog-infra/bin/backlog-agent-compact.mjs" ]]; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Done section has ${done_count} items; auto-compacting..." | tee -a "$LOG_FILE"
    node "$HOME/dev/projects/active/backlog-infra/bin/backlog-agent-compact.mjs" >> "$LOG_FILE" 2>&1 || true
  fi

  # Orphaned changes — after every tick, any uncommitted modifications left
  # behind by claude (e.g. it crashed before committing) would block the next
  # pull.  Stash them with a descriptive message so they can be recovered.
  if [[ -n $(git -C "$PWD" status --porcelain 2>/dev/null) ]]; then
    local stash_msg; stash_msg="backlog-agent auto-stash: orphaned changes after tick $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    if git -C "$PWD" stash push -m "$stash_msg" 2>/dev/null; then
      # Nothing ever auto-pops these (they're preserved for manual recovery), so
      # surface the running count — otherwise they leak invisibly (audit §4d).
      local n_stashes; n_stashes="$(git -C "$PWD" stash list 2>/dev/null | grep -c 'backlog-agent auto-stash' || true)"
      n_stashes="${n_stashes:-1}"
      echo "[$(date '+%Y-%m-%d %H:%M:%S')] orphaned changes stashed (${n_stashes} backlog-agent auto-stash(es) pending — 'git stash list' to review, 'git stash pop' to recover)" | tee -a "$LOG_FILE"
      log_event orphan_stashed pending "$n_stashes"
      if (( n_stashes >= 5 )); then
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] WARNING: ${n_stashes} orphaned auto-stashes have piled up — claude keeps leaving the tree dirty; investigate and clean up." | tee -a "$LOG_FILE"
      fi
    fi
  fi
}

# --- Layer 2: plan-limit cooldown (docs/multi-agent-design.md) ---
# Returns 0 (true) if a plan-limit cooldown is currently in effect. Side
# effect: removes an expired cooldown file so a stale one isn't re-read.
# Parses the integer `until_epoch` directly (no jq dependency).
cooldown_active() {
  [[ -f "$COOLDOWN_FILE" ]] || return 1
  local until_epoch now
  until_epoch="$(grep -oE '"until_epoch"[[:space:]]*:[[:space:]]*[0-9]+' "$COOLDOWN_FILE" 2>/dev/null \
                 | grep -oE '[0-9]+$' | head -n1 || true)"
  if [[ -z "$until_epoch" ]]; then
    return 1  # malformed/legacy file — treat as no cooldown
  fi
  now="$(date +%s)"
  if (( now < until_epoch )); then
    return 0
  fi
  rm -f "$COOLDOWN_FILE" 2>/dev/null || true
  return 1
}

# Echo the human-readable `until` ISO timestamp from the cooldown file (or
# nothing if there's no file / no field).
cooldown_until_str() {
  [[ -f "$COOLDOWN_FILE" ]] || return 0
  grep -oE '"until"[[:space:]]*:[[:space:]]*"[^"]*"' "$COOLDOWN_FILE" 2>/dev/null \
    | sed -E 's/.*"([^"]*)"$/\1/' | head -n1 || true
}

# --- Account-level cooldown publish (W2; docs/account-cooldown.md) ---
# When THIS daemon arms a local cooldown (plan-limit detected), ALSO publish the
# reset to the D1 bus so the WHOLE FLEET stands down at once instead of every
# other daemon×project failing its own claude call first. jq-free hand-built
# payload (the driver avoids a jq dependency); bearer-auth (writes are privileged,
# same key as the reads). Best-effort + backgrounded with a short timeout (like
# notify_cooldown) so a slow / unreachable D1 can never stall or abort the tick.
# The endpoint keeps the LATER until_epoch (max) across concurrent writers, so a
# daemon that couldn't parse the reset (and fell back to a shorter window) can't
# truncate a correctly-parsed longer cooldown. No-op without a health key or curl
# (the local cooldown still holds for this project).
_d1_publish_cooldown() {
  [[ "$ACCOUNT_COOLDOWN_DISABLE" == "1" ]] && return 0
  local until_epoch="${1:-}"
  [[ "$until_epoch" =~ ^[0-9]+$ ]] || return 0
  command -v curl >/dev/null 2>&1 || return 0
  local key_file="$HOME/.config/backlog/health-key" key=""
  [[ -f "$key_file" ]] && key="$(tr -d '[:space:]' < "$key_file" 2>/dev/null || true)"
  [[ -n "$key" ]] || return 0   # no key ⇒ can't write; local cooldown still holds
  local host payload
  host="$(_health_host)"
  # Hand-built JSON (jq-free). Values are an integer + a constant + a hostname —
  # no untrusted interpolation.
  payload="$(printf '{"until_epoch":%s,"reason":"anthropic-plan-limit","armed_by":"%s"}' "$until_epoch" "$host")"
  ( curl -s -m 8 -X POST \
      -H "Authorization: Bearer $key" -H "Content-Type: application/json" \
      -d "$payload" "$COOLDOWN_URL" >/dev/null 2>&1 || true ) &
  return 0
}

# Arm a cooldown: write COOLDOWN_FILE. If $1 is a numeric epoch (parsed
# from claude's "resets X:XXpm" message), use it directly; otherwise fall
# back to COOLDOWN_SECONDS from now.
start_cooldown() {
  mkdir -p "$STATE_DIR"
  local now until_epoch until_iso detected_iso parsed_from
  now="$(date +%s)"
  if [[ -n "${1:-}" ]] && [[ "$1" =~ ^[0-9]+$ ]]; then
    until_epoch="$1"
    parsed_from="true"
  else
    until_epoch=$(( now + COOLDOWN_SECONDS ))
    parsed_from="false"
  fi
  until_iso="$(date -u -r "$until_epoch" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null \
            || date -u -d "@$until_epoch" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo '')"
  detected_iso="$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo '')"
  local reason="anthropic-plan-limit"
  cat > "$COOLDOWN_FILE" <<JSON
{
  "until": "${until_iso}",
  "until_epoch": ${until_epoch},
  "reason": "${reason}",
  "detected_at": "${detected_iso}",
  "parsed_from_reset": ${parsed_from}
}
JSON
  local wait_info
  if [[ "$parsed_from" == "true" ]]; then
    wait_info="until ${until_iso:-?} (parsed from claude output)"
  else
    wait_info="until ${until_iso:-+${COOLDOWN_SECONDS}s}"
  fi
  echo "  [cooldown] plan/session limit detected — pausing claude ticks ${wait_info} (rm ${COOLDOWN_FILE} to clear)" | tee -a "$LOG_FILE"
  log_event cooldown_armed until "$until_iso" until_epoch "$until_epoch" reason "$reason" parsed_from_reset "$parsed_from"
  notify_cooldown "$until_iso"
  # Publish the per-account reset to the D1 bus so the whole fleet stands down at
  # once (account-cooldown, W2). Best-effort + fail-open: a failed publish only
  # means the other daemons fall back to detecting the limit themselves.
  _d1_publish_cooldown "$until_epoch"
}

# --- Opt-in notification channel (W2; docs/dead-mans-switch.md) ---
# Fire a best-effort Slack / email / macOS-local alert. The ONE canonical config is
# ~/.claude/agent-notify.json ($NOTIFY_CONFIG):
#   { "slack_webhook_url": "https://hooks.slack.com/...",
#     "email": "you@example.com",
#     "local_notify": true }
# All keys optional; an absent file or all-empty keys ⇒ silent no-op. Parsing is
# jq-FREE (grep/sed extraction, same idiom as the D1 reads) so an alert never
# depends on jq being installed, and every send is backgrounded with a short
# timeout so a slow / unreachable endpoint can never stall or abort the daemon.
# Both the plan-limit cooldown alert (notify_cooldown) and the dead-man's-switch
# (_hookfail_record) route through here so there's exactly ONE config + code path.
# The CLI monitor's _notify (bin/backlog-agents) reads the SAME canonical file.
# Usage: notify_send "<title>" "<body>"  (title = Slack prefix + email subject).
notify_send() {
  local title="${1:-backlog-agent}" body="${2:-}"
  [[ -n "$body" ]] || return 0
  [[ -f "$NOTIFY_CONFIG" ]] || return 0
  local slack_url email local_notify
  slack_url="$(grep -oE '"slack_webhook_url"[[:space:]]*:[[:space:]]*"[^"]*"' "$NOTIFY_CONFIG" 2>/dev/null \
              | sed -E 's/.*:[[:space:]]*"([^"]*)".*/\1/' | head -n1 || true)"
  email="$(grep -oE '"email"[[:space:]]*:[[:space:]]*"[^"]*"' "$NOTIFY_CONFIG" 2>/dev/null \
              | sed -E 's/.*:[[:space:]]*"([^"]*)".*/\1/' | head -n1 || true)"
  local_notify="$(grep -oE '"local_notify"[[:space:]]*:[[:space:]]*(true|false)' "$NOTIFY_CONFIG" 2>/dev/null \
              | grep -oE '(true|false)$' | head -n1 || true)"
  [[ -z "$slack_url" && -z "$email" && "$local_notify" != "true" ]] && return 0
  if [[ -n "$slack_url" ]] && command -v curl >/dev/null 2>&1; then
    # JSON-escape backslash + double-quote in our own controlled text (jq-free).
    local esc payload
    esc="$(printf '%s' "${title}: ${body}" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
    payload="$(printf '{"text":"%s"}' "$esc")"
    ( curl -fsS -m 10 -X POST -H 'Content-Type: application/json' \
        --data "$payload" "$slack_url" >/dev/null 2>&1 || true ) &
  fi
  if [[ -n "$email" ]] && command -v mail >/dev/null 2>&1; then
    ( printf '%s\n' "$body" | mail -s "$title" "$email" >/dev/null 2>&1 || true ) &
  fi
  if [[ "$local_notify" == "true" ]] && command -v osascript >/dev/null 2>&1; then
    local osbody ostitle
    osbody="$(printf '%s' "$body" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
    ostitle="$(printf '%s' "$title" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
    ( osascript -e "display notification \"${osbody}\" with title \"${ostitle}\"" >/dev/null 2>&1 || true ) &
  fi
  return 0
}

# Fire the plan-limit cooldown alert (Layer 2). Thin wrapper over notify_send so
# the cooldown alert and the dead-man's-switch share one config + code path.
# start_cooldown runs once per cooldown window (active cooldowns short-circuit the
# claude tick) so this fires once per "entered cooldown" event, not every heartbeat.
notify_cooldown() {
  local until_str="${1:-?}"
  local project host
  project="$(basename "$(pwd)")"
  host="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo '?')"
  notify_send "backlog-agent cooldown: ${project}@${host}" \
    "⏸ backlog-agent [${project}@${host}] hit the Anthropic plan/session limit — claude ticks paused until ${until_str}"
}

# Record a status-hook outcome for the dead-man's-switch (the repeated-hook-failure
# half; docs/dead-mans-switch.md). $1 = 1 for status_ok, 0 for status_fail; $2 =
# optional reason (e.g. "exit 1" / hook_missing) woven into the alert text. On
# success: clear the state file (resets BOTH the consecutive-fail streak and the
# `alerted` throttle, so the NEXT incident can alert). On failure: bump count; when
# it reaches DMS_HOOKFAIL_THRESHOLD and we haven't already alerted for THIS incident,
# fire ONE notify_send + set `alerted` (so a persistent failure doesn't re-alert
# every tick). node for parse/serialize (already a hard dep; mirrors failcount_*).
# Best-effort: any failure is a silent no-op so the switch can never abort a tick.
_hookfail_record() {
  local ok="${1:-0}" reason="${2:-}"
  [[ -z "${HOOKFAIL_STATE_FILE:-}" ]] && return 0
  if [[ "$ok" == "1" ]]; then
    [[ -f "$HOOKFAIL_STATE_FILE" ]] && rm -f "$HOOKFAIL_STATE_FILE" 2>/dev/null
    return 0
  fi
  mkdir -p "$STATE_DIR" 2>/dev/null || true
  local out count fire
  out="$(node -e '
    const fs = require("fs");
    const [file, thrStr] = [process.argv[1], process.argv[2]];
    const thr = parseInt(thrStr, 10) || 3;
    let obj = {};
    try { obj = JSON.parse(fs.readFileSync(file, "utf8")) || {}; } catch { obj = {}; }
    const count = (Number.isInteger(obj.count) ? obj.count : 0) + 1;
    let fire = 0;
    if (count >= thr && !obj.alerted) { fire = 1; obj.alerted = true; }
    obj.count = count;
    try { fs.writeFileSync(file, JSON.stringify(obj) + "\n"); } catch {}
    process.stdout.write(count + " " + fire);
  ' "$HOOKFAIL_STATE_FILE" "$DMS_HOOKFAIL_THRESHOLD" 2>/dev/null || echo "0 0")"
  count="${out%% *}"; fire="${out##* }"
  [[ "$fire" == "1" ]] || return 0
  local project host msg
  project="$(basename "$(pwd)")"
  host="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo '?')"
  msg="⚠ backlog-agent [${project}@${host}] status hook FAILED ${count} consecutive ticks${reason:+ (${reason})} — the daemon is alive but not syncing/committing. Check .claude/backlog-agent.log."
  log_event dms_hookfail_alert count "$count" reason "${reason:-hook_fail}"
  notify_send "backlog-agent dead-man's-switch: ${project}@${host}" "$msg"
  return 0
}

# --- Per-project budget enforcement (W2; docs/per-project-budget.md) ---
# Echo a one-line reason string (e.g. "5h 3.1M/3.0M" or "week 31M/30M, 5h 3.1M/3.0M")
# if THIS project's rolling token spend is over its per-project cap, else echo
# NOTHING. The whole feature is FAIL-OPEN: any missing/unreadable input — budget
# disabled, no node, no budgets file, no `projects` entry for this project, no cap
# set, or an unreadable ledger — echoes empty (= no enforcement = today's
# behaviour). The cap is keyed by `_health_project` (same identity freeze_exempt
# uses). Spend = a plain sum of the ledger's `tokens` over the window; the ledger
# is git-tracked, so the sum already spans every host (project-total, decision #2).
# Both windows enforce: trips if rolling-5h > cap_5h OR rolling-week > cap_week
# (each independently optional). Side-effect on UNDER-cap: clears the alert-once
# state so the next breach can alert again (mirrors cooldown_active's expiry rm).
# node (a hard dep) does the combined read + windowing in one pass.
_budget_over_cap() {
  [[ "$BUDGET_DISABLE" == "1" ]] && return 0
  command -v node >/dev/null 2>&1 || return 0
  [[ -f "$BUDGETS_FILE" ]] || return 0
  local ledger="${STATE_DIR}/backlog-history.jsonl"
  [[ -f "$ledger" ]] || return 0
  local project now reason
  project="$(_health_project)"
  now="$(date +%s)"
  reason="$(node -e '
    const fs = require("fs");
    const [budgetsFile, ledgerFile, project, nowStr] = process.argv.slice(1);
    const now = parseInt(nowStr, 10);
    let budgets;
    try { budgets = JSON.parse(fs.readFileSync(budgetsFile, "utf8")); } catch { process.exit(0); }
    const p = budgets && budgets.projects && budgets.projects[project];
    if (!p || typeof p !== "object") process.exit(0);            // no entry ⇒ uncapped
    const cap5h = Number.isFinite(p.rolling_5h_tokens)   ? p.rolling_5h_tokens   : null;
    const capWk = Number.isFinite(p.rolling_week_tokens) ? p.rolling_week_tokens : null;
    if (cap5h === null && capWk === null) process.exit(0);       // no cap set ⇒ uncapped
    let data;
    try { data = fs.readFileSync(ledgerFile, "utf8"); } catch { process.exit(0); }
    const cut5h = now - 5 * 3600, cutWk = now - 7 * 24 * 3600;
    let s5 = 0, sw = 0;
    for (const line of data.split("\n")) {
      if (!line.trim()) continue;
      let r; try { r = JSON.parse(line); } catch { continue; }
      const tok = Number.isFinite(r.tokens) ? r.tokens : 0;
      if (tok <= 0) continue;
      const t = Date.parse(r.ts) / 1000;
      if (!Number.isFinite(t)) continue;
      if (t >= cut5h) s5 += tok;
      if (t >= cutWk) sw += tok;
    }
    const fmt = n => n >= 1e6 ? (n / 1e6).toFixed(1) + "M" : n >= 1e3 ? Math.round(n / 1e3) + "k" : "" + n;
    const parts = [];
    if (cap5h !== null && s5 > cap5h) parts.push("5h " + fmt(s5) + "/" + fmt(cap5h));
    if (capWk !== null && sw > capWk) parts.push("week " + fmt(sw) + "/" + fmt(capWk));
    if (parts.length) process.stdout.write(parts.join(", "));
  ' "$BUDGETS_FILE" "$ledger" "$project" "$now" 2>/dev/null || true)"
  if [[ -z "$reason" ]]; then
    rm -f "$BUDGET_STATE_FILE" 2>/dev/null || true   # under cap ⇒ reset alert-once
    return 0
  fi
  printf '%s' "$reason"
  return 0
}

# Fire ONE budget-pause alert per breach, then throttle (mirrors _hookfail_record's
# {alerted} flag). The flag lives in BUDGET_STATE_FILE and is cleared by
# _budget_over_cap when spend drops back under the cap, so a later breach re-alerts.
# Best-effort: any failure is a silent no-op (never aborts a tick).
_budget_alert_once() {
  local reason="${1:-}"
  [[ -z "${BUDGET_STATE_FILE:-}" ]] && return 0
  mkdir -p "$STATE_DIR" 2>/dev/null || true
  # Always refresh `reason` (so the banner shows the current breach); only `fire`
  # the alert on the rising edge (alerted flag not yet set this breach).
  local fire
  fire="$(node -e '
    const fs = require("fs");
    const [file, reason] = [process.argv[1], process.argv[2]];
    let obj = {};
    try { obj = JSON.parse(fs.readFileSync(file, "utf8")) || {}; } catch { obj = {}; }
    let fire = 0;
    if (!obj.alerted) { fire = 1; obj.alerted = true; }
    obj.reason = reason;
    try { fs.writeFileSync(file, JSON.stringify(obj) + "\n"); } catch {}
    process.stdout.write("" + fire);
  ' "$BUDGET_STATE_FILE" "$reason" 2>/dev/null || echo 0)"
  [[ "$fire" == "1" ]] || return 0
  local project host
  project="$(_health_project)"
  host="$(_health_host)"
  log_event budget_alert reason "$reason"
  notify_send "backlog-agent budget cap: ${project}@${host}" \
    "⏸ backlog-agent [${project}@${host}] exceeded its per-project token budget (${reason}) — Claude ticks held (heartbeat-only, or routed to a fallback agent if configured) until the rolling window drains back under the cap."
  return 0
}

# --- Layer 3: alternative-agent fallback (docs/multi-agent-design.md) ---

# Returns 0 (true) iff the opt-in fallback agent is configured AND usable right
# now: AGENT_FALLBACK_FILE exists, jq is present, `.fallback.command` is a
# non-empty array, and the optional `.fallback.available_when` shell test (if
# set) exits 0. Any failure → 1, so the caller falls back to Layer 2 idle.
# Deliberately conservative: a malformed config never breaks the daemon.
fallback_agent_available() {
  [[ -f "$AGENT_FALLBACK_FILE" ]] || return 1
  command -v jq >/dev/null 2>&1 || return 1
  # Must have at least one command element.
  local n; n="$(jq -r '(.fallback.command | length) // 0' "$AGENT_FALLBACK_FILE" 2>/dev/null || echo 0)"
  [[ "$n" =~ ^[0-9]+$ && "$n" -gt 0 ]] || return 1
  # available_when gate (optional). Eval in a subshell so it can't mutate our
  # state; treat a missing/empty test as "always available".
  local guard; guard="$(jq -r '.fallback.available_when // empty' "$AGENT_FALLBACK_FILE" 2>/dev/null || true)"
  if [[ -n "$guard" ]]; then
    ( eval "$guard" ) >/dev/null 2>&1 || return 1
  fi
  return 0
}

# Echo the fallback agent's display name: explicit `.fallback.name`, else the
# basename of command[0] (e.g. "opencode"). Used for the status-hook --agent
# flag and event logging.
fallback_agent_name() {
  local name
  name="$(jq -r '.fallback.name // empty' "$AGENT_FALLBACK_FILE" 2>/dev/null || true)"
  if [[ -z "$name" ]]; then
    name="$(jq -r '.fallback.command[0] // empty' "$AGENT_FALLBACK_FILE" 2>/dev/null || true)"
    name="$(basename "${name:-agent}")"
  fi
  printf '%s' "${name:-agent}"
}

# Populate the global array FALLBACK_CMD with the fallback invocation, with
# every `{prompt}` token in the configured command replaced by $1 (the tick
# prompt). Returns 1 (leaving FALLBACK_CMD unset/empty) if the command can't be
# read — callers only invoke this after fallback_agent_available, so that's a
# defensive guard, not the normal path.
build_fallback_cmd() {
  local prompt="$1"
  FALLBACK_CMD=()
  local el
  while IFS= read -r el; do
    FALLBACK_CMD+=( "${el//\{prompt\}/$prompt}" )
  done < <(jq -r '.fallback.command[]' "$AGENT_FALLBACK_FILE" 2>/dev/null || true)
  [[ ${#FALLBACK_CMD[@]} -gt 0 ]] || return 1
  return 0
}

# ---- helpers: parse claude's "resets X:XXpm" into an epoch ----

# Convert "3:45pm" or "12:00am" to "HH:MM:SS" (24h).
__time_to_24h() {
  local t="$1"
  t="$(echo "$t" | sed -E 's/([0-9])([ap]m)/\1 \2/i')"
  local hour rest min ampm
  hour="${t%%:*}"
  rest="${t#*:}"
  min="${rest%%[apAP ]*}"
  ampm="$(echo "$rest" | tr '[:upper:]' '[:lower:]' | grep -o '[ap]m' || true)"
  hour="${hour// /}"; min="${min// /}"
  # Force base-10 so leading-zero values ("08"/"09") aren't misread as invalid
  # octal by the arithmetic and printf below (in bash, 08 is not a valid number),
  # which would otherwise zero the field and mis-time the cooldown.
  hour=$((10#${hour:-0})); min=$((10#${min:-0}))
  if [[ "$ampm" == "pm" ]]; then
    if [[ "$hour" != "12" ]]; then hour=$(( hour + 12 )); fi
  else
    if [[ "$hour" == "12" ]]; then hour=0; fi
  fi
  printf '%02d:%02d:00' "$hour" "$min"
}

# Parse date+time string to epoch. macOS first, GNU fallback.
__date_parse() {
  local str="$1"
  date -j -f '%Y-%m-%d %H:%M:%S' "$str" '+%s' 2>/dev/null \
    || date -d "$str" '+%s' 2>/dev/null \
    || echo ""
}

# Add N days to an epoch.
__date_add_days() {
  local epoch="$1" days="$2"
  date -j -v+"${days}"d -f '%s' "$epoch" '+%s' 2>/dev/null \
    || date -d "@${epoch} +${days} days" '+%s' 2>/dev/null \
    || echo ""
}

# Parse time-only reset like "3:45pm" → epoch.
__parse_time_only() {
  local time_str="$1" now_epoch="$2" today hms epoch
  today="$(date '+%Y-%m-%d')"
  hms="$(__time_to_24h "$time_str")"
  epoch="$(__date_parse "${today} ${hms}")"
  [[ -z "$epoch" ]] && { echo ""; return 0; }
  if (( epoch <= now_epoch )); then
    epoch="$(__date_add_days "$epoch" 1)"
  fi
  echo "${epoch:-}"
}

# Parse day+time reset like "Mon 12:00am" → epoch.
__parse_day_time() {
  local day_time="$1" now_epoch="$2" day_str time_str today hms epoch
  day_str="${day_time%% *}"; time_str="${day_time#* }"
  today="$(date '+%Y-%m-%d')"
  hms="$(__time_to_24h "$time_str")"
  epoch="$(__date_parse "${today} ${hms}")"
  [[ -z "$epoch" ]] && { echo ""; return 0; }
  local target_num=0
  case "$day_str" in
    Mon) target_num=1 ;; Tue) target_num=2 ;; Wed) target_num=3 ;;
    Thu) target_num=4 ;; Fri) target_num=5 ;; Sat) target_num=6 ;;
    Sun) target_num=7 ;; *) echo ""; return 0 ;;
  esac
  local current_num; current_num="$(date '+%u')"
  local days_ahead=$(( (target_num - current_num + 7) % 7 ))
  if (( days_ahead == 0 )); then
    if (( epoch <= now_epoch )); then days_ahead=7; fi
  fi
  if (( days_ahead > 0 )); then
    epoch="$(__date_add_days "$epoch" "$days_ahead")"
  fi
  echo "${epoch:-}"
}

# Extract "resets X:XXpm" from claude output, return epoch (or "").
_parse_reset_to_epoch() {
  local capture_file="$1" raw reset_str now_epoch
  raw="$(grep -oiE 'resets[[:space:]]+([A-Z][a-z]{2}[[:space:]]+)?[0-9]{1,2}:[0-9]{2}[ap]m' "$capture_file" 2>/dev/null | head -n1 || true)"
  [[ -z "$raw" ]] && { echo ""; return 0; }
  reset_str="$(echo "$raw" | sed -E 's/.*resets[[:space:]]+//i')"
  now_epoch="$(date +%s)"
  if echo "$reset_str" | grep -qiE '^[a-z]{3}[[:space:]][0-9]'; then
    __parse_day_time "$reset_str" "$now_epoch"
  else
    __parse_time_only "$reset_str" "$now_epoch"
  fi
}

_run_status_hook() {
  local item="$1" exit_code="${2:-0}" mode="${3:-loop}" pre_head="$4" pulled="${5:-0}" agent="${6:-claude}"
  # Driver version-skew (W1): stamp the tick with the git SHA of the *shared
  # driver* this daemon is actually running — the last commit touching the bin
  # dir ($LIB_DIR), so it only changes when the machinery changes, not on every
  # docs commit. The dashboard compares this to origin to surface "M1 is running
  # a stale driver" at a glance. Empty if backlog-infra isn't a git checkout.
  local driver_sha
  driver_sha="$(git -C "$LIB_DIR" log -1 --format=%h -- "$LIB_DIR" 2>/dev/null || true)"
  if [[ -n "$HOOK" && -f "$HOOK" ]]; then
    local hook_rc=0 hook_pid hook_wd_pid
    # Wall-clock cap (HOOK_TIMEOUT_SECS) via a pure-bash watchdog. The hook runs
    # network git ops (fetch/push) and fires on EVERY tick outcome (incl. idle),
    # so a stalled network here would wedge even a heartbeat tick. Background +
    # SIGTERM-after-timeout bounds it; a killed hook yields a non-zero hook_rc
    # (logged status_fail) and the tick proceeds. No coreutils `timeout` needed.
    node "$HOOK" --item "$item" --exit-code "$exit_code" --mode "$mode" --pre-head "$pre_head" --pulled "$pulled" --driver-sha "$driver_sha" --agent "$agent" >> "$LOG_FILE" 2>&1 &
    hook_pid=$!
    # Watchdog fds -> /dev/null so an orphaned sleep can't hold our pipe open.
    ( sleep "$HOOK_TIMEOUT_SECS"; kill -TERM "$hook_pid" 2>/dev/null ) >/dev/null 2>&1 &
    hook_wd_pid=$!
    if wait "$hook_pid"; then hook_rc=0; else hook_rc=$?; fi
    # Tear down the watchdog + its sleep child (pkill -P before the parent dies).
    pkill -P "$hook_wd_pid" 2>/dev/null || true
    kill -TERM "$hook_wd_pid" 2>/dev/null || true
    wait "$hook_wd_pid" 2>/dev/null || true
    if [[ $hook_rc -eq 0 ]]; then
      log_event status_ok item "$item"
      _hookfail_record 1
    else
      log_event status_fail item "$item" exit_code "$hook_rc"
      _hookfail_record 0 "exit ${hook_rc}"
    fi
  else
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] status hook not found or not executable: ${HOOK:-<not set>}" | tee -a "$LOG_FILE"
    log_event status_fail item "$item" reason hook_missing
    _hookfail_record 0 hook_missing
  fi
}

_maybe_auto_complete() {
  local item="$1"
  [[ -z "$item" ]] && return 0
  local still_in_progress
  still_in_progress="$(sed -n '/^## Open/,/^## [A-Z]/p' "$BACKLOG_FILE" | grep -cE '^(- )?\[~\] ' || true)"
  [[ "$still_in_progress" -eq 0 ]] && return 0
  local real_changes
  real_changes="$(git -C "$PWD" diff --name-only HEAD 2>/dev/null | grep -vE '^\.claude/' || true)"
  if [[ -n "$real_changes" ]]; then
    return 2
  fi
  if ! git -C "$PWD" diff --name-only HEAD 2>/dev/null | grep -qE '^\.claude/' 2>/dev/null; then
    return 1
  fi
  _local_awk_inplace "$BACKLOG_FILE" '
    BEGIN { in_open=0; done=0 }
    /^## Open/       { in_open=1; print; next }
    /^## [A-Z]/      { if (done) exit; in_open=0; print; next }
    in_open && !done && /^(- )?\[~\] / {
      sub(/\[~\]/, "[x]"); done=1
    }
    { print }
  ' 2>/dev/null || true
  git -C "$PWD" add "$BACKLOG_FILE" 2>/dev/null
  # If the marker flip staged nothing (no [~] matched), there's nothing to land.
  git -C "$PWD" commit -m "auto-complete: ${item} (already implemented)" >/dev/null 2>&1 || return 0
  # CAS, like the claim push: a bare `push || true` would silently drop the [x]
  # completion if a concurrent remote advanced between pull and push, and the
  # next tick's reset would then re-open a done item (audit §3b). On push
  # rejection, rebase the completion on top of origin and retry; if that fails,
  # leave the local [x] commit for the next sync to reconcile — do NOT reset.
  local acbranch; acbranch="$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  if git -C "$PWD" push origin "$acbranch" 2>/dev/null; then
    echo "  [auto-done] ${item} (only metadata changed — already implemented)" | tee -a "$LOG_FILE"
  else
    git -C "$PWD" fetch origin "$acbranch" 2>/dev/null || true
    if git -C "$PWD" pull --rebase origin "$acbranch" 2>/dev/null && git -C "$PWD" push origin "$acbranch" 2>/dev/null; then
      echo "  [auto-done] ${item} (already implemented; rebase + retry)" | tee -a "$LOG_FILE"
    else
      git -C "$PWD" rebase --abort 2>/dev/null || true
      echo "  [auto-done?] ${item} — completion commit not pushed; will reconcile next tick" | tee -a "$LOG_FILE"
    fi
  fi
  return 0
}

# --- Guard 4 (W2): per-tick outcome verification helpers ---

# True iff the just-worked item's title now appears on an [x] line in ## Open,
# i.e. THIS tick claimed completion. Matched as a fixed substring (titles carry
# regex-special chars: **, (, ), `) so claude appending a one-line summary to the
# [x] line still counts. Scoped to ## Open because that's where the canonical
# in-place [~]→[x] flip lands (compaction → Done runs later, in _post_tick_cleanup).
_completion_claimed() {
  local item="$1"
  [[ -z "$item" ]] && return 1
  sed -n '/^## Open/,/^## [A-Z]/p' "$BACKLOG_FILE" 2>/dev/null \
    | grep -F -- "$item" | grep -qE '^(- )?\[x\] '
}

# Populate the global array GATE_CMD with the project's verification command, in
# precedence order: (1) .claude/backlog-gate.json `.gate` (array ⇒ argv run
# directly; string ⇒ run via `bash -c`); (2) package.json — a "verify" script,
# else "typecheck" && "test" chained via `bash -c` (npm's stock "no test
# specified" placeholder is ignored). Returns 1 (GATE_CMD empty) when no gate is
# defined ⇒ caller FAILS OPEN. Uses node (a hard dependency already — see
# failcount_*); no jq needed, and package.json parsing is robust.
resolve_gate() {
  GATE_CMD=()
  [[ "$GATE_DISABLE" == "1" ]] && return 1
  command -v node >/dev/null 2>&1 || return 1
  local line
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    GATE_CMD+=( "$line" )
  done < <(node -e '
    // Resolve the gate argv, then print ONCE at the end. NB: do NOT
    // process.exit() right after stdout.write — when stdout is a pipe (this runs
    // under a process substitution) the write is async and exit() truncates it
    // (the classic node pipe-flush footgun). Letting node end naturally flushes.
    const fs = require("fs");
    const [gateFile, pkgFile] = [process.argv[1], process.argv[2]];
    let out = null;
    // 1. explicit per-project config.
    try {
      const g = (JSON.parse(fs.readFileSync(gateFile, "utf8")) || {}).gate;
      if (Array.isArray(g) && g.length) out = g.map(String);
      else if (typeof g === "string" && g.trim()) out = ["bash", "-c", g];
    } catch {}
    // 2. package.json convention fallback.
    if (!out) {
      try {
        const s = (JSON.parse(fs.readFileSync(pkgFile, "utf8")) || {}).scripts || {};
        if (s.verify) out = ["npm", "run", "verify"];
        else {
          const chain = [];
          if (s.typecheck) chain.push("npm run typecheck");
          // Ignore the npm default placeholder so a project with no real tests
          // is not falsely failed (reopened forever until the breaker blocks it).
          if (s.test && !/no test specified/i.test(s.test)) chain.push("npm run test");
          if (chain.length) out = ["bash", "-c", chain.join(" && ")];
        }
      } catch {}
    }
    // 3. no gate ⇒ print nothing ⇒ caller fails open. The trailing newline is
    // load-bearing: `while read` drops a final unterminated line, so without it a
    // single-element gate (the common case) would never enter the loop body.
    if (out) process.stdout.write(out.join("\n") + "\n");
  ' "$GATE_FILE" "package.json" 2>/dev/null || true)
  [[ ${#GATE_CMD[@]} -gt 0 ]] || return 1
  return 0
}

# Run the resolved gate (GATE_CMD) on the current HEAD under a pure-bash
# wall-clock watchdog (GATE_TIMEOUT_SECS), mirroring the claude/status-hook
# watchdogs so a hanging test can never wedge the tick. Captures combined output
# to $1. Returns the gate's real exit (0 = pass); a watchdog kill yields a
# non-zero (143) which the caller treats as a FAILED verification.
run_gate() {
  local out_file="$1"
  local gpid gwd grc=0
  "${GATE_CMD[@]}" < /dev/null > "$out_file" 2>&1 &
  gpid=$!
  ( sleep "$GATE_TIMEOUT_SECS"; kill -TERM "$gpid" 2>/dev/null ) >/dev/null 2>&1 &
  gwd=$!
  if wait "$gpid"; then grc=0; else grc=$?; fi
  pkill -P "$gwd" 2>/dev/null || true
  kill -TERM "$gwd" 2>/dev/null || true
  wait "$gwd" 2>/dev/null || true
  return "$grc"
}

# --- Per-item token/turn/spend ceiling helpers (W2; docs/per-item-ceiling.md) ---

# Resolve the effective per-item ceilings for an item title into the globals
# CEIL_TURNS, CEIL_TOKENS (integers, 0 = uncapped) and CEIL_BUDGET_USD (a number
# string, "0" = no preventive cap). Precedence (each later layer overrides):
#   env defaults (MAX_*_PER_TICK)  →  CEILINGS_FILE top-level (project default)
#   →  CEILINGS_FILE `items` entry whose KEY is a substring of the item title.
# Absent everything ⇒ 0/0/0 (uncapped). FAIL-OPEN: unreadable config ⇒ env values
# only. node (a hard dep) parses the JSON robustly; no jq. Called once pre-tick
# (to build --max-budget-usd) and reused post-tick (the globals persist).
resolve_ceiling() {
  CEIL_TURNS=0; CEIL_TOKENS=0; CEIL_BUDGET_USD=0
  [[ "$CEILING_DISABLE" == "1" ]] && return 0
  command -v node >/dev/null 2>&1 || return 0
  [[ -n "${1:-}" ]] || return 0
  local out
  out="$(node -e '
    const fs = require("fs");
    const [file, item, envTurns, envTokens, envBudget] = process.argv.slice(1);
    const numOr = (v, d) => { const n = parseFloat(v); return Number.isFinite(n) ? n : d; };
    let turns = numOr(envTurns, 0), tokens = numOr(envTokens, 0), budget = numOr(envBudget, 0);
    const apply = (o) => {
      if (!o || typeof o !== "object") return;
      if (Number.isFinite(o.max_turns))      turns  = o.max_turns;
      if (Number.isFinite(o.max_tokens))     tokens = o.max_tokens;
      if (Number.isFinite(o.max_budget_usd)) budget = o.max_budget_usd;
    };
    let cfg = null;
    try { cfg = JSON.parse(fs.readFileSync(file, "utf8")); } catch {}
    if (cfg && typeof cfg === "object") {
      apply(cfg);                                       // project-level default
      const items = cfg.items && typeof cfg.items === "object" ? cfg.items : null;
      if (items) {                                      // per-item override
        for (const k of Object.keys(items)) {
          if (k && item.includes(k)) { apply(items[k]); break; }
        }
      }
    }
    const i = n => (n > 0 ? Math.floor(n) : 0);
    const u = n => (n > 0 ? n : 0);
    process.stdout.write(i(turns) + " " + i(tokens) + " " + u(budget));
  ' "$CEILINGS_FILE" "$1" "$MAX_TURNS_PER_TICK" "$MAX_TOKENS_PER_TICK" "$MAX_BUDGET_USD_PER_TICK" 2>/dev/null || true)"
  [[ -n "$out" ]] || return 0
  read -r CEIL_TURNS CEIL_TOKENS CEIL_BUDGET_USD <<<"$out"
  [[ "$CEIL_TURNS"      =~ ^[0-9]+$ ]]            || CEIL_TURNS=0
  [[ "$CEIL_TOKENS"     =~ ^[0-9]+$ ]]            || CEIL_TOKENS=0
  [[ "$CEIL_BUDGET_USD" =~ ^[0-9]+(\.[0-9]+)?$ ]] || CEIL_BUDGET_USD=0
  return 0
}

# Read THIS tick's actual turns + headline tokens from claude's newest session
# transcript into the globals USAGE_TURNS / USAGE_TOKENS (empty ⇒ unreadable ⇒
# the caller FAILS OPEN). Mirrors backlog-agent-status.mjs findNewestTranscript +
# extractUsage: the transcript lives under ~/.claude/projects/<cwd-with-/-as-->/
# (newest *.jsonl by mtime); each `claude -p` writes a fresh session there, so the
# newest one right after claude exits is THIS tick's. Headline tokens =
# input+output+cache_creation (excludes cache_read), identical to the ledger's
# `tokens` so the ceiling and the per-project budget measure the same quantity.
_read_tick_usage() {
  USAGE_TURNS=""; USAGE_TOKENS=""
  command -v node >/dev/null 2>&1 || return 0
  local out
  out="$(node -e '
    const fs = require("fs"), os = require("os"), path = require("path");
    const cwd = process.argv[1];
    const dir = path.join(os.homedir(), ".claude", "projects", cwd.split("/").join("-"));
    let newest = null, mt = 0;
    try {
      for (const n of fs.readdirSync(dir)) {
        if (!n.endsWith(".jsonl")) continue;
        const f = path.join(dir, n);
        let m; try { m = fs.statSync(f).mtimeMs; } catch { continue; }
        if (m > mt) { mt = m; newest = f; }
      }
    } catch { process.exit(0); }                        // no dir ⇒ fail open
    if (!newest) process.exit(0);
    let text; try { text = fs.readFileSync(newest, "utf8"); } catch { process.exit(0); }
    let lastResult = null, turns = 0;
    const seen = new Set();
    const summed = { input: 0, output: 0, cache_creation: 0 };
    for (const line of text.split("\n")) {
      if (!line) continue;
      let o; try { o = JSON.parse(line); } catch { continue; }
      if (o.type === "result" && (o.usage || o.num_turns != null)) {
        lastResult = o;
      } else if (o.type === "assistant" && o.message && o.message.usage) {
        const id = o.message.id;
        if (id) { if (seen.has(id)) continue; seen.add(id); }
        const usg = o.message.usage;
        summed.input          += usg.input_tokens ?? 0;
        summed.output         += usg.output_tokens ?? 0;
        summed.cache_creation += usg.cache_creation_input_tokens ?? 0;
        if (o.message.stop_reason) turns++;
      }
    }
    let t, tok;
    if (lastResult && lastResult.usage) {
      const usg = lastResult.usage;
      t   = lastResult.num_turns != null ? lastResult.num_turns : turns;
      tok = (usg.input_tokens ?? 0) + (usg.output_tokens ?? 0) + (usg.cache_creation_input_tokens ?? 0);
    } else {
      t = turns; tok = summed.input + summed.output + summed.cache_creation;
    }
    process.stdout.write(String(t) + " " + String(tok));
  ' "$PWD" 2>/dev/null || true)"
  [[ -n "$out" ]] || return 0
  read -r USAGE_TURNS USAGE_TOKENS <<<"$out"
  [[ "$USAGE_TURNS"  =~ ^[0-9]+$ ]] || USAGE_TURNS=""
  [[ "$USAGE_TOKENS" =~ ^[0-9]+$ ]] || USAGE_TOKENS=""
  return 0
}

# --- Secret-scanning pre-push gate: install (docs/secret-scan.md) ---
# The hook stub (prepush_hook_body), version/marker, and foreign/current
# detectors live in _lib.sh — shared with the CLI's install-hooks + doctor.
#
# Ensure THIS repo's .git/hooks/pre-push is our current-version gate. Idempotent,
# version-keyed, best-effort (never aborts a tick). Self-heals a missing/empty or
# stale-version hook every tick; LEAVES a foreign hook (non-empty, no marker)
# untouched so we never clobber a user's own pre-push hook. Echoes a one-line note
# only on a (re)write or a foreign-hook skip.
ensure_prepush_hook() {
  [[ "$SECRET_SCAN_DISABLE" == "1" ]] && return 0
  local gitdir; gitdir="$(git -C "$PWD" rev-parse --git-dir 2>/dev/null || true)"
  [[ -n "$gitdir" ]] || return 0
  case "$gitdir" in /*) : ;; *) gitdir="$PWD/$gitdir" ;; esac
  local hook="$gitdir/hooks/pre-push"
  # A NON-EMPTY pre-push hook without our marker is a real user hook — never
  # clobber it (use `backlog-agents install-hooks --force`). Empty/missing ⇒ ok.
  if prepush_hook_is_foreign "$hook"; then
    echo "  [secret-scan] pre-push hook present but not ours — leaving foreign hook untouched (use \`backlog-agents install-hooks --force\` to replace)" | tee -a "$LOG_FILE"
    return 0
  fi
  prepush_hook_is_current "$hook" && return 0
  mkdir -p "$gitdir/hooks" 2>/dev/null || return 0
  if prepush_hook_body "$SECRET_SCAN_BIN" > "$hook" 2>/dev/null; then
    chmod +x "$hook" 2>/dev/null || true
    echo "  [secret-scan] installed/updated pre-push gate (version ${PREPUSH_HOOK_VERSION})" | tee -a "$LOG_FILE"
    log_event secret_hook_installed version "$PREPUSH_HOOK_VERSION"
  fi
  return 0
}

tick_once() {
  local ts pre_head item_title claude_exit
  # Layer 3: which agent runs this tick. "claude" normally; set to the fallback
  # agent's name when a cooldown is active and a fallback is configured/available.
  local agent_name="claude" use_fallback=""

  # Per-tick mutex. do_run runs the polling loop AND an fswatch subshell that
  # fires whenever BACKLOG_FILE changes — including the daemon's OWN claim /
  # reclaim commits. Without this, the two drivers can run tick_once
  # concurrently, each claiming the same item and spawning its own claude.
  # The process lock (acquire_lock) is held for the daemon's whole lifetime
  # and does NOT serialize ticks within one daemon. Take a short-lived lock
  # here; if another tick holds it, skip silently. Released via the RETURN
  # trap below; cleared across daemon restarts by release_lock / acquire_lock.
  if ! mkdir "$TICK_LOCK_DIR" 2>/dev/null; then
    TICK_OUTCOME=idle
    return 0
  fi
  trap 'rmdir "$TICK_LOCK_DIR" 2>/dev/null || true' RETURN

  ts="$(date '+%Y-%m-%d %H:%M:%S')"
  local tick_start_epoch; tick_start_epoch="$(date +%s)"
  {
    echo
    echo "================================================================"
    echo "[$ts] tick start"
    echo "================================================================"
  } | tee -a "$LOG_FILE"
  log_event tick_start

  # Self-heal the secret-scanning pre-push gate every tick (cheap file write,
  # best-effort) — BEFORE any short-circuit so even an idle/heartbeat/cooldown
  # tick keeps the clone's hook current. docs/secret-scan.md.
  ensure_prepush_hook

  # --- Layer 2: plan-limit cooldown short-circuit (local + account-wide) ---
  # A prior tick may have hit the Anthropic plan/session cap and armed a
  # cooldown (docs/multi-agent-design.md). While it's active, skip the claude
  # invocation entirely — it would just fail again in ~1s and burn a
  # fail-loop. Heartbeat the status file so the fleet view shows the daemon
  # alive (not STALE), then return without claiming any item.
  #
  # The cooldown is the UNION of THIS project's LOCAL cooldown and the FLEET-WIDE
  # account cooldown published to D1 by whichever daemon FIRST hit the per-account
  # plan limit (account-cooldown, W2). Consulting the account signal FIRST means
  # the whole fleet stands down at once — the other daemons no longer each have to
  # fail their own claude call to discover the cap. The account read FAILS OPEN
  # (D1 unreachable ⇒ empty), so it degrades cleanly to the existing local-only
  # behaviour — never a regression to the per-project cooldown.
  local acct_cd_epoch; acct_cd_epoch="$(_d1_account_cooldown_epoch)"
  if cooldown_active || [[ -n "$acct_cd_epoch" ]]; then
    # --- Layer 3: alternative-agent fallback ---
    # Rather than idling through the whole cooldown, if an opt-in fallback agent
    # (e.g. OpenCode/DeepSeek) is configured and available, fall THROUGH to the
    # normal claim+work path with that agent driving the tick. The Anthropic plan
    # limit (local OR account) is per-account; a different provider isn't capped,
    # so simple items can still make progress. If no fallback is available, keep
    # the Layer 2 heartbeat-only behavior below.
    if fallback_agent_available; then
      use_fallback=1
      agent_name="$(fallback_agent_name)"
      echo "[$(date '+%Y-%m-%d %H:%M:%S')] plan-limit cooldown active; running this tick via fallback agent '${agent_name}' (Layer 3)" | tee -a "$LOG_FILE"
      log_event fallback_agent agent "$agent_name"
      # fall through — do NOT short-circuit.
    else
    # Effective reset = the LATER of the local + account until_epoch (whichever is
    # active) so the daemon loop sleeps until the fleet actually resumes.
    local local_cd_epoch eff_epoch cd_source cd_until
    local_cd_epoch="$(grep -oE '"until_epoch"[[:space:]]*:[[:space:]]*[0-9]+' "$COOLDOWN_FILE" 2>/dev/null | grep -oE '[0-9]+$' | head -n1 || true)"
    eff_epoch="$acct_cd_epoch"
    if [[ -n "$local_cd_epoch" ]]; then
      if [[ -z "$eff_epoch" ]] || (( local_cd_epoch > eff_epoch )); then eff_epoch="$local_cd_epoch"; fi
    fi
    if [[ -n "$acct_cd_epoch" ]]; then
      cd_source="account"; [[ -n "$local_cd_epoch" ]] && cd_source="local+account"
    else
      cd_source="local"
    fi
    cd_until=""
    if [[ -n "$eff_epoch" ]]; then
      cd_until="$(date -u -r "$eff_epoch" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date -u -d "@$eff_epoch" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo '')"
    fi
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] plan-limit cooldown active (${cd_source}) until ${cd_until:-?}; heartbeat only (skipping claude)" | tee -a "$LOG_FILE"
    pre_head="$(git rev-parse HEAD 2>/dev/null || echo '')"
    _run_status_hook "" 0 loop "$pre_head" 0
    _post_tick_cleanup
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] tick done (cooldown)" | tee -a "$LOG_FILE"
    # Communicate exact wait time to the caller so the daemon loop can
    # sleep precisely until the reset moment instead of polling.
    if [[ -n "$eff_epoch" ]]; then
      local now_ep; now_ep="$(date +%s)"
      COOLDOWN_WAIT_SECONDS=$(( eff_epoch - now_ep > 0 ? eff_epoch - now_ep : 0 ))
    fi
    log_event tick_done outcome cooldown source "$cd_source" duration_s "$(( $(date +%s) - tick_start_epoch ))"
    TICK_OUTCOME=cooldown
    return 0
    fi  # end fallback-unavailable (Layer 2 idle) branch
  fi

  # --- Per-project budget enforcement (W2; docs/per-project-budget.md) ---
  # Self-imposed SPEND cap (distinct from the account plan-limit cooldown above):
  # if THIS project's own rolling token spend exceeds a per-project cap in
  # backlog-budgets.json, pause to heartbeat-only + alert ONCE, self-clearing as
  # the rolling window drains. backlog-infra's OWN daemon is EXEMPT (operated
  # interactively — like freeze/pause). Like the cooldown above, this honors the
  # Layer-3 fallback: a budget cap is on *Anthropic* spend, so a non-Claude
  # fallback may still drive the tick. The `use_fallback` guard avoids re-handling
  # if the cooldown block already chose the fallback this tick.
  if [[ "$use_fallback" != "1" ]] && ! freeze_exempt; then
    local _budget_reason; _budget_reason="$(_budget_over_cap)"
    if [[ -n "$_budget_reason" ]]; then
      _budget_alert_once "$_budget_reason"
      if fallback_agent_available; then
        use_fallback=1
        agent_name="$(fallback_agent_name)"
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] per-project budget cap exceeded (${_budget_reason}); running this tick via fallback agent '${agent_name}' (non-Anthropic spend)" | tee -a "$LOG_FILE"
        log_event budget_fallback agent "$agent_name" reason "$_budget_reason"
        # fall through to the normal claim + work flow with the fallback agent
      else
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] per-project budget cap exceeded (${_budget_reason}); heartbeat only (skipping claude until the rolling window drains under the cap)" | tee -a "$LOG_FILE"
        pre_head="$(git rev-parse HEAD 2>/dev/null || echo '')"
        _run_status_hook "" 0 loop "$pre_head" 0
        _post_tick_cleanup
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] tick done (budget)" | tee -a "$LOG_FILE"
        log_event budget_paused reason "$_budget_reason"
        log_event tick_done outcome budget reason "$_budget_reason" duration_s "$(( $(date +%s) - tick_start_epoch ))"
        TICK_OUTCOME=budget
        return 0
      fi
    fi
  fi

  # --- Fleet control short-circuit: stop / pause / freeze (docs/fleet-freeze.md) ---
  # ONE combined read (the endpoint resolves precedence stop > pause > freeze and
  # returns the effective "mode"). Structural twin of the cooldown short-circuit
  # above. Behaviour by mode:
  #   stop  — FULL HALT. No work, no heartbeat: exit the tick (TICK_OUTCOME=stop)
  #           so the daemon loop breaks and the process exits. launchd respawns
  #           after ThrottleInterval and re-reads stop (exits again), so the daemon
  #           stays effectively down until `backlog-agents start` clears it; the
  #           in-flight claim is reaped once its heartbeat goes stale. No infra
  #           exemption — stop halts EVERY daemon. `launchctl bootout` is the hard
  #           local backstop for a true process-level halt.
  #   pause  — manual heartbeat-only hold. backlog-infra's OWN daemon is EXEMPT
  #            (only stop halts it), mirroring freeze.
  #   freeze — auto-armed heartbeat-only hold while a driver change propagates.
  #            backlog-infra's OWN daemon is EXEMPT: for it the flag is a signal
  #            to EVALUATE the clear (delegated to `backlog-agents freeze --eval`),
  #            then keep ticking so the fix can land + the fleet can thaw.
  # Reads FAIL-OPEN (D1 down ⇒ no control), stop included.
  local _control _ctl_mode _ctl_reason
  _control="$(_d1_control_get)"
  _ctl_mode="${_control%%$'\t'*}"
  _ctl_reason="${_control#*$'\t'}"
  [[ "$_ctl_reason" == "$_control" ]] && _ctl_reason=""   # no tab ⇒ no reason
  case "$_ctl_mode" in
    stop)
      echo "[$(date '+%Y-%m-%d %H:%M:%S')] fleet STOP active (${_ctl_reason:-manual stop}); halting daemon — no work, no heartbeat (clears on \`backlog-agents start\`; \`launchctl bootout\` for a hard halt)" | tee -a "$LOG_FILE"
      log_event tick_done outcome stop reason "${_ctl_reason:-}" duration_s "$(( $(date +%s) - tick_start_epoch ))"
      TICK_OUTCOME=stop
      return 0
      ;;
    pause|freeze)
      if freeze_exempt; then
        if [[ "$_ctl_mode" == "freeze" ]]; then
          echo "[$(date '+%Y-%m-%d %H:%M:%S')] fleet-freeze active — exempt daemon (${FREEZE_PROJECT}); evaluating clear, continuing to tick" | tee -a "$LOG_FILE"
          # Best-effort clear (skew zero across live hosts AND canary green).
          # Never blocks this tick — the exempt daemon always proceeds to work.
          if command -v backlog-agents >/dev/null 2>&1; then
            backlog-agents freeze --eval >>"$LOG_FILE" 2>&1 || true
          fi
        else
          echo "[$(date '+%Y-%m-%d %H:%M:%S')] fleet PAUSE active — exempt daemon (${FREEZE_PROJECT}); continuing to tick (only \`stop\` halts the control-plane daemon)" | tee -a "$LOG_FILE"
        fi
        # fall through to the normal claim + work flow
      else
        local _hold_label="fleet-freeze"
        [[ "$_ctl_mode" == "pause" ]] && _hold_label="fleet-pause"
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] ${_hold_label} active (${_ctl_reason:-in-flight infra change}); heartbeat only (skipping claude until the fleet resumes)" | tee -a "$LOG_FILE"
        pre_head="$(git rev-parse HEAD 2>/dev/null || echo '')"
        _run_status_hook "" 0 loop "$pre_head" 0
        _post_tick_cleanup
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] tick done (${_hold_label})" | tee -a "$LOG_FILE"
        log_event tick_done outcome "$_ctl_mode" reason "${_ctl_reason:-}" duration_s "$(( $(date +%s) - tick_start_epoch ))"
        TICK_OUTCOME="$_ctl_mode"
        return 0
      fi
      ;;
  esac

  # Pull before reading the backlog — catches cross-machine changes from
  # other computers that pushed to origin. Best-effort: no upstream is fine,
  # network failure is fine, dirty working tree is fine (leave it alone).
  # Track how many commits were pulled so the dashboard shows activity.
  # Pre-check SSH so failures produce a clear diagnostic rather than a
  # confusing "Permission denied (publickey)" buried in the log.
  local pulled=0 head_before head_after
  local ssh_ok=0
  check_github_ssh && ssh_ok=1
  if git -C "$PWD" rev-parse --abbrev-ref @{u} >/dev/null 2>&1; then
    head_before="$(git -C "$PWD" rev-parse HEAD 2>/dev/null || echo '')"
    # Fetch first (always safe, no-op on failure), then fast-forward
    # if possible. If HEAD has diverged from origin (local commits
    # that were never pushed, e.g. a claude push that failed), reset
    # to origin to recover the sync channel. The daemon's work is
    # idempotent — a discarded commit will be redone on the next tick
    # if the item is still open.
     branch="$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    git -C "$PWD" fetch origin "$branch" 2>&1 | sed 's/^/  [git] /' | tee -a "$LOG_FILE" || true
    if git -C "$PWD" merge-base --is-ancestor HEAD "origin/$branch" 2>/dev/null; then
      # Stash dirty per-host status files before merge — they are written
      # every tick by the status hook and cause frequent merge conflicts
      # when the other machine has pushed its own copies.
      local stashed=false
      if ! git -C "$PWD" diff --quiet -- ".claude/backlog-status-"*".json" 2>/dev/null; then
        if git -C "$PWD" stash push -- ".claude/backlog-status-"*".json" 2>/dev/null; then
          stashed=true
        fi
      fi
      if ! git -C "$PWD" merge --ff-only "origin/$branch" 2>&1 | sed 's/^/  [git] /' | tee -a "$LOG_FILE"; then
        echo "  [git] fast-forward merge failed (continuing)" | tee -a "$LOG_FILE"
      fi
      if [[ "$stashed" == "true" ]]; then
        git -C "$PWD" stash pop 2>/dev/null || git -C "$PWD" stash drop 2>/dev/null || true
      fi
    else
      # Stash dirty per-host files before rebase/reset to avoid losing
      # status data written by this machine's status hook.
      local stashed=false
      if ! git -C "$PWD" diff --quiet -- ".claude/backlog-status-"*".json" 2>/dev/null; then
        if git -C "$PWD" stash push -- ".claude/backlog-status-"*".json" 2>/dev/null; then
          stashed=true
        fi
      fi
      echo "  [git] local diverged from origin/${branch}; attempting rebase" | tee -a "$LOG_FILE"
      if git -C "$PWD" pull --rebase origin "$branch" 2>/dev/null; then
        echo "  [git] rebase succeeded (local commits preserved on top of origin)" | tee -a "$LOG_FILE"
      else
        git -C "$PWD" rebase --abort 2>/dev/null || true
        # Capture the about-to-be-discarded HEAD so the reset isn't silent. The
        # commit(s) here can include real unpushed work claude committed but
        # couldn't push; reset --hard leaves them in the reflog, so log the SHA
        # loudly with the recovery command (audit §4c).
        local discarded_sha; discarded_sha="$(git -C "$PWD" rev-parse --short HEAD 2>/dev/null || true)"
        git -C "$PWD" reset --hard "origin/$branch" 2>/dev/null || true
        echo "  [git] rebase conflict — reset to origin; discarded local commit ${discarded_sha:-?} (recover: git reflog / git reset --hard ${discarded_sha:-<sha>})" | tee -a "$LOG_FILE"
        log_event reset_discarded sha "${discarded_sha:-}" reason rebase_conflict
      fi
      if [[ "$stashed" == "true" ]]; then
        git -C "$PWD" stash pop 2>/dev/null || git -C "$PWD" stash drop 2>/dev/null || true
      fi
    fi
    head_after="$(git -C "$PWD" rev-parse HEAD 2>/dev/null || echo '')"
    if [[ -n "$head_before" && -n "$head_after" && "$head_before" != "$head_after" ]]; then
      pulled="$(git -C "$PWD" rev-list --count "${head_before}..${head_after}" 2>/dev/null || echo 0)"
      echo "  [git] pulled ${pulled} commit(s)" | tee -a "$LOG_FILE"
    fi
  fi

  # Auto-flip [?] items that have [user] answers, so manual `backlog-agent unblock`
  # is only needed when the user explicitly wants to block (no answer yet).
  auto_flip_blocked

  # Reclaim stale [~] items from dead daemons before selecting the next
  # item. This runs after the pull (origin is current) and before item
  # selection, so reclaimed items become eligible on this tick.
  reclaim_stale_claims

  pre_head="$(git rev-parse HEAD 2>/dev/null || echo '')"
  # Only match items within the Open section (daemon never touches Thinking).
  # sed extracts from ## Open to next ## header or EOF; grep matches within.
  item_title="$(sed -n '/^## Open/,/^## [A-Z]/p' "$BACKLOG_FILE" 2>/dev/null | grep -m1 -E "$ITEM_REGEX" | strip_marker || true)"

  # Write the in-flight sentinel so `backlog-agent` (status) can show that a tick
  # is actively running rather than just "last tick 44m ago". Format:
  # <daemon_pid>\t<start_epoch>\t<item_title>. Cleared after the HOOK below.
  # If the daemon is SIGKILL'd mid-tick the sentinel is orphaned; status
  # reconciles by checking that the recorded PID is still alive.
  if [[ -n "$INFLIGHT_FILE" ]]; then
    printf '%s\t%s\t%s\n' "$$" "$(date +%s)" "$item_title" > "$INFLIGHT_FILE"
  fi

  # If we reclaimed stale claims, commit + push the reclaim now (before the
  # claim below). Bundling the reclaim into the later claim commit fails when
  # the reclaimed item is also the one selected: reclaim flips [~]→[ ] and the
  # claim flips [ ]→[~], cancelling to a zero net diff, so the claim commit is
  # skipped and the tick aborts as "claim push failed". Committing the reclaim
  # separately keeps the claim's [ ]→[~] a real diff so the CAS push still works.
  if [[ $RECLAIMED_COUNT -gt 0 ]]; then
    if ! git -C "$PWD" diff --quiet "$BACKLOG_FILE" 2>/dev/null; then
      git -C "$PWD" add "$BACKLOG_FILE"
      git -C "$PWD" commit -m "reclaim: ${RECLAIMED_COUNT} stale claim(s)" >/dev/null 2>&1 || true
      git -C "$PWD" push origin "$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null)" 2>/dev/null || true
      echo "  [reclaim] pushed ${RECLAIMED_COUNT} stale claim recovery" | tee -a "$LOG_FILE"
    fi
  fi

  # If no open [-] or [!] items, skip the claude invocation entirely.
  # The heartbeat still updates the status file so the fleet view knows
  # the daemon is alive, but we don't burn tokens on an idle tick.
  if [[ -z "$item_title" ]]; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] no open items; heartbeat only (skipping claude)" | tee -a "$LOG_FILE"
    _run_status_hook "" 0 loop "$pre_head" "$pulled"
    _post_tick_cleanup
    [[ -n "$INFLIGHT_FILE" ]] && rm -f "$INFLIGHT_FILE"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] tick done (idle)" | tee -a "$LOG_FILE"
    log_event tick_done outcome idle duration_s "$(( $(date +%s) - tick_start_epoch ))"
    TICK_OUTCOME=idle
    return 0
  fi

  # --- Guard 1 (W2): per-item circuit breaker ---
  # If this exact item has already failed CIRCUIT_BREAKER_THRESHOLD ticks in a
  # row, stop re-claiming it. Flip it [ ]/[!] → [?] in place with an inline
  # note, commit+push just that markup (same unclaim commit+push pattern as
  # below), and skip claude entirely so the user can weigh in. The per-item
  # counter is reset only when the item completes or a tick succeeds.
  local item_fails; item_fails="$(failcount_get "$item_title")"
  if (( item_fails >= CIRCUIT_BREAKER_THRESHOLD )); then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] circuit breaker: '${item_title}' failed ${item_fails}x consecutively — auto-blocking [?] and skipping claude" | tee -a "$LOG_FILE"
    # Flip the first eligible [ ]/[!] item in ## Open to [?] and append the
    # auto-block note. Scoped to ## Open like the claim flip; matches only
    # the first item so we never touch a later one.
    _local_awk_inplace "$BACKLOG_FILE" '
      BEGIN { in_open=0; done=0 }
      /^## Open/       { in_open=1; print; next }
      /^## [A-Z]/      { if (done) exit; in_open=0; print; next }
      in_open && !done && /^(- )?\[[ !]\] / {
        sub(/\[[ !]\]/, "[?]")
        $0 = $0 " — [circuit-breaker] auto-blocked after '"$CIRCUIT_BREAKER_THRESHOLD"' failed attempts"
        done=1
      }
      { print }
    ' 2>/dev/null || true
    if ! git -C "$PWD" diff --quiet "$BACKLOG_FILE" 2>/dev/null; then
      git -C "$PWD" add "$BACKLOG_FILE" 2>/dev/null
      git -C "$PWD" commit -m "circuit-breaker: auto-block ${item_title}" >/dev/null 2>&1
      git -C "$PWD" push origin "$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null)" 2>/dev/null || true
      echo "  [circuit-breaker] auto-blocked ${item_title}" | tee -a "$LOG_FILE"
    fi
    log_event circuit_tripped item "$item_title" fails "$item_fails"
    # The item is no longer open; drop its counter so a later retry starts fresh.
    failcount_reset "$item_title"
    _run_status_hook "" 0 loop "$pre_head" "$pulled"
    _post_tick_cleanup
    [[ -n "$INFLIGHT_FILE" ]] && rm -f "$INFLIGHT_FILE"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] tick done (circuit-breaker)" | tee -a "$LOG_FILE"
    log_event tick_done outcome circuit_breaker item "$item_title" duration_s "$(( $(date +%s) - tick_start_epoch ))"
    TICK_OUTCOME=idle
    return 0
  fi

  # Flip the selected item from [ ] → [~] so other machines on the same
  # project skip it. Commit+push the marker change before claude runs.
  # If claude fails, flip it back. If the daemon crashes mid-tick the [~]
  # item stays stuck — recoverable via `backlog-agent unclaim`.
  local claimed=false
  if [[ -n "$item_title" ]]; then
    # Stamp the claim with THIS host so the reaper probes the right owner.
    local owner_tag; owner_tag="$(_owner_tag)"
    _local_awk_inplace "$BACKLOG_FILE" '
      BEGIN { in_open=0; done=0 }
      /^## Open/       { in_open=1; print; next }
      /^## [A-Z]/      { if (done) exit; in_open=0; print; next }
      in_open && !done && /^(- )?\[[ !]\] / {
        sub(/\[[ !]\]/, "[~]"); $0 = $0 owner; done=1
      }
      { print }
    ' -v owner="$owner_tag" 2>/dev/null || true
    if ! git -C "$PWD" diff --quiet "$BACKLOG_FILE" 2>/dev/null; then
      git -C "$PWD" add "$BACKLOG_FILE"
      if git -C "$PWD" commit -m "claim: ${item_title}" >/dev/null 2>&1; then
        local claim_pushed=true
        git -C "$PWD" push origin "$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null)" 2>/dev/null || claim_pushed=false
        if [[ "$claim_pushed" == "true" ]]; then
          claimed=true
          echo "  [claim] ${item_title}" | tee -a "$LOG_FILE"
          log_event claim item "$item_title"
        else
          # Push failed — another machine may have pushed first. Try to
          # rebase the claim on top of origin. If the item is still open
          # on the remote the rebase succeeds and we retry the push. If a
          # merge conflict occurs (someone else claimed the same item),
          # abort the rebase and reset so the next tick proceeds cleanly.
          local branch
          # `|| true`: a non-zero rev-parse (unborn / transiently-locked HEAD on
          # this race-recovery path) must not trip set -e and kill the daemon —
          # matches the guarded rev-parse siblings elsewhere in the file.
          branch="$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
          git -C "$PWD" fetch origin "$branch" 2>/dev/null || true
          if git -C "$PWD" pull --rebase origin "$branch" 2>/dev/null; then
            if git -C "$PWD" push origin "$branch" 2>/dev/null; then
              claimed=true
              echo "  [claim] ${item_title} (rebase + retry)" | tee -a "$LOG_FILE"
              log_event claim item "$item_title" rebased true
            else
              git -C "$PWD" reset --hard "origin/$branch" 2>/dev/null || true
              echo "  [skipped] claim push failed after rebase for '${item_title}' — reset to origin" | tee -a "$LOG_FILE"
              sleep $(( (RANDOM % 5) + 1 ))  # backoff to reduce cross-machine race
            fi
          else
            git -C "$PWD" rebase --abort 2>/dev/null || true
            git -C "$PWD" reset --hard "origin/$branch" 2>/dev/null || true
            echo "  [skipped] claim push failed for '${item_title}' — rebase conflict, reset to origin" | tee -a "$LOG_FILE"
          fi
        fi
      fi
    fi
  fi

  # If claim push failed (claimed=false but item was found), skip claude
  # — the item was unclaimed and stays [ ] for the next tick.
  if [[ -n "$item_title" && "$claimed" != "true" ]]; then
    log_event claim_lost item "$item_title"
    _post_tick_cleanup
    [[ -n "$INFLIGHT_FILE" ]] && rm -f "$INFLIGHT_FILE"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] tick skipped (claim push failed)" | tee -a "$LOG_FILE"
    log_event tick_done outcome claim_lost duration_s "$(( $(date +%s) - tick_start_epoch ))"
    return 0
  fi

  local prompt
  prompt="The daemon has already claimed \`${item_title}\` (marked it [~]). Work it now. Re-read $BACKLOG_FILE fresh from disk for context, then complete exactly that item: implement the fix or feature described in the item body; typecheck + tests green before declaring done; update $BACKLOG_FILE (move the item to Done with [x] + a one-paragraph summary); commit with scoped \`git add <files>\` by filename; then exit. If the item turns out to need a user decision mid-work, flip it to [?] with a brief note on what's blocked, commit just the markup change, and exit."

  # `set -e + pipefail` would otherwise abort the daemon on any non-zero
  # claude exit, before we ever reach the PIPESTATUS capture. Wrapping in
  # `|| handler` keeps the failure local: PIPESTATUS still reflects the
  # claude pipeline when the handler runs.
  # --fallback-model absorbs transient Anthropic overload of the default
  # model (Layer 1 of docs/multi-agent-design.md). It does not help with
  # plan-limit exhaustion — haiku counts against the same plan — that's
  # Layer 2's cooldown.
  # Capture claude's output to a temp file so we can pattern-match the plan-limit
  # signature after a failure, then flush it to the log.
  local capture_file
  capture_file="$(mktemp 2>/dev/null || echo "${STATE_DIR}/.claude-out.$$")"
  # Snapshot HEAD immediately before claude runs so Guards 2/3 can scope their
  # diff to exactly the commit(s) claude pushed this tick (excluding the
  # daemon's own reclaim/claim commits, which only touch the backlog file).
  local work_base; work_base="$(git -C "$PWD" rev-parse HEAD 2>/dev/null || echo '')"
  claude_exit=0
  # Wall-clock cap (CLAUDE_TIMEOUT_SECS) via a pure-bash watchdog — no coreutils
  # `timeout` dependency. claude runs in the background writing to the capture
  # file; a watchdog SIGTERMs it if it overruns. `wait` then yields claude's REAL
  # exit (or 143 if the watchdog killed it — handled as a normal failure below,
  # so the item is unclaimed/reopened rather than wedged). Running it detached
  # (not in a `| tee` pipeline) gives the true exit without ${PIPESTATUS} games
  # and makes the plan-limit grep race-free since claude has fully exited. Output
  # reaches the log after the call returns rather than live — fine for a headless
  # tick. A hung claude would otherwise hold the tick lock with no heartbeat.
  # Layer 3: pick the agent command. Normally `claude -p`; under an active
  # cooldown with an available fallback (use_fallback set above), run the
  # configured fallback agent on the SAME prompt instead. If the fallback
  # command can't be built (defensive — availability was already checked),
  # fall back to claude so the tick isn't lost.
  # Resolve the per-item ceilings ONCE here (CEIL_TURNS / CEIL_TOKENS / CEIL_BUDGET_USD,
  # globals). Used now to build the preventive --max-budget-usd flag, and reused
  # post-tick for the turns/tokens guard. docs/per-item-ceiling.md.
  resolve_ceiling "$item_title"
  local -a agent_cmd
  if [[ -n "$use_fallback" ]] && build_fallback_cmd "$prompt"; then
    agent_cmd=( "${FALLBACK_CMD[@]}" )
  else
    use_fallback=""; agent_name="claude"
    agent_cmd=( claude -p --fallback-model claude-haiku-4-5 )
    # Preventive per-item SPEND cap: claude self-stops when predicted spend would
    # exceed the budget (saves the runaway tick's tail). Only the native dollar cap
    # exists in this CLI (no --max-turns); turns/tokens are caught post-hoc below.
    [[ "$CEIL_BUDGET_USD" != "0" ]] && agent_cmd+=( --max-budget-usd "$CEIL_BUDGET_USD" )
    agent_cmd+=( "$prompt" )
  fi
  local claude_pid wd_pid
  "${agent_cmd[@]}" < /dev/null > "$capture_file" 2>&1 &
  claude_pid=$!
  # Watchdog fds -> /dev/null: otherwise its `sleep` child inherits the tick's
  # stdout/stderr and, if orphaned, keeps them open and stalls anything reading
  # our output until the sleep expires.
  ( sleep "$CLAUDE_TIMEOUT_SECS"; kill -TERM "$claude_pid" 2>/dev/null ) >/dev/null 2>&1 &
  wd_pid=$!
  if wait "$claude_pid"; then claude_exit=0; else claude_exit=$?; fi
  # Tear down the watchdog AND its sleep child (killing only the subshell would
  # orphan the sleep) — pkill -P first, while the parent still owns the sleep.
  pkill -P "$wd_pid" 2>/dev/null || true
  kill -TERM "$wd_pid" 2>/dev/null || true
  wait "$wd_pid" 2>/dev/null || true
  cat "$capture_file" >> "$LOG_FILE" 2>/dev/null || true
  log_event claude_exit item "$item_title" exit_code "$claude_exit" agent "$agent_name"
  if [[ $claude_exit -ne 0 ]]; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] tick failed (${agent_name} exit=$claude_exit)" | tee -a "$LOG_FILE"
    # Layer 2: if the failure was a plan/session-limit rejection, arm a
    # cooldown so subsequent ticks idle gracefully instead of re-failing
    # every heartbeat until the rolling window resets. Skip when running the
    # Layer 3 fallback agent: a cooldown is already active (that's why we're on
    # the fallback), the fallback uses a different provider so the Claude
    # plan-limit regex is irrelevant, and re-arming would just extend the idle.
    if [[ -z "$use_fallback" ]] && grep -qiE "$PLAN_LIMIT_REGEX" "$capture_file" 2>/dev/null; then
      local parsed_epoch; parsed_epoch="$(_parse_reset_to_epoch "$capture_file")"
      if [[ -n "$parsed_epoch" ]]; then
        start_cooldown "$parsed_epoch"
      else
        start_cooldown
      fi
    fi
    if [[ "$claimed" == "true" ]]; then
      local auto_result=0
      _maybe_auto_complete "$item_title" || auto_result=$?
      if [[ $auto_result -eq 0 ]]; then
        : # auto-complete already handled
      elif [[ $auto_result -eq 2 ]]; then
        echo "  [keep] ${item_title} (real changes detected, keeping claimed)" | tee -a "$LOG_FILE"
      else
        _local_awk_inplace "$BACKLOG_FILE" '
          BEGIN { in_open=0; done=0 }
          /^## Open/       { in_open=1; print; next }
          /^## [A-Z]/      { if (done) exit; in_open=0; print; next }
          in_open && !done && /^(- )?\[~\] / {
            sub(/\[~\]/, "[ ]"); sub(/ +<!-- @[^>]*-->[ ]*$/, ""); done=1
          }
          { print }
        ' 2>/dev/null || true
        git -C "$PWD" add "$BACKLOG_FILE" 2>/dev/null
        git -C "$PWD" commit -m "unclaim: ${item_title}" >/dev/null 2>&1
        git -C "$PWD" push origin "$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null)" 2>/dev/null || true
        echo "  [unclaim] ${item_title}" | tee -a "$LOG_FILE"
        # Guard 1 (W2): record this consecutive failure. Once the count reaches
        # CIRCUIT_BREAKER_THRESHOLD the next tick auto-blocks the item ([?]) up
        # front instead of re-claiming and re-failing.
        local new_fails; new_fails="$(failcount_bump "$item_title")"
        log_event item_failed item "$item_title" fails "$new_fails"
      fi
    fi
  else
    if [[ "$claimed" == "true" ]]; then
      _maybe_auto_complete "$item_title" >/dev/null 2>&1 || true
    fi

    # Snapshot the commit(s) claude (+ auto-complete) landed this tick:
    # work_base..work_head. Captured ONCE here, BEFORE any verification reopen
    # commit advances HEAD, so it is reused cleanly by Guard 4 (verification),
    # Guards 2/3 (diff-size/protected-path), and the fleet-freeze auto-arm —
    # none of which should see the reopen markup commit.
    local work_head=""
    [[ -n "$work_base" ]] && work_head="$(git -C "$PWD" rev-parse HEAD 2>/dev/null || echo '')"
    local work_committed=false
    [[ -n "$work_base" && -n "$work_head" && "$work_head" != "$work_base" ]] && work_committed=true

    # --- Guard 6 (W2): per-item token/turn ceiling (docs/per-item-ceiling.md) ---
    # [pause-primitive consumer, scope=ITEM] The preventive --max-budget-usd cap
    # (built above) saves the spend tail; this is the POST-HOC backstop catching
    # the runaway TASK that turns/tokens-spiraled within this one tick (below the
    # per-project budget's rolling radar). Read THIS session's actual usage from
    # claude's newest transcript and, if over an effective ceiling, act:
    #   * INCOMPLETE item ([~] still): reopen [~]→[ ] + inline note + failcount_bump
    #     (composes with the Guard-1 breaker → [?] after K). This is the runaway the
    #     ceiling exists to stop continuing next tick. Keep any commit (Guards 2/3/4).
    #   * COMPLETED item ([x] this tick): LOG only — the grind already ended in
    #     success; reopening finished work would only re-spend it. Surface the cost.
    # Runs regardless of work_committed (a no-commit spin is the worst runaway).
    # FAIL-OPEN: unreadable usage ⇒ no action. Mutually exclusive with Guard 4's
    # reopen by construction (Guard 4 only fires on [x]; the ceiling only reopens [~]).
    local ceiling_breached=false
    if [[ "$claimed" == "true" && "$CEILING_DISABLE" != "1" ]] \
         && (( CEIL_TURNS > 0 || CEIL_TOKENS > 0 )); then
      _read_tick_usage
      if [[ -n "$USAGE_TURNS" && -n "$USAGE_TOKENS" ]]; then
        local over=""
        # --max-budget-usd self-stops AT the cap, so a turn ceiling hit is `>=`
        # (reaching it is the breach); tokens is `>` (strictly over the cap).
        (( CEIL_TOKENS > 0 && USAGE_TOKENS > CEIL_TOKENS )) && over+="tokens ${USAGE_TOKENS}/${CEIL_TOKENS} "
        (( CEIL_TURNS  > 0 && USAGE_TURNS >= CEIL_TURNS  )) && over+="turns ${USAGE_TURNS}/${CEIL_TURNS} "
        if [[ -n "$over" ]]; then
          over="${over% }"
          if _completion_claimed "$item_title"; then
            echo "  [ceiling] '${item_title}' completed but ran hot (${over}) — flagging (not reopening finished work)" | tee -a "$LOG_FILE"
            log_event item_ceiling item "$item_title" breach "$over" reopened false completed true
          else
            ceiling_breached=true
            echo "  [ceiling] '${item_title}' exceeded its per-item ceiling (${over}) — reopening + bumping failcount (commit kept, flagged)" | tee -a "$LOG_FILE"
            # Reopen [~]→[ ] for THIS item (literal title substring match), strip
            # the owner stamp (else it leaks into the stripped title on the next
            # pick + claim, drifting the failcount key — same fix as Guards 4 / the
            # exit≠0 unclaim), and append an inline ceiling note. Scoped git add.
            _local_awk_inplace "$BACKLOG_FILE" '
              BEGIN { in_open=0; done=0 }
              /^## Open/       { in_open=1; print; next }
              /^## [A-Z]/      { if (done) exit; in_open=0; print; next }
              in_open && !done && /^(- )?\[~\] / && index($0, title) {
                sub(/\[~\]/, "[ ]"); sub(/ +<!-- @[^>]*-->[ ]*$/, "")
                $0 = $0 " <!-- ceiling: " note " -->"; done=1
              }
              { print }
            ' -v title="$item_title" -v note="$over" 2>/dev/null || true
            if ! git -C "$PWD" diff --quiet "$BACKLOG_FILE" 2>/dev/null; then
              git -C "$PWD" add "$BACKLOG_FILE" 2>/dev/null
              git -C "$PWD" commit -m "ceiling: reopen ${item_title}" >/dev/null 2>&1
              git -C "$PWD" push origin "$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null)" 2>/dev/null || true
              echo "  [ceiling] reopened ${item_title}" | tee -a "$LOG_FILE"
            else
              echo "  [ceiling] WARNING: '${item_title}' over ceiling but no [~] match in ## Open to reopen — needs manual attention" | tee -a "$LOG_FILE"
            fi
            local cfails; cfails="$(failcount_bump "$item_title")"
            log_event item_ceiling item "$item_title" breach "$over" reopened true fails "$cfails"
          fi
        fi
      fi
    fi

    # --- Guard 4 (W2): per-tick outcome verification (the first VETOING guard) ---
    # exit 0 + claude's self-report is NOT proof the gate is green. When this tick
    # both LANDED A COMMIT and CLAIMED COMPLETION (the item is now [x]) and the
    # project defines a gate, independently run it on the committed HEAD. On
    # failure (or timeout) REOPEN the item ([x]→[ ]) + failcount_bump so K
    # consecutive verification failures trip the Guard-1 circuit breaker → [?].
    # No auto-revert (commit stands, flagged — mirrors Guards 2/3). No gate
    # defined ⇒ FAIL-OPEN (skip = the prior behaviour). docs/per-tick-verification.md.
    local verify_failed=false
    if [[ "$claimed" == "true" && "$work_committed" == "true" ]] \
         && _completion_claimed "$item_title" && resolve_gate; then
      local gate_out; gate_out="$(mktemp 2>/dev/null || echo "${STATE_DIR}/.gate-out.$$")"
      echo "  [verify] running gate: ${GATE_CMD[*]} (timeout ${GATE_TIMEOUT_SECS}s)" | tee -a "$LOG_FILE"
      local gate_rc=0
      run_gate "$gate_out" || gate_rc=$?
      cat "$gate_out" >> "$LOG_FILE" 2>/dev/null || true
      if [[ $gate_rc -ne 0 ]]; then
        verify_failed=true
        echo "  [verify] FAILED (exit=${gate_rc}) for '${item_title}' — reopening + bumping failcount (commit kept, flagged)" | tee -a "$LOG_FILE"
        # Reopen [x] → [ ] in ## Open, targeting THIS item by title. index() is a
        # literal substring match (titles carry regex-special chars), so a [x]
        # line with claude's appended summary still matches. Strip the owner stamp
        # too (mirrors the exit≠0 unclaim path) — otherwise it leaks into the
        # stripped title on the NEXT pick + claim, drifting the failcount key so
        # the circuit breaker never accumulates. Scoped `git add` of the backlog.
        _local_awk_inplace "$BACKLOG_FILE" '
          BEGIN { in_open=0; done=0 }
          /^## Open/       { in_open=1; print; next }
          /^## [A-Z]/      { if (done) exit; in_open=0; print; next }
          in_open && !done && /^(- )?\[x\] / && index($0, title) {
            sub(/\[x\]/, "[ ]"); sub(/ +<!-- @[^>]*-->[ ]*$/, ""); done=1
          }
          { print }
        ' -v title="$item_title" 2>/dev/null || true
        if ! git -C "$PWD" diff --quiet "$BACKLOG_FILE" 2>/dev/null; then
          git -C "$PWD" add "$BACKLOG_FILE" 2>/dev/null
          git -C "$PWD" commit -m "verify-failed: reopen ${item_title}" >/dev/null 2>&1
          git -C "$PWD" push origin "$(git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null)" 2>/dev/null || true
          echo "  [verify] reopened ${item_title}" | tee -a "$LOG_FILE"
        else
          echo "  [verify] WARNING: '${item_title}' failed its gate but could not be auto-reopened (no [x] match in ## Open) — needs manual attention" | tee -a "$LOG_FILE"
        fi
        local vfails; vfails="$(failcount_bump "$item_title")"
        log_event verify_failed item "$item_title" exit_code "$gate_rc" gate "${GATE_CMD[*]}" fails "$vfails"
      else
        echo "  [verify] gate passed for '${item_title}'" | tee -a "$LOG_FILE"
        log_event verify_passed item "$item_title" gate "${GATE_CMD[*]}"
      fi
      rm -f "$gate_out" 2>/dev/null || true
    fi

    # Guard 1 (W2): a clean tick clears the item's consecutive-failure streak —
    # but only when neither verification NOR the ceiling failed (either already
    # bumped above; resetting here would erase that and defeat the breaker).
    if [[ "$verify_failed" != "true" && "$ceiling_breached" != "true" ]]; then
      failcount_reset "$item_title"
    fi

    # --- Guards 2 & 3 (W2): inspect what claude actually committed this tick ---
    # Both scope their diff to work_base..work_head — the commit(s) claude pushed,
    # excluding the daemon's own reclaim/claim/verify-reopen markup commits.
    # Neither auto-reverts: the commit stands and we flag it for the user to review.
    if [[ "$work_committed" == "true" ]]; then
        local changed_files changed_lines
        changed_files="$(git -C "$PWD" diff --name-only "$work_base" "$work_head" 2>/dev/null | grep -c . || true)"
        changed_files="${changed_files:-0}"
        # Sum insertions+deletions across the range (numstat: <add>\t<del>\t<path>).
        changed_lines="$(git -C "$PWD" diff --numstat "$work_base" "$work_head" 2>/dev/null \
          | awk '{ a=($1=="-"?0:$1); d=($2=="-"?0:$2); sum+=a+d } END { print sum+0 }' || true)"
        changed_lines="${changed_lines:-0}"

        # Guard 2: diff-size guardrail.
        if (( changed_files > DIFF_SIZE_MAX_FILES || changed_lines > DIFF_SIZE_MAX_LINES )); then
          echo "  [WARNING] diff-size guardrail: '${item_title}' touched ${changed_files} file(s) / ${changed_lines} line(s) (limits: ${DIFF_SIZE_MAX_FILES} files, ${DIFF_SIZE_MAX_LINES} lines) — review this tick" | tee -a "$LOG_FILE"
          log_event diff_oversize item "$item_title" files "$changed_files" lines "$changed_lines" max_files "$DIFF_SIZE_MAX_FILES" max_lines "$DIFF_SIZE_MAX_LINES"
        fi

        # Guard 3: protected-path guardrail. Flag if any committed file matches
        # a protected path. Exact path match against the repo-relative names.
        local protected_hit="" f p
        while IFS= read -r f; do
          [[ -z "$f" ]] && continue
          for p in $PROTECTED_PATHS; do
            if [[ "$f" == "$p" ]]; then
              protected_hit+="${f} "
              break
            fi
          done
        done < <(git -C "$PWD" diff --name-only "$work_base" "$work_head" 2>/dev/null || true)
        if [[ -n "$protected_hit" ]]; then
          # Trim trailing space.
          protected_hit="${protected_hit% }"
          echo "  [WARNING] protected-path guardrail: '${item_title}' modified protected file(s): ${protected_hit} — review this tick" | tee -a "$LOG_FILE"
          log_event protected_path_touched item "$item_title" paths "$protected_hit"
        fi

        # --- Guard 5 (W2): secret-scan post-push flag (docs/secret-scan.md) ---
        # The pre-push HOOK is the real prevention (rejects claude's push before a
        # key leaves the machine). This is belt-and-suspenders: if THIS clone was
        # missing the hook (fresh machine pre-first-tick, hand-edited .git/hooks,
        # `push --no-verify`), the commit is already pushed — we can't un-publish
        # it, but we DETECT it and alert LOUDLY so the user can rotate the key.
        # Flag-only, like Guards 2/3 (no reopen — the leak is in git history, and
        # the actionable response is key rotation, not a code retry). Scoped to
        # work_base..work_head; runs the builtin floor directly (no hook needed).
        if [[ "$SECRET_SCAN_DISABLE" != "1" && -x "$SECRET_SCAN_BIN" ]]; then
          local secret_out secret_rc=0
          secret_out="$(SECRET_SCAN_DISABLE=0 "$SECRET_SCAN_BIN" --range "$work_base" "$work_head" 2>&1)" || secret_rc=$?
          if [[ $secret_rc -ne 0 ]]; then
            echo "  [WARNING] secret-scan: '${item_title}' pushed a commit with secret-like content (the pre-push hook was bypassed/absent) — ROTATE the key; it is in git history" | tee -a "$LOG_FILE"
            log_event secret_detected item "$item_title" range "${work_base}..${work_head}"
            local sshost; sshost="$(_health_host 2>/dev/null || hostname -s 2>/dev/null || echo '?')"
            notify_send "backlog-agent SECRET LEAK: $(basename "$PWD")@${sshost}" \
              "🔓 backlog-agent [$(basename "$PWD")@${sshost}] pushed a commit with secret-like content for item '${item_title}' (pre-push hook bypassed/absent). The secret is in git history — ROTATE it now. Range ${work_base}..${work_head}."
          fi
        fi

        # --- Fleet-freeze auto-arm (docs/fleet-freeze.md §2) ---
        # Only the EXEMPT (backlog-infra) daemon arms: when its own work commit
        # touches the SHARED driver dir (FLEET_AFFECTING_PREFIX = bin/), a
        # fleet-affecting change is in flight — hold the rest of the fleet to
        # heartbeat-only until it propagates (skew zero) + validates (canary).
        # Distinct from PROTECTED_PATHS above (per-project review signal; that
        # set also covers CLAUDE.md/.gitignore, which are NOT fleet-affecting).
        # The clear is fast + automatic, so arming on every bin/ commit is cheap.
        # Guard 4 ordering: VERIFY FIRST — never arm the freeze (hold the whole
        # fleet) on a bin/ commit that just FAILED its own gate; the item is being
        # reopened, so there's no verified infra change to propagate.
        if [[ "$verify_failed" != "true" && "$ceiling_breached" != "true" ]] && freeze_exempt && command -v backlog-agents >/dev/null 2>&1; then
          local fleet_hit=""
          while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            if [[ "$f" == "$FLEET_AFFECTING_PREFIX"* ]]; then fleet_hit+="${f} "; fi
          done < <(git -C "$PWD" diff --name-only "$work_base" "$work_head" 2>/dev/null || true)
          if [[ -n "$fleet_hit" ]]; then
            fleet_hit="${fleet_hit% }"
            echo "  [fleet-freeze] arming: fleet-affecting change committed (${fleet_hit}) — holding the fleet until propagated + canary-green" | tee -a "$LOG_FILE"
            log_event fleet_freeze_armed item "$item_title" sha "$work_head" paths "$fleet_hit"
            backlog-agents freeze --arm --sha "$work_head" --by "$(_health_host)" \
              --reason "in-flight infra change: ${item_title}" >>"$LOG_FILE" 2>&1 || true
          fi
        fi
    fi
  fi
  rm -f "$capture_file" 2>/dev/null || true

  _run_status_hook "$item_title" "$claude_exit" loop "$pre_head" "$pulled" "$agent_name"

  _post_tick_cleanup
  [[ -n "$INFLIGHT_FILE" ]] && rm -f "$INFLIGHT_FILE"
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] tick done" | tee -a "$LOG_FILE"
  log_event tick_done outcome work item "$item_title" exit_code "$claude_exit" agent "$agent_name" duration_s "$(( $(date +%s) - tick_start_epoch ))"
  TICK_OUTCOME=work
}

# --- subcommands ---
do_status() {
  require_backlog
  local DIM=$'\e[2m' RS=$'\e[0m' GN=$'\e[32m' YL=$'\e[33m' RD=$'\e[31m' B=$'\e[1m' CY=$'\e[36m'

  local open_count
  # grep -c prints "0" AND exits non-zero on no matches; `|| true` lets us
  # keep its stdout without duplicating it.
  open_count="$(grep -c -E "$ITEM_REGEX" "$BACKLOG_FILE" 2>/dev/null || true)"
  open_count="${open_count:-0}"
  local thinking_count
  thinking_count="$(sed -n '/^## Thinking/,/^## Open/p' "$BACKLOG_FILE" 2>/dev/null | grep -c -E '^- \[ \] ' || true)"
  thinking_count="${thinking_count:-0}"
  local progress_count
  progress_count="$(grep -c -E '^(- )?\[\~\] ' "$BACKLOG_FILE" 2>/dev/null || true)"
  progress_count="${progress_count:-0}"
  local cc="$GN"
  (( open_count > 0 )) && cc="$YL"
  (( open_count > 5 )) && cc="$RD"
  local extra=""
  (( thinking_count > 0 )) && extra=" (${thinking_count} thinking)"
  (( progress_count > 0 )) && extra="${extra} (${progress_count} in progress)"
  printf '%s%s%s  %s%d open%s%s\n' "${B}${CY}" "$BACKLOG_FILE" "${RS}" "${cc}" "$open_count" "${RS}" "$extra"

  if (( open_count > 0 )); then
    local next
    next="$(grep -m1 -E "$ITEM_REGEX" "$BACKLOG_FILE" 2>/dev/null | strip_marker || true)"
    [[ -n "$next" ]] && printf '  %s→ next:%s %s\n' "$DIM" "$RS" "$next"
  fi

  # In-flight tick? Sentinel is written by tick_once before invoking claude
  # and removed on tick completion. We re-verify with `kill -0` so a
  # sentinel orphaned by a SIGKILL'd daemon doesn't look like a live tick.
  if [[ -n "$INFLIGHT_FILE" ]] && [[ -f "$INFLIGHT_FILE" ]]; then
    local in_pid in_epoch in_title in_now in_age in_age_str
    IFS=$'\t' read -r in_pid in_epoch in_title < "$INFLIGHT_FILE" || true
    if [[ -n "${in_pid:-}" ]] && kill -0 "$in_pid" 2>/dev/null; then
      in_now="$(date '+%s')"
      in_age=$(( in_now - in_epoch ))
      if   (( in_age < 60 ));   then in_age_str="${in_age}s"
      elif (( in_age < 3600 )); then in_age_str="$((in_age/60))m"
      else                           in_age_str="$((in_age/3600))h"
      fi
      printf '  %s⚙ in flight%s  started %s ago' "$CY" "$RS" "$in_age_str"
      [[ -n "$in_title" ]] && printf '  %s· %s%s' "$DIM" "$in_title" "$RS"
      printf '\n'
    fi
  fi

  # Plan-limit cooldown? Surface it so the daemon reads as "idling on
  # purpose" rather than STALE/failed (Layer 2, docs/multi-agent-design.md).
  if cooldown_active; then
    local cd_until; cd_until="$(cooldown_until_str)"
    printf '  %s⏸ plan-limit cooldown%s  until %s%s%s\n' "$YL" "$RS" "$YL" "${cd_until:-?}" "$RS"
  fi

  local status_file=""
  if [[ -f .claude/backlog-status.json ]]; then
    status_file=".claude/backlog-status.json"
  elif [[ -f .claude/loop-status.json ]]; then
    status_file=".claude/loop-status.json"
  fi
  if [[ -n "$status_file" ]] && command -v jq >/dev/null 2>&1; then
    local last_tick last_item last_exit
    # `// empty`/`// 0` only apply once the JSON parses; a truncated/corrupt
    # status file (mid-write crash, conflicted cross-machine merge) makes jq exit
    # non-zero BEFORE the filter, which under set -e would abort `status` — the
    # default subcommand. Guard each read so a bad file degrades to empty/default.
    last_tick="$(jq -r '.last_tick_at // empty' "$status_file" 2>/dev/null || true)"
    last_item="$(jq -r '.last_item // ""' "$status_file" 2>/dev/null || true)"
    last_exit="$(jq -r '.last_exit_code // 0' "$status_file" 2>/dev/null || echo 0)"
    if [[ -n "$last_tick" ]]; then
      local clean tick_epoch now age age_str state label
      clean="${last_tick%.*Z}"
      [[ "$clean" == "$last_tick" ]] && clean="${last_tick%Z}"
      tick_epoch="$(date -j -u -f '%Y-%m-%dT%H:%M:%S' "$clean" '+%s' 2>/dev/null || echo '')"
      if [[ -n "$tick_epoch" ]]; then
        now="$(date '+%s')"
        age=$(( now - tick_epoch ))
        if   (( age < 60 ));    then age_str="${age}s ago"
        elif (( age < 3600 ));  then age_str="$((age/60))m ago"
        elif (( age < 86400 )); then age_str="$((age/3600))h ago"
        else                         age_str="$((age/86400))d ago"
        fi
        state="$DIM"; label="idle"
        if   (( age < 1800 ));  then state="$GN"; label="fresh"
        elif (( age >= 7200 )); then state="$RD"; label="STALE"
        fi
        [[ "$last_exit" != "0" ]] && state="$RD"
        printf '  %s%s%s  last tick %s' "$state" "$label" "$RS" "$age_str"
        [[ -n "$last_item" ]] && printf '  %s· %s%s' "$DIM" "$last_item" "$RS"
        printf '\n'
      fi
    fi
  fi
}

# Read ESCALATING_IDLE_SLEEP at the given 1-based streak index. Falls back
# to the last element if beyond the list, or HEARTBEAT_SECONDS if unset.
_pick_idle_sleep() {
  local streak="$1" idx=0 val
  for val in $ESCALATING_IDLE_SLEEP; do
    idx=$((idx + 1))
    if (( idx == streak )); then echo "$val"; return 0; fi
  done
  echo "${val:-$HEARTBEAT_SECONDS}"
}

do_run() {
  ensure_backlog
  check_interactive_worker
  ${INSTALL_DAEMON:-true} && maybe_install_daemon
  acquire_lock
  trap 'release_lock' EXIT
  trap 'exit 130' INT TERM
  STARTUP_RECLAIM=1
  if command -v fswatch >/dev/null 2>&1; then
    (
      fswatch -0 "$BACKLOG_FILE" | while IFS= read -r -d '' _; do
        sleep "$DEBOUNCE_SECONDS"
        tick_once
      done
    ) &
    WATCH_PID=$!
    echo "watching $BACKLOG_FILE (fswatch pid $WATCH_PID); fast-start ${FAST_SECONDS}s, idle escalates ${ESCALATING_IDLE_SLEEP// /→}s. ctrl-c to stop."
  else
    echo "fswatch not installed (brew install fswatch). heartbeat every ${FAST_SECONDS}s, idle escalates ${ESCALATING_IDLE_SLEEP// /→}s." >&2
  fi
  local tick_count=0 idle_streak=0 sleep_sec
  TICK_OUTCOME=""
  tick_once
  while true; do
    sleep_sec=""
    case "$TICK_OUTCOME" in
      work)
        idle_streak=0
        if (( tick_count < FAST_TICKS )); then
          sleep_sec="$FAST_SECONDS"
        else
          sleep_sec="$HEARTBEAT_SECONDS"
        fi ;;
      idle)
        idle_streak=$((idle_streak + 1))
        sleep_sec="$(_pick_idle_sleep "$idle_streak")" ;;
      cooldown)
        idle_streak=0
        if [[ -n "${COOLDOWN_WAIT_SECONDS:-}" ]] && (( COOLDOWN_WAIT_SECONDS > 0 )); then
          sleep_sec="$COOLDOWN_WAIT_SECONDS"
        else
          sleep_sec="$HEARTBEAT_SECONDS"
        fi ;;
      freeze|pause)
        # Fleet-freeze / fleet-pause hold: heartbeat-only at the normal heartbeat
        # cadence so the fleet view sees the daemon alive (just held), and the
        # daemon re-checks the control promptly once it resumes/thaws.
        idle_streak=0
        sleep_sec="$HEARTBEAT_SECONDS" ;;
      stop)
        # Fleet STOP: full halt. Break the loop so the process exits (launchd
        # respawns after ThrottleInterval and re-reads stop, so the daemon stays
        # effectively down until `backlog-agents start` clears the flag).
        echo "fleet STOP — exiting the daemon loop (\`backlog-agents start\` to resume; \`launchctl bootout\` for a hard halt)."
        break ;;
      *) sleep_sec="$FAST_SECONDS" ;;
    esac
    [[ -n "$sleep_sec" ]] && sleep_interruptible "$sleep_sec"
    TICK_OUTCOME=""
    tick_once
    tick_count=$((tick_count + 1))
  done
}

do_tick() {
  ensure_backlog
  check_interactive_worker
  acquire_lock
  trap 'release_lock' EXIT
  trap 'exit 130' INT TERM
  tick_once
}

do_watch() {
  ensure_backlog
  check_interactive_worker
  ${INSTALL_DAEMON:-true} && maybe_install_daemon
  acquire_lock
  trap 'release_lock' EXIT
  trap 'exit 130' INT TERM
  echo "heartbeat-only loop; fast-start ${FAST_SECONDS}s, idle escalates ${ESCALATING_IDLE_SLEEP// /→}s. ctrl-c to stop."
  local tick_count=0 idle_streak=0 sleep_sec
  TICK_OUTCOME=""
  tick_once
  while true; do
    sleep_sec=""
    case "$TICK_OUTCOME" in
      work)
        idle_streak=0
        if (( tick_count < FAST_TICKS )); then
          sleep_sec="$FAST_SECONDS"
        else
          sleep_sec="$HEARTBEAT_SECONDS"
        fi ;;
      idle)
        idle_streak=$((idle_streak + 1))
        sleep_sec="$(_pick_idle_sleep "$idle_streak")" ;;
      cooldown)
        idle_streak=0
        if [[ -n "${COOLDOWN_WAIT_SECONDS:-}" ]] && (( COOLDOWN_WAIT_SECONDS > 0 )); then
          sleep_sec="$COOLDOWN_WAIT_SECONDS"
        else
          sleep_sec="$HEARTBEAT_SECONDS"
        fi ;;
      freeze|pause)
        # Fleet-freeze / fleet-pause hold: heartbeat-only at the normal heartbeat
        # cadence so the fleet view sees the daemon alive (just held), and the
        # daemon re-checks the control promptly once it resumes/thaws.
        idle_streak=0
        sleep_sec="$HEARTBEAT_SECONDS" ;;
      stop)
        # Fleet STOP: full halt. Break the loop so the process exits (launchd
        # respawns after ThrottleInterval and re-reads stop, so the daemon stays
        # effectively down until `backlog-agents start` clears the flag).
        echo "fleet STOP — exiting the daemon loop (\`backlog-agents start\` to resume; \`launchctl bootout\` for a hard halt)."
        break ;;
      *) sleep_sec="$FAST_SECONDS" ;;
    esac
    [[ -n "$sleep_sec" ]] && sleep_interruptible "$sleep_sec"
    TICK_OUTCOME=""
    tick_once
    tick_count=$((tick_count + 1))
  done
}

do_log() {
  require_backlog
  if [[ ! -f "$LOG_FILE" ]]; then
    echo "no log file at $LOG_FILE yet — has the daemon ticked?" >&2
    exit 1
  fi
  # tail -F (capital F) keeps following across log rotation; -n 50 gives
  # enough context to orient on without flooding a fresh terminal.
  exec tail -n 50 -F "$LOG_FILE"
}

do_unblock() {
  ensure_backlog
  local arg="${1:-}"

  # Collect [?] items as parallel arrays of line-number + stripped-title.
  local -a lines titles
  while IFS=$'\t' read -r ln rest; do
    lines+=("$ln")
    titles+=("$rest")
  done < <(awk '/^(- )?\[\?\] / { line=$0; sub(/^(- )?\[\?\] /, "", line); print NR "\t" line }' "$BACKLOG_FILE")

  local n=${#lines[@]}
  if (( n == 0 )); then
    echo "no [?] items in $BACKLOG_FILE"
    return 0
  fi

  case "$arg" in
    "")
      printf '%-3s %s\n' "#" "BLOCKED ITEM"
      local i
      for ((i=0; i<n; i++)); do
        printf '%-3d %s\n' "$((i+1))" "${titles[$i]:0:100}"
      done
      echo
      echo "Flip to [!] (answered, ready to retry):  backlog-agent unblock <N> | --all"
      ;;
    --all)
      sed -i '' -E 's|^(- )?\[\?\] |\1[!] |g' "$BACKLOG_FILE"
      echo "flipped $n item(s) [?] → [!]"
      ;;
    *)
      [[ "$arg" =~ ^[0-9]+$ ]] || { echo "usage: backlog-agent unblock [<N> | --all]" >&2; exit 2; }
      local idx="$arg"
      (( idx >= 1 && idx <= n )) || { echo "no [?] item #$idx (have $n)" >&2; exit 2; }
      local target_line="${lines[$((idx-1))]}"
      sed -i '' -E "${target_line}s|^(- )?\[\?\] |\1[!] |" "$BACKLOG_FILE"
      echo "flipped #$idx: ${titles[$((idx-1))]:0:100}"
      ;;
  esac
}

do_unclaim() {
  # Flip all [~] items back to [ ] (recovery after a daemon crash mid-tick).
  ensure_backlog
  local n
  n="$(grep -c -E '^(- )?\[\~\] ' "$BACKLOG_FILE" 2>/dev/null || true)"
  n="${n:-0}"
  if (( n == 0 )); then
    echo "no [~] (in-progress) items found"
    return 0
  fi
  # Flip [~]->[ ] and drop the owner stamp (stamped first, then legacy).
  if [[ "$(uname)" == "Darwin" ]]; then
    sed -i '' -E -e 's|^((- )?)\[\~\] (.*) +<!-- @[^>]*-->[[:space:]]*$|\1[ ] \3|g' -e 's|^(- )?\[\~\] |\1[ ] |g' "$BACKLOG_FILE"
  else
    sed -i -E -e 's|^((- )?)\[\~\] (.*) +<!-- @[^>]*-->[[:space:]]*$|\1[ ] \3|g' -e 's|^(- )?\[\~\] |\1[ ] |g' "$BACKLOG_FILE"
  fi
  echo "unclaimed $n item(s) [~] → [ ]"
}

do_compact() {
  if [[ -f scripts/backlog-agent-compact.mjs ]]; then
    exec node scripts/backlog-agent-compact.mjs "$@"
  elif [[ -f scripts/compact-backlog.mjs ]]; then
    exec node scripts/compact-backlog.mjs "$@"
  elif [[ -f "$HOME/dev/projects/active/backlog-infra/bin/backlog-agent-compact.mjs" ]]; then
    exec node "$HOME/dev/projects/active/backlog-infra/bin/backlog-agent-compact.mjs" "$@"
  else
    echo "error: no scripts/backlog-agent-compact.mjs in $(pwd) or $HOME/dev/projects/active/backlog-infra/bin/" >&2
    exit 1
  fi
}

# --- launchd daemon install ---
# XML-escape a string for safe interpolation into the plist heredoc.
# Order matters: ampersand must be replaced first so we don't double-escape
# Resolve the canonical paths a generated plist needs to reference.
# Echos: project_root, project, label, plist_path, bin_path (newline-separated).
daemon_paths() {
  local project_root project label plist_path bin_path
  project_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  project="$(basename "$project_root")"
  label="com.${USER}.${project}.backlog-agent"
  plist_path="$HOME/Library/LaunchAgents/${label}.plist"
  bin_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "$(readlink "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")"
  printf '%s\n%s\n%s\n%s\n%s\n' "$project_root" "$project" "$label" "$plist_path" "$bin_path"
}

do_install_daemon() {
  ensure_backlog
  local project_root project label plist_path bin_path
  { read -r project_root; read -r project; read -r label; read -r plist_path; read -r bin_path; } < <(daemon_paths)

  mkdir -p "$HOME/Library/LaunchAgents" "$project_root/.claude"

  # If a previous plist exists, boot it out so we can replace cleanly.
  # bootout sends SIGTERM, waits ~5s, then SIGKILLs.
  if [[ -f "$plist_path" ]]; then
    echo "replacing existing plist at $plist_path"
    launchctl bootout "gui/$(id -u)/${label}" 2>/dev/null || true
    local i=0
    while launchctl print "gui/$(id -u)/${label}" >/dev/null 2>&1 && (( i < 10 )); do
      sleep 1; i=$((i + 1))
    done
  fi

  # Retire any OLD-label daemons for this project so we don't end up with two
  # daemons (old + new label) racing for the same backlog. Pre-migration
  # installs used the `.backlog` symlink label or the even older `.backlog-loop`
  # label; both must be booted out AND their plists removed — leaving a plist
  # with RunAtLoad on disk would resurrect the daemon on the next login/reboot,
  # and maybe_install_daemon treats a stray old plist as "already installed".
  local old_suffix old_label old_plist
  for old_suffix in backlog backlog-loop; do
    old_label="com.${USER}.${project}.${old_suffix}"
    old_plist="$HOME/Library/LaunchAgents/${old_label}.plist"
    if launchctl print "gui/$(id -u)/${old_label}" >/dev/null 2>&1; then
      echo "booting out old-label daemon ${old_label}"
      launchctl bootout "gui/$(id -u)/${old_label}" 2>/dev/null || true
      local j=0
      while launchctl print "gui/$(id -u)/${old_label}" >/dev/null 2>&1 && (( j < 10 )); do
        sleep 1; j=$((j + 1))
      done
    fi
    if [[ -f "$old_plist" ]]; then
      rm -f "$old_plist" && echo "removed old-label plist ${old_plist}"
    fi
  done

  # Always clear any stale mkdir-lock before bootstrap. A prior daemon may
  # have been SIGKILL'd (by bootout's 5s timeout escalation, by a manual
  # SIGKILL, or by a crash), skipping the EXIT trap and leaving the
  # lockdir behind. On first install, this catches locks abandoned by an
  # earlier manual `backlog run` in the same project.
  rmdir "${project_root}/.claude/backlog-agent.lock" 2>/dev/null || true
  rmdir "${project_root}/.claude/backlog.lock" 2>/dev/null || true

  # XML-escape each substitution so a path or label containing `&`, `<`,
  # or `>` doesn't produce a malformed plist. Realistic paths under
  # ~/dev/projects/ are alphanumeric+hyphen so this is mostly defensive.
  local label_x bin_path_x project_root_x home_x bin_dir_x
  label_x="$(xml_escape "$label")"
  bin_path_x="$(xml_escape "$bin_path")"
  local bin_dir; bin_dir="$(dirname "$bin_path")"
  bin_dir_x="$(xml_escape "$bin_dir")"
  project_root_x="$(xml_escape "$project_root")"
  home_x="$(xml_escape "$HOME")"

  cat > "$plist_path" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${label_x}</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${bin_path_x}</string>
        <string>run</string>
    </array>

    <key>WorkingDirectory</key>
    <string>${project_root_x}</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${bin_dir_x}:${home_x}/dotfiles/bin:${home_x}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>${home_x}</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>60</integer>

    <key>StandardOutPath</key>
    <string>${project_root_x}/.claude/launchd-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>${project_root_x}/.claude/launchd-stderr.log</string>
</dict>
</plist>
EOF

  if ! launchctl bootstrap "gui/$(id -u)" "$plist_path"; then
    echo "error: launchctl bootstrap failed for ${label}." >&2
    echo "  plist is on disk at $plist_path." >&2
    echo "  to retry manually: launchctl bootstrap gui/\$(id -u) $plist_path" >&2
    echo "  to inspect: launchctl print gui/\$(id -u)/${label}" >&2
    exit 1
  fi
  echo "bootstrapped ${label}"
  echo "  plist: ${plist_path}"
  echo "  cwd:   ${project_root}"
  echo "  logs:  ${project_root}/.claude/{backlog-agent.log,launchd-stdout.log,launchd-stderr.log}"
  echo "  status: launchctl print gui/\$(id -u)/${label}"
}

do_uninstall_daemon() {
  local project_root project label plist_path _bin
  { read -r project_root; read -r project; read -r label; read -r plist_path; read -r _bin; } < <(daemon_paths)

  if launchctl print "gui/$(id -u)/${label}" >/dev/null 2>&1; then
    launchctl bootout "gui/$(id -u)/${label}" || true
    echo "booted out ${label}"
  fi
  if [[ -f "$plist_path" ]]; then
    rm "$plist_path"
    echo "removed ${plist_path}"
  else
    echo "no plist at ${plist_path}; nothing to remove."
  fi
  # Symmetric to install-daemon: clear any stale mkdir-lock so a future
  # reinstall doesn't start in a wedged state.
  rmdir "${project_root}/.claude/backlog-agent.lock" 2>/dev/null || true
}

# --- dispatch ---
cmd="${1:-status}"
shift 2>/dev/null || true

if [[ "${1:-}" == "--no-daemon" ]]; then
  INSTALL_DAEMON=false
  shift
else
  INSTALL_DAEMON=true
fi

case "$cmd" in
  status|"")  do_status ;;
  run)        do_run ;;
  tick)       do_tick ;;
  watch)      do_watch ;;
  log|tail)   do_log ;;
  unblock)    do_unblock "$@" ;;
  unclaim)    do_unclaim ;;
  compact)    do_compact "$@" ;;
  install-daemon)   do_install_daemon ;;
  uninstall-daemon) do_uninstall_daemon ;;
  -h|--help)
    sed -n '2,40p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
    ;;
  *)
    echo "backlog-agent: unknown subcommand: $cmd (try \`backlog-agent --help\`)" >&2
    exit 2
    ;;
esac
