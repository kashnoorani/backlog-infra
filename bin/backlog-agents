#!/usr/bin/env bash
# backlog-agents ŌĆö fleet view across every project's backlog.
#
# Subcommands:
#   backlog-agents              Dashboard: per-project backlog state (last tick,
#                         current item, freshness, per-project tick-token
#                         totals). For host-wide Anthropic plan usage, run
#                         /usage inside Claude Code ŌĆö the transcript-derived
#                         host totals previously shown here drifted from
#                         /usage's numbers and were removed.
#   backlog-agents sync [--no-pull|--restart-only] [--no-gate] [--gate-only]
#                         Pull dotfiles + every active project, then restart every
#                         agent launchd daemon (both legacy
#                         com.${USER}.*.backlog-loop and new
#                         com.${USER}.*.backlog-agent labels). The RESTART is gated
#                         on canary + version-skew (see _sync_gate_check): it won't
#                         restart agents onto a driver that hasn't passed `canary`
#                         or that differs from origin/main's bin ŌĆö blocked, the
#                         daemons keep their last-validated driver. --no-gate is the
#                         manual override; --gate-only just reports whether a restart
#                         would be allowed (no pull/restart; exit 0=allowed, 1=blocked).
#   backlog-agents list         Show installed agent labels + their state.
#
#   backlog-agents doctor       Preflight health check. Reports drift between the
#                         manifest (~/dotfiles/active-projects.txt), the project
#                         dirs, and the installed launchd daemons ŌĆö plus per-project
#                         config hygiene (gitignore patterns, status-hook resolves,
#                         plists pointing at canonical de-symlinked paths, budgets
#                         file present, required tools). Read-only; never changes
#                         state. Exits non-zero if any hard check FAILs.
#
#   backlog-agents canary [--check] [--json]
#                         Blast-radius control for the shared driver. Run mode
#                         validates the current driver (self-test suite + doctor)
#                         and records a pass keyed to its bin SHA. --check is the
#                         read-only gate (exit 0 iff the running driver passed) ŌĆö
#                         the reaper-restart / fleet-freeze consult it so a daemon
#                         never comes back up on an unvalidated driver.
#
#   backlog-agents metrics [--json]
#                         Efficiency metrics from each project's per-tick ledger
#                         (.claude/backlog-history.jsonl). Per-project table plus a
#                         fleet summary of: total ticks, completed items,
#                         tokens-per-completion, success rate (exit_code==0 / total),
#                         and retry rate (ticks per completed item). NOTE: history
#                         has no explicit "completed" flag yet, so a completion is
#                         APPROXIMATED as a tick with exit_code==0 AND a non-empty
#                         work_commit. --json emits a machine-readable object.
#
#   backlog-agents daemon-sync [--interval <seconds>] [--once]
#                       Run `backlog-agents sync` in a loop, keeping all projects
#                       pulled and agents healthy. Default interval is 86400s
#                       (24h). --once runs a single sync and exits (testing).
#                       Each cycle's RESTART is canary/skew-gated (see `sync`), so
#                       the loop can pull a new driver but will refuse to push it
#                       fleet-wide until `canary` validates it ŌĆö agents keep the
#                       last-good driver until then.
#
#   backlog-agents install-watchdog
#                       Install a launchd plist that runs `daemon-sync` as a
#                       background agent, keeping all projects synced daily.
#                       Idempotent: replaces an existing plist if present.
#
#   backlog-agents uninstall-watchdog
#                       Boot out and remove the sync-watchdog launchd plist.
#
#   backlog-agents monitor [--fix] [--interval <seconds>] [--once]
#                       Fleet-wide agent log monitor. Scans .claude/backlog-agent.log
#                       across all projects for failure patterns (git conflicts,
#                       dirty trees, push failures, stale locks, bad cooldowns,
#                       stuck agents) and auto-fixes where safe. --fix applies
#                       corrections; without it, runs dry-run (report only).
#                       Default interval is 60s. --once runs a single scan.
#
#   backlog-agents install-monitor
#                       Install a launchd plist that runs the monitor continuously
#                       in auto-fix mode. See also: monitor, uninstall-monitor.
#
#   backlog-agents uninstall-monitor
#                       Boot out and remove the monitor launchd plist.
#
# Dashboard flags:
#   --fetch    git fetch -q each project before reading state
#   --watch    refresh every 10s (Ctrl-C to exit)
#   --effort   add log-size column
#   --day      bucket right column by today instead of 7d
#   --compact  single-line per project, skip machines table
#   --artifacts show uncommitted changes per host per project
#
# Sync flags:
#   --no-pull         skip dotfiles + project pulls (just restart agents)
#   --restart-only    same as --no-pull, also skip the final dashboard print
#
# Per-project state lookup is polyglot during the migration:
#   status file:    .claude/backlog-status.json (new) or .claude/loop-status.json (legacy)
#   history file:   .claude/backlog-history.jsonl (new) or .claude/effort-log.jsonl (legacy)
#   daemon plist:   com.${USER}.<n>.backlog-agent.plist (new) or com.${USER}.<n>.backlog-loop.plist (legacy)
#
# Requires `jq` (brew install jq).

set -euo pipefail
LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$LIB_DIR/_lib.sh"

# Walk both ~/dev/projects/active/ and ~/dev/projects/ (legacy top-level
# layout). Repos with a status file show up regardless of which layer
# they're in. Override with `BACKLOGS_PROJECTS_ROOTS=(...)`.
if [[ -z "${BACKLOGS_PROJECTS_ROOTS+x}" ]]; then
  PROJECTS_ROOTS=("$HOME/dev/projects/active" "$HOME/dev/projects")
else
  PROJECTS_ROOTS=("${BACKLOGS_PROJECTS_ROOTS[@]}")
fi
DOTFILES="$HOME/dotfiles"
ACTIVE_ROOT="$HOME/dev/projects/active"

command -v jq >/dev/null 2>&1 || { echo "backlog-agents: requires jq (brew install jq)" >&2; exit 1; }

# ANSI
B=$'\e[1m'; DIM=$'\e[2m'; RS=$'\e[0m'
CY=$'\e[36m'; GN=$'\e[32m'; YL=$'\e[33m'; RD=$'\e[31m'

info() { echo "ŌåÆ $*"; }
ok()   { echo "  Ō£ō $*"; }
warn() { echo "  ! $*"; }

# ---- helpers ----

iso_to_epoch() {
  local iso="$1"
  if [[ "$iso" == *.*Z ]]; then
    iso="${iso%.*Z}Z"
  fi
  iso="${iso%Z}"
  date -j -u -f '%Y-%m-%dT%H:%M:%S' "$iso" '+%s' 2>/dev/null || echo ""
}

# Discover per-project status + history files, polyglot during migration.
find_status_file() {
  local proj="$1"
  if   [[ -f "$proj/.claude/backlog-status.json" ]]; then echo "$proj/.claude/backlog-status.json"
  elif [[ -f "$proj/.claude/loop-status.json"    ]]; then echo "$proj/.claude/loop-status.json"
  fi
}
find_history_file() {
  local proj="$1"
  if   [[ -f "$proj/.claude/backlog-history.jsonl" ]]; then echo "$proj/.claude/backlog-history.jsonl"
  elif [[ -f "$proj/.claude/effort-log.jsonl"      ]]; then echo "$proj/.claude/effort-log.jsonl"
  fi
}
find_backlog_file() {
  local proj="$1"
  if   [[ -f "$proj/docs/Backlog.md" ]]; then echo "$proj/docs/Backlog.md"
  elif [[ -f "$proj/Backlog.md"      ]]; then echo "$proj/Backlog.md"
  elif [[ -f "$proj/backlog.txt"     ]]; then echo "$proj/backlog.txt"
  fi
}

# Print the first actionable item in the `## Open` section: a `- [ ]`
# (open), `- [!]` (retry after answered block), or `- [~]` (in progress).
# Skips `- [?]` (blocked on user) since the worker can't act on those.
# Strips the marker, leading emoji prefix tokens (­¤ö┤/­¤¤Ī/­¤¤ó, "P1 ŌĆö", etc.)
# are preserved so the priority is visible in the dashboard.
top_open_item() {
  local file="$1"
  [[ -f "$file" ]] || { echo ""; return; }
  awk '
    /^## Open/        { in_open=1; next }
    in_open && /^## / { exit }
    in_open && /^- \[[ !~]\] / {
      sub(/^- \[[ !~]\] /, "")
      sub(/ *<!-- @[^>]*-->$/, "")   # hide the claim owner stamp
      sub(/[. ]+$/, "")
      print
      exit
    }
  ' "$file"
}

# ---- subcommand: dashboard (default) ----

snapshot() {
  local now; now="$(date '+%s')"

  local cutoff_5h cutoff_right
  cutoff_5h=$(( now - 18000 ))
  if (( DAY )); then
    cutoff_right="$(date -j -f '%Y-%m-%d %H:%M:%S' "$(date '+%Y-%m-%d') 00:00:00" '+%s')"
  else
    cutoff_right=$(( now - 604800 ))
  fi

  local -a rows=()

  # Fleet-wide host tracking (cross-machine).
  local this_host; this_host="$(hostname)"
  this_host_short="${this_host%.local}"
  local fleet_hosts_set='|'
  local this_machine_projects=0

  # Per-machine accumulators (built during project loop).
  # Uses parallel indexed arrays ŌĆö bash 3.2 compatible (macOS default bash).
  # _MAP_IDX is a global set by _map_ensure as a side-channel (command
  # substitution runs in a subshell in bash 3.2, so functions that modify
  # arrays can't return values via stdout).
  _MAP_IDX=-1
  _map_keys=()        # ordered list of unique hostname keys
  _map_5h=()          # parallel: 5h token sums
  _map_right=()       # parallel: right-column token sums
  _map_proj=()        # parallel: project counts
  _map_seen=()        # parallel: last tick epoch (max)
  _map_driver=()      # parallel: driver SHA this host last reported (version-skew)

  _map_idx() {
    local k="$1" i
    for i in "${!_map_keys[@]}"; do
      [[ "${_map_keys[$i]}" == "$k" ]] && { printf '%d' "$i"; return 0; }
    done
    return 1
  }
  _map_ensure() {
    local k="$1" i
    for i in "${!_map_keys[@]}"; do
      if [[ "${_map_keys[$i]}" == "$k" ]]; then
        _MAP_IDX=$i
        return 0
      fi
    done
    _map_keys+=("$k")
    _map_5h+=(0); _map_right+=(0); _map_proj+=(0); _map_seen+=(0); _map_driver+=("")
    _MAP_IDX=$((${#_map_keys[@]} - 1))
    return 0
  }
  # Record the driver SHA a host last reported (only for hosts already in the
  # map; doesn't conjure phantom machines). Last write wins ŌĆö all projects on a
  # host run the same shared driver, so they agree.
  _map_set_driver() {
    local k="$1" v="$2" i
    [[ -z "$v" || "$v" == "null" ]] && return 0
    i="$(_map_idx "$k")" || return 0
    _map_driver[$i]="$v"
  }
  _map_add() {
    _map_ensure "$1"
    local i=$_MAP_IDX t5h="${2:-0}" tr="${3:-0}"
    _map_5h[$i]=$(( ${_map_5h[$i]:-0} + t5h ))
    _map_right[$i]=$(( ${_map_right[$i]:-0} + tr ))
    _map_proj[$i]=$(( ${_map_proj[$i]:-0} + 1 ))
  }
  _map_max_seen() {
    _map_ensure "$1"
    local i=$_MAP_IDX v="${2:-0}"
    (( v > ${_map_seen[$i]:-0} )) && _map_seen[$i]=$v
    return 0
  }

  # Count local agent plists (new label, old label, legacy label).
  local local_daemons=0
  local pl
  for pl in "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-agent.plist \
            "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog.plist \
            "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-loop.plist; do
    [[ -f "$pl" ]] && local_daemons=$((local_daemons + 1))
  done

  # Dedupe candidates by realpath.
  local -a candidates=()
  local root proj_dir
  for root in "${PROJECTS_ROOTS[@]}"; do
    [[ -d "$root" ]] || continue
    for proj_dir in "$root"/*/; do
      [[ -d "$proj_dir" ]] || continue
      candidates+=("${proj_dir%/}")
    done
  done

  local seen='|'
  local -a unique=()
  for proj_dir in "${candidates[@]}"; do
    local real
    real="$(cd "$proj_dir" 2>/dev/null && pwd -P)" || continue
    case "$seen" in
      *"|$real|"*) continue ;;
    esac
    seen="${seen}${real}|"
    unique+=("$real")
  done

  for proj_dir in "${unique[@]}"; do
    local proj="$proj_dir"
    local status; status="$(find_status_file "$proj")"
    local log;    log="$(find_history_file "$proj")"
    [[ -n "$status" ]] || continue

    if (( FETCH )); then
      git -C "$proj" fetch -q origin 2>/dev/null || true
    fi

    local name; name="$(basename "$proj")"
    local last_tick last_item last_exit last_pull
    last_tick="$(jq -r '.last_tick_at // empty' "$status")"
    last_item="$(jq -r '.last_item // ""' "$status")"
    last_exit="$(jq -r '.last_exit_code // 0' "$status")"
    last_pull="$(jq -r '(.last_pull_count // 0 | tostring)' "$status")"
    [[ "$last_pull" == "0" || "$last_pull" == "null" ]] && last_pull=""

    # Prefer the live "top of Open" from docs/Backlog.md over the
    # status JSON's last_item ŌĆö last_item is set by the status hook
    # at end-of-iteration and can drift empty when the hook's scrape
    # misses (e.g. format drift in the backlog file). The top-of-Open
    # reading is the forward-looking signal: what's being worked on
    # right now, or what the worker will pick next.
    local backlog_file current_item
    backlog_file="$(find_backlog_file "$proj")"
    current_item=""
    if [[ -n "$backlog_file" && "$backlog_file" == *.md ]]; then
      current_item="$(top_open_item "$backlog_file")"
    fi
    [[ -z "$current_item" ]] && current_item="$last_item"

    local tick_epoch="" age=0 state="?" state_color="$DIM"
    [[ -n "$last_tick" ]] && tick_epoch="$(iso_to_epoch "$last_tick")"
    if [[ -n "$tick_epoch" ]]; then
      age=$(( now - tick_epoch ))
      if   (( age < 1800 )); then state="fresh"; state_color="$GN"
      elif (( age < 7200 )); then state="idle";  state_color="$DIM"
      else                        state="STALE"; state_color="$RD"
      fi
    fi
    [[ "$last_exit" != "0" ]] && state_color="$RD"

    local sum_5h=0 sum_right=0 active_host="" hosts_csv="" has_this_work="false"
    if [[ -n "$log" ]]; then
      local out
      out="$(jq -s -r \
        --argjson c5h "$cutoff_5h" --argjson cR "$cutoff_right" --arg thisHost "$this_host_short" '
        def norm: sub("\\.[0-9]+Z$"; "Z") | fromdateiso8601;
        ([ .[] | { t: (.ts | norm), tok: (.tokens // 0), h: (.host // "" | sub("\\.local$"; "")) } ] | sort_by(.t)) as $rs
        | ([$rs[] | select(.tok > 0)] | last | .h // "ŌĆö") as $host
        | ([$rs[].h // empty] | unique | join(",")) as $hosts
        | "\($host)|" +
          "\(([$rs[] | select(.t >= $c5h) | .tok] | add // 0))|" +
          "\(([$rs[] | select(.t >= $cR)  | .tok] | add // 0))|" +
          "\($hosts)|" +
          "\([$rs[] | select(.h == $thisHost and .tok > 0)] | length > 0)|" +
          "\([$rs | group_by(.h)[] | "\(.[0].h):\([.[] | select(.t >= $c5h) | .tok] | add // 0):\([.[] | select(.t >= $cR) | .tok] | add // 0)"] | join(";"))"
      ' "$log" 2>/dev/null || printf '%s\n' "ŌĆö|0|0||false|")"
      IFS='|' read -r active_host sum_5h sum_right hosts_csv has_this_work per_host_groups <<< "$out"
    fi

    # Per-machine token aggregation from per-host groups.
    if [[ -n "$per_host_groups" ]]; then
      IFS=';' read -ra hgroups <<< "$per_host_groups"
      local group h t5h tr
      for group in "${hgroups[@]}"; do
        [[ -z "$group" ]] && continue
        IFS=':' read -r h t5h tr <<< "$group"
        [[ -z "$h" || "$h" == "ŌĆö" ]] && continue
        _map_add "$h" "$t5h" "$tr"
        if [[ -n "${tick_epoch:-}" && "${tick_epoch:-0}" != "0" ]]; then
          _map_max_seen "$h" "$tick_epoch"
        fi
      done
    fi

    local active_host_short="${active_host%.local}"
    active_host_short="${active_host_short#Kash-MBA-}"
    (( ${#active_host_short} > 14 )) && active_host_short="${active_host_short:0:11}ŌĆ”"

    # Compute other-hosts column (all hosts that worked on this project, minus the active one).
    local other_hosts=""
    if [[ -n "$hosts_csv" ]]; then
      local oh_arr=()
      IFS=',' read -ra host_arr_oh <<< "$hosts_csv"
      for h in "${host_arr_oh[@]}"; do
        [[ -z "$h" ]] && continue
        local hc="${h%.local}"
        hc="${hc#Kash-MBA-}"
        (( ${#hc} > 12 )) && hc="${hc:0:9}ŌĆ”"
        [[ "$hc" == "$active_host_short" ]] && continue
        oh_arr+=("$hc")
      done
      if [[ ${#oh_arr[@]} -gt 0 ]]; then
        local _saved_ifs="$IFS"
        IFS=,
        other_hosts="${oh_arr[*]}"
        IFS="$_saved_ifs"
      fi
    fi

    # Fleet-wide host tracking
    if [[ -n "$hosts_csv" ]]; then
      local h
      IFS=',' read -ra host_arr <<< "$hosts_csv"
      for h in "${host_arr[@]}"; do
        [[ -z "$h" ]] && continue
        h="${h%.local}"
        case "$fleet_hosts_set" in
          *"|$h|"*) ;;
          *) fleet_hosts_set="${fleet_hosts_set}${h}|" ;;
        esac
      done
    fi
    [[ "$has_this_work" == "true" ]] && this_machine_projects=$((this_machine_projects + 1))

    local age_str=""
    [[ -n "$tick_epoch" ]] && age_str="$(fmt_age $age)"
    local item_short="${current_item:-}"
    (( ${#item_short} > 36 )) && item_short="${item_short:0:33}ŌĆ”"

    local log_mb=""
    if [[ -n "$log" ]]; then
      log_mb="$(awk -v b="$(wc -c < "$log")" 'BEGIN{printf "%.2fM", b/1048576}')"
    fi

    # Sort key: projects with open items first, then by freshness, then by recency.
    local has_item=1; [[ -n "${current_item:-}" ]] && has_item=0
    local state_rank=2
    case "$state" in fresh) state_rank=0 ;; idle) state_rank=1 ;; STALE) state_rank=2 ;; esac
    local sort_key; printf -v sort_key '%d%d%06d' "$has_item" "$state_rank" "$age"

    rows+=("$sort_key|$name|$age_str|$active_host_short|$item_short|$state|$state_color|$(fmt_tok $sum_5h)|$(fmt_tok $sum_right)|$last_pull|$log_mb|$other_hosts|$age")
  done

  # Sort rows by priority: open items first, then freshness, then recency.
  if (( ${#rows[@]} > 1 )); then
    local -a sorted=()
    while IFS= read -r r; do
      [[ -n "$r" ]] && sorted+=("$r")
    done < <(printf '%s\n' "${rows[@]}" | sort -t'|' -k1,1n)
    rows=("${sorted[@]}")
  fi

  # ---- header ----
  # right_label feeds the per-project table column header below ("5h | week"
  # or "5h | today"). The host-wide rolling-totals bars that used to live
  # here were transcript-derived and drifted from /usage's numbers, so we
  # just point users at /usage instead ŌĆö it's authoritative for the plan
  # budget, and we couldn't match it from a shell script anyway.
  local right_label="week"; (( DAY )) && right_label="today"

  printf '%sBACKLOGS%s\n' "${B}${CY}" "${RS}"
  printf '  %sper-project tick state. for host token usage, run %s/usage%s%s in Claude Code.%s\n' \
    "${DIM}" "${B}" "${RS}${DIM}" "" "${RS}"

  if (( ${#rows[@]} == 0 )); then
    printf '\n  %sNo projects with .claude/backlog-status.json or .claude/loop-status.json under: %s%s\n' \
      "$DIM" "${PROJECTS_ROOTS[*]}" "$RS"
    return
  fi

  # Health summary: count daemon states and watchdog status.
  local fresh=0 idle=0 stale=0
  for row in "${rows[@]}"; do
    local st; st="${row#*|*|*|*|*|}"
    st="${st%%|*}"
    case "$st" in
      fresh) fresh=$((fresh + 1)) ;;
      idle)  idle=$((idle + 1)) ;;
      STALE) stale=$((stale + 1)) ;;
    esac
  done
  local total=$((fresh + idle + stale))

  # Per-machine state counts.
  local m_active=0 m_idle=0 m_stale=0
  if (( ${#_map_keys[@]} > 0 )); then
    local mh_idx
    for mh_idx in "${!_map_keys[@]}"; do
      local mage=$(( now - ${_map_seen[$mh_idx]:-0} ))
      if   (( mage < 1800 )); then m_active=$((m_active + 1))
      elif (( mage < 7200 )); then m_idle=$((m_idle + 1))
      else m_stale=$((m_stale + 1))
      fi
    done
  fi

  local fleet_host_count
  fleet_host_count="$(echo "${fleet_hosts_set#|}" | tr '|' '\n' | grep -c . 2>/dev/null || echo 0)"
  printf '  %s%d machines%s known  |  this machine (%s%s%s): active on %s%d%s of %d projects\n' \
    "$B" "$fleet_host_count" "$RS" \
    "$B" "$this_host_short" "$RS" \
    "$GN" "$this_machine_projects" "$RS" "$total"

  # Fleet-wide backlog counts: sum open and done across all active projects.
  local total_open=0 total_done=0
  for proj_dir in "${unique[@]}"; do
    local s; s="$(find_status_file "$proj_dir")"
    [[ -n "$s" ]] || continue
    local o d
    o="$(jq -r '(.backlog.open // 0 | tostring)' "$s" 2>/dev/null || echo 0)"
    d="$(jq -r '(.backlog.done // 0 | tostring)' "$s" 2>/dev/null || echo 0)"
    [[ "$o" =~ ^[0-9]+$ ]] && total_open=$((total_open + o))
    [[ "$d" =~ ^[0-9]+$ ]] && total_done=$((total_done + d))
  done

  local have_sync=0 have_watch=0
  [[ -f "$HOME/Library/LaunchAgents/com.${USER}.backlog-agents-sync.plist" ]] && have_sync=1
  [[ -f "$HOME/Library/LaunchAgents/com.${USER}.dev-projects-watchdog.plist" ]] && have_watch=1
  printf '  projects: %d (%s%d fresh%s, %s%d idle%s, %s%d stale%s)  |' \
    "$total" "$GN" "$fresh" "$RS" "$DIM" "$idle" "$RS" "$RD" "$stale" "$RS"
  if (( ${#_map_keys[@]} > 0 )); then
    printf '  machines: %d (%s%d active%s, %s%d idle%s, %s%d stale%s)  |' \
      "${#_map_keys[@]}" "$GN" "$m_active" "$RS" "$DIM" "$m_idle" "$RS" "$RD" "$m_stale" "$RS"
  fi
  printf '  open: %s%d%s  done: %s%d%s  |' \
    "$GN" "$total_open" "$RS" "$DIM" "$total_done" "$RS"
  printf '  this machine: %s%d daemons%s' "$B" "$local_daemons" "$RS"
  if (( have_sync && have_watch )); then
    printf ', watchdog %sŌ£ō%s\n' "$GN" "$RS"
  elif (( have_sync || have_watch )); then
    printf ', watchdog %s%s%s\n' \
      "$( ((have_sync && have_watch)) && echo "$GN" || echo "$RD")" \
      "$( ((have_sync)) && printf 'sync' ; ((have_sync && have_watch)) && printf '/' ; ((have_watch)) && printf 'new' )" \
      "$RS"
  else
    printf ', watchdog %sŌ£Ś%s\n' "$RD" "$RS"
  fi

  # Monitor daemon status ŌĆö aggregate from per-host files
  local mon_status_dir="$ACTIVE_ROOT/backlog-infra/.claude"
  if launchctl print "gui/$(id -u)/com.${USER}.backlog-agents-monitor" >/dev/null 2>&1; then
    local mon_sweeps=0 mon_fixed=0 mon_flagged=0 mon_hosts=0
    local ms_file
    for ms_file in "$mon_status_dir"/monitor-status-*.json; do
      [[ -f "$ms_file" ]] || continue
      mon_sweeps=$(( mon_sweeps + $(jq -r '.sweeps_total // 0' "$ms_file" 2>/dev/null || echo 0) ))
      mon_fixed=$(( mon_fixed + $(jq -r '.fixed_total // 0' "$ms_file" 2>/dev/null || echo 0) ))
      mon_flagged=$(( mon_flagged + $(jq -r '.flagged_total // 0' "$ms_file" 2>/dev/null || echo 0) ))
      mon_hosts=$(( mon_hosts + 1 ))
    done
    # Also accept legacy single file
    local leg="$mon_status_dir/monitor-status.json"
    if [[ -f "$leg" ]]; then
      mon_sweeps=$(( mon_sweeps + $(jq -r '.sweeps_total // 0' "$leg" 2>/dev/null || echo 0) ))
      mon_fixed=$(( mon_fixed + $(jq -r '.fixed_total // 0' "$leg" 2>/dev/null || echo 0) ))
      mon_flagged=$(( mon_flagged + $(jq -r '.flagged_total // 0' "$leg" 2>/dev/null || echo 0) ))
      mon_hosts=$(( mon_hosts + 1 ))
    fi
    if (( mon_hosts > 0 )); then
      printf '  monitor: %sactive%s (%d host%s)  sweeps: %s%d%s  fixed: %s%d%s  flagged: %s%d%s\n' \
        "$GN" "$RS" "$mon_hosts" "$([[ $mon_hosts -eq 1 ]] && echo '' || echo 's')" "$B" "$mon_sweeps" "$RS" "$GN" "$mon_fixed" "$RS" "$YL" "$mon_flagged" "$RS"
    else
      printf '  monitor: %sactive%s (no status file yet)\n' "$GN" "$RS"
    fi
  else
    printf '  monitor: %snot installed%s\n' "$DIM" "$RS"
  fi

  echo

  # ---- driver version-skew (W1) ----
  # Capture each host's reported driver SHA from its per-host status file, and
  # compute the reference (origin/main's last bin commit). The MACHINES table
  # flags any host whose driver differs from the reference ŌĆö that's the "M1 ran
  # the broken driver for hours because the fix was unpulled" incident, now a
  # glance instead of a guess.
  local dh_proj dh_file dh_key dh_sha
  for dh_proj in "${unique[@]}"; do
    for dh_file in "$dh_proj/.claude/backlog-status-"*.json; do
      [[ -f "$dh_file" ]] || continue
      dh_key="$(basename "$dh_file" .json)"; dh_key="${dh_key#backlog-status-}"
      dh_key="${dh_key%.local}"   # map keys are .local-stripped (see _map_add)
      dh_sha="$(jq -r '.driver_sha // empty' "$dh_file" 2>/dev/null || true)"
      _map_set_driver "$dh_key" "$dh_sha"
    done
  done
  local ref_driver_sha="" infra_dir="$ACTIVE_ROOT/backlog-infra"
  if [[ -d "$infra_dir/.git" ]]; then
    (( FETCH )) && git -C "$infra_dir" fetch -q origin 2>/dev/null || true
    ref_driver_sha="$(git -C "$infra_dir" log -1 --format=%h origin/main -- bin 2>/dev/null || true)"
    [[ -z "$ref_driver_sha" ]] && ref_driver_sha="$(git -C "$infra_dir" log -1 --format=%h -- bin 2>/dev/null || true)"
  fi

  # ---- MACHINES table ----
  if (( ! COMPACT )); then
  if (( ${#_map_keys[@]} > 0 )); then
    local right_upper; right_upper="$(printf '%s' "$right_label" | tr '[:lower:]' '[:upper:]')"
    printf '  %sMACHINES%s (%d known)\n' "${B}${CY}" "${RS}" "${#_map_keys[@]}"
    printf '  %s%-20s %-21s %-11s %-11s %-9s %-7s %-10s%s\n' \
      "$DIM" "MACHINE" "5h TOKENS (rate)" "$right_upper" "LAST SEEN" "DAEMONS" "STATUS" "DRIVER" "$RS"

    local sorted_hosts
    sorted_hosts="$(printf '%s\n' "${_map_keys[@]}" | sort)"
    local mh mi
    while IFS= read -r mh; do
      [[ -z "$mh" ]] && continue
      mi="$(_map_idx "$mh")"
      [[ -z "$mi" ]] && continue
      local mh_short="${mh%.local}"
      mh_short="${mh_short#Kash-MBA-}"
      (( ${#mh_short} > 14 )) && mh_short="${mh_short:0:11}ŌĆ”"
      local t5h_raw=${_map_5h[$mi]:-0}
      local m5h; m5h="$(fmt_tok $t5h_raw)"
      local mr; mr="$(fmt_tok ${_map_right[$mi]:-0})"
      local mseen=${_map_seen[$mi]:-0}
      local mseen_str="ŌĆö"
      local ms="?" msc="$DIM"
      if (( mseen > 0 )); then
        local mage2; mage2=$(( now - mseen ))
        mseen_str="$(fmt_age $mage2)"
        if   (( mage2 < 1800 )); then ms="active"; msc="$GN"
        elif (( mage2 < 7200 )); then ms="idle";  msc="$DIM"
        else                       ms="stale"; msc="$RD"
        fi
      fi
      # Token burn rate: tokens-per-minute in the 5h window.
      # Build a fixed-width combined field (token + rate) so columns align.
      local tok_field; tok_field="${B}${m5h}${RS}"
      local tok_visible="${#m5h}"
      local rate_str=""
      if (( t5h_raw > 0 )); then
        local rate; rate=$(( t5h_raw / 300 ))
        rate_str=" $(fmt_tok $rate)/m"
        tok_field+="${DIM}${rate_str}${RS}"
        tok_visible=$(( tok_visible + ${#rate_str} ))
      fi
      # Pad to target visible width so the WEEK column stays aligned.
      local tok_pad=$(( 21 - tok_visible ))
      if (( tok_pad > 0 )); then
        local spaces; printf -v spaces '%*s' "$tok_pad" ''
        tok_field+="$spaces"
      fi
      local daemon_str=""
      if [[ "$mh" == "$this_host" || "$mh" == "${this_host%.local}" ]]; then
        daemon_str="${local_daemons}"
        (( have_sync && have_watch )) && daemon_str+=" +2w"
        (( have_sync && ! have_watch )) && daemon_str+=" +sw"
        (( ! have_sync && have_watch )) && daemon_str+=" +pw"
      else
        daemon_str="${_map_proj[$mi]:-0} d"
      fi
      # Driver column: green if it matches the reference, red + ŌÜĀ if it's skewed.
      local mdriver="${_map_driver[$mi]:-}"
      local driver_field
      if [[ -z "$mdriver" ]]; then
        driver_field="${DIM}ŌĆö${RS}"
      elif [[ -n "$ref_driver_sha" && "$mdriver" != "$ref_driver_sha" ]]; then
        driver_field="${RD}${mdriver} ŌÜĀ${RS}"
      else
        driver_field="${GN}${mdriver}${RS}"
      fi
      printf '  %-20s %s %-11s %-11s %-9s %s%-7s%s %s\n' \
        "$mh_short" "$tok_field" "$mr" "$mseen_str" "$daemon_str" "$msc" "$ms" "$RS" "$driver_field"
    done <<< "$sorted_hosts"

    if [[ -n "$ref_driver_sha" ]]; then
      printf '  %sdriver ref (origin/main bin): %s%s\n' "$DIM" "$ref_driver_sha" "$RS"
    fi
    echo
  fi

  if (( ! COMPACT )); then

  if (( EFFORT )) ; then
    printf '  %s%-18s %-9s %-9s %-36s %-6s %-9s %-4s %-7s %-7s %-8s%s\n' \
      "$DIM" "PROJECT" "LAST BY" "TICK" "ITEM" "STATE" "ALSO BY" "PULL" "5h" "$right_label" "LOG" "$RS"
  else
    printf '  %s%-18s %-9s %-9s %-36s %-6s %-9s %-4s %-7s %-7s%s\n' \
      "$DIM" "PROJECT" "LAST BY" "TICK" "ITEM" "STATE" "ALSO BY" "PULL" "5h" "$right_label" "$RS"
  fi
  for row in "${rows[@]}"; do
    local name age host item state state_color s5h sR pulled log_mb other_hosts _sort _age
    IFS='|' read -r _sort name age host item state state_color s5h sR pulled log_mb other_hosts _age <<< "$row"
    (( ${#name} > 18 )) && name="${name:0:15}ŌĆ”"
    (( ${#other_hosts} > 9 )) && other_hosts="${other_hosts:0:6}ŌĆ”"
    if (( EFFORT )); then
      printf '  %-18s %-9s %-9s %-36s %s%-6s%s %-9s %-4s %-7s %-7s %-8s\n' \
        "$name" "$host" "$age" "$item" "$state_color" "$state" "$RS" "$other_hosts" "$pulled" "$s5h" "$sR" "$log_mb"
    else
      printf '  %-18s %-9s %-9s %-36s %s%-6s%s %-9s %-4s %-7s %-7s\n' \
        "$name" "$host" "$age" "$item" "$state_color" "$state" "$RS" "$other_hosts" "$pulled" "$s5h" "$sR"
    fi
  done
  fi  # ! COMPACT

  # ---- health alerts ----
  local alert_n=0
  local alert_lines=()
  for proj_dir in "${unique[@]}"; do
    local cd_file="$proj_dir/.claude/agent-cooldown.json"
    if [[ -f "$cd_file" ]]; then
      local cd_until_epoch cd_active=0 cd_reason cd_parsed
      cd_until_epoch="$(jq -r '.until_epoch // 0' "$cd_file" 2>/dev/null || echo 0)"
      [[ "$cd_until_epoch" =~ ^[0-9]+$ ]] && (( cd_until_epoch > now )) && cd_active=1
      if (( cd_active )); then
        local cd_name; cd_name="$(basename "$proj_dir")"
        cd_reason="$(jq -r '.reason // "plan-limit"' "$cd_file" 2>/dev/null)"
        cd_parsed="$(jq -r '.parsed_from_reset // false' "$cd_file" 2>/dev/null)"
        local remaining=$(( cd_until_epoch - now ))
        local remain_str=""
        if (( remaining >= 3600 )); then
          remain_str="$(printf '%dh %dm' $((remaining/3600)) $(((remaining%3600)/60))) left"
        elif (( remaining >= 60 )); then
          remain_str="$((remaining/60))m left"
        else
          remain_str="${remaining}s left"
        fi
        local precise_tag=""
        [[ "$cd_parsed" == "true" ]] && precise_tag="${YL}(precise)${RS} " || precise_tag="${DIM}(~estimated)${RS} "
        local until_time
        local today_midnight; today_midnight="$(date -j -f '%Y-%m-%d %H:%M:%S' "$(date '+%Y-%m-%d') 00:00:00" '+%s' 2>/dev/null || true)"
        if [[ -n "$today_midnight" ]] && (( cd_until_epoch >= today_midnight + 86400 )); then
          until_time="$(date -j -f '%s' "$cd_until_epoch" '+%b %d %H:%M' 2>/dev/null || echo '?')"
        else
          until_time="$(date -j -f '%s' "$cd_until_epoch" '+%H:%M' 2>/dev/null || echo '?')"
        fi
        alert_lines+=("  ${RD}${cd_name}${RS} ${precise_tag}cooldown (${cd_reason}) ŌĆö ${remain_str} (until ${until_time})")
        alert_n=$((alert_n + 1))
      fi
    fi
  done
  if (( alert_n > 0 )); then
    echo
    printf '  %sALERTS%s\n' "${B}${YL}" "${RS}"
    for line in "${alert_lines[@]}"; do printf '%s\n' "$line"; done
    echo
  fi

  # ---- stuck [~] items ----
  local stuck_n=0
  local stuck_lines=()
  local stuck_threshold=7200
  for proj_dir in "${unique[@]}"; do
    local backlog; backlog="$(find_backlog_file "$proj_dir")"
    local history; history="$(find_history_file "$proj_dir")"
    [[ -n "$backlog" && -n "$history" ]] || continue
    local pname; pname="$(basename "$proj_dir")"
    local wip_items
    wip_items="$(awk '
      /^## Open/        { in_sec=1; next }
      /^## In progress/ { in_sec=1; next }
      /^## /            { in_sec=0; next }
      in_sec && /^- \[~\] / { sub(/^- \[~\] /, ""); sub(/ *<!-- @[^>]*-->$/, ""); sub(/[. ]+$/, ""); print }
    ' "$backlog" 2>/dev/null || true)"
    [[ -n "$wip_items" ]] || continue
    while IFS= read -r wip_item; do
      [[ -z "$wip_item" ]] && continue
      local first_ts
      first_ts="$(jq -rs --arg it "$wip_item" \
        'map(select(.item == $it)) | sort_by(.ts) | .[0].ts // ""' \
        "$history" 2>/dev/null || true)"
      [[ -n "$first_ts" ]] || continue
      local first_epoch; first_epoch="$(iso_to_epoch "$first_ts" 2>/dev/null || echo "")"
      [[ -n "$first_epoch" ]] || continue
      local age=$(( now - first_epoch ))
      (( age > stuck_threshold )) || continue
      local age_str
      if (( age >= 86400 )); then
        age_str="$(printf '%dd %dh' $((age/86400)) $(((age%86400)/3600)))"
      elif (( age >= 3600 )); then
        age_str="$(printf '%dh %dm' $((age/3600)) $(((age%3600)/60)))"
      else
        age_str="$((age/60))m"
      fi
      stuck_lines+=("  ${RD}${pname}${RS} ${YL}[~]${RS} ${DIM}${age_str}${RS} ŌĆö ${wip_item:0:70}")
      stuck_n=$((stuck_n + 1))
    done <<< "$wip_items"
  done
  if (( stuck_n > 0 )); then
    echo
    printf '  %sSTUCK%s (>%dh in-progress)\n' "${B}${YL}" "${RS}" "$((stuck_threshold/3600))"
    for line in "${stuck_lines[@]}"; do printf '%s\n' "$line"; done
    echo
  fi

  # ---- artifacts ----
  if (( ARTIFACTS )); then
    local art_n=0 art_any=0
    local art_lines=()
    for proj_dir in "${unique[@]}"; do
      local pname; pname="$(basename "$proj_dir")"
      for host_status in "$proj_dir/.claude/backlog-status-"*.json; do
        [[ -f "$host_status" ]] || continue
        local hname; hname="$(basename "$host_status" .json)"
        hname="${hname#backlog-status-}"
        hname="${hname%.local}"
        hname="${hname#Kash-MBA-}"
        local uncommitted
        uncommitted="$(jq -r '
          (.artifacts.uncommitted // []) |
          if length == 0 then empty
          else .[] | "\(.status) \(.path)"
          end
        ' "$host_status" 2>/dev/null)"
        if [[ -n "$uncommitted" ]]; then
          art_any=1
          while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local st_code="${line:0:2}" st_path="${line:3}"
            local st_color="$DIM"
            case "$st_code" in
              "??"|" D"|"D ") st_color="$RD" ;;   # untracked / deleted
              " M"|"M "|"MM") st_color="$YL" ;;    # modified
              " A"|"R ")      st_color="$GN" ;;    # added / renamed
            esac
            art_lines+=("  ${pname}  ${DIM}${hname}${RS}  ${st_color}${st_code}${RS} ${DIM}${st_path}${RS}")
            art_n=$((art_n + 1))
          done <<< "$uncommitted"
        fi
      done
    done
    if (( art_any )); then
      printf '  %sARTIFACTS%s (%d file(s))\n' "${B}${CY}" "${RS}" "$art_n"
      for line in "${art_lines[@]}"; do printf '%s\n' "$line"; done
    echo
  fi
  fi  # ! COMPACT
  fi

  # ---- compact mode: skip everything below, render single-line per project ----
  if (( COMPACT )); then
    echo
    printf '  %-18s %-7s %-9s %-6s %-7s %s\n' "PROJECT" "STATE" "LAST BY" "PULL" "5h" "ITEM"
    for row in "${rows[@]}"; do
      local _sort name age_str host item state state_color s5h sR pulled _log_mb _oh _age
      IFS='|' read -r _sort name age_str host item state state_color s5h sR pulled _log_mb _oh _age <<< "$row"
      (( ${#item} > 40 )) && item="${item:0:37}ŌĆ”"
      printf '  %-18s %s%-6s%s %-9s %-6s %-7s %s\n' \
        "$name" "$state_color" "$state" "$RS" "$host" "$pulled" "$s5h" "$item"
    done
    return
  fi
}

# ---- subcommand: sync ----

# ---- canary + version-skew gate for sync (W3) ----
# Because bin/ is SHARED, `sync` restarting every agent is exactly how one bad
# driver commit goes fleet-wide (the 2026-05-28 cooldown bug broke all 7 daemons
# this way). Pulling is harmless ŌĆö it only updates files; ACTIVATING the pulled
# driver by restarting the daemons is the blast radius. So the gate sits in front
# of the RESTART, not the pull: a blocked restart leaves every daemon running its
# last-validated driver (still resident in the running process). Two conditions,
# both fail-safe (any uncertainty ŌåÆ block):
#   (1) no version-skew ŌĆö the local bin SHA must equal origin/main's bin SHA, so
#       we never restart onto a driver the pull failed to land or that diverged;
#   (2) canary passed    ŌĆö `canary --check` must be green for that SHA, so we
#       never restart onto a driver the hermetic self-test hasn't validated.
# Prints a one-line reason when it blocks (captured in the daemon-sync log).
_sync_gate_check() {
  local infra_dir="$ACTIVE_ROOT/backlog-infra"
  local cur="" origin=""
  if [[ -d "$infra_dir/.git" ]]; then
    git -C "$infra_dir" fetch origin main -q 2>/dev/null || true
    cur="$(git -C "$infra_dir" log -1 --format=%h -- bin 2>/dev/null || true)"
    origin="$(git -C "$infra_dir" log -1 --format=%h origin/main -- bin 2>/dev/null || true)"
  fi
  if [[ -z "$cur" ]]; then
    warn "sync gate: cannot determine the driver bin SHA (no backlog-infra git) ŌĆö refusing to restart agents (fail-safe)"
    return 1
  fi
  if [[ -n "$origin" && "$cur" != "$origin" ]]; then
    warn "sync gate: version-skew ŌĆö local bin ${cur} != origin/main bin ${origin} (pull blocked or diverged)."
    warn "          NOT restarting; daemons keep their current driver. Resolve the pull, then re-run \`backlog-agents sync\`."
    return 1
  fi
  if ! do_canary --check >/dev/null 2>&1; then
    warn "sync gate: driver ${cur} has not passed canary ŌĆö NOT restarting; daemons keep the last-validated driver."
    warn "          Run \`backlog-agents canary\` to validate this driver, then \`backlog-agents sync\`."
    return 1
  fi
  ok "sync gate: driver ${cur} ŌĆö canary green, no skew; safe to restart"
  return 0
}

do_sync() {
  local NO_PULL=0 RESTART_ONLY=0 NO_GATE=0 GATE_ONLY=0
  for arg in "$@"; do
    case "$arg" in
      --no-pull)      NO_PULL=1 ;;
      --restart-only) NO_PULL=1; RESTART_ONLY=1 ;;
      --no-gate)      NO_GATE=1 ;;
      --gate-only)    GATE_ONLY=1 ;;
      *) echo "backlog-agents sync: unknown flag: $arg" >&2; exit 2 ;;
    esac
  done

  # Read-only gate evaluation (no pull, no restart, no snapshot): exit 0 iff a
  # restart would be allowed right now. Useful as a fleet-freeze input + for tests.
  if (( GATE_ONLY )); then
    if _sync_gate_check; then return 0; else return 1; fi
  fi

  if (( NO_PULL == 0 )); then
    need_github_ssh "backlog-agents sync" || warn "SSH to GitHub is broken ŌĆö pulls will fail"

    info "pulling dotfiles"
    git -C "$DOTFILES" pull --ff-only origin main && ok "dotfiles up to date"

    info "running kash_setup.sh (idempotent)"
    ( . "$DOTFILES/bootstrap/kash_setup.sh" ) || warn "kash_setup.sh reported errors above"
    ok "bootstrap done"

    if [[ -d "$ACTIVE_ROOT" ]]; then
      info "pulling each active project"
      for proj in "$ACTIVE_ROOT"/*/; do
        [[ -d "$proj/.git" ]] || continue
        local local_name; local_name="$(basename "$proj")"
        if branch="$(git -C "$proj" symbolic-ref --short HEAD 2>/dev/null)"; then
          if git -C "$proj" pull --ff-only origin "$branch" >/dev/null 2>&1; then
            ok "$local_name (on $branch)"
          else
            warn "$local_name: pull --ff-only failed (probably dirty or diverged); leaving alone"
          fi
        else
          warn "$local_name: detached HEAD; skipping pull"
        fi
      done
    fi
  fi

  # ---- gate the restart on canary + version-skew (see _sync_gate_check) ----
  local do_restart=1
  if (( NO_GATE )); then
    warn "sync: --no-gate set ŌĆö bypassing the canary/skew gate (manual override)"
  elif ! _sync_gate_check; then
    do_restart=0
  fi

  # Restart daemons ŌĆö both legacy (.backlog-loop) and new (.backlog-agent) labels.
  if (( do_restart )); then
  info "restarting agents"
  local restarted=0
  local plist label name repo
  for plist in "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-agent.plist \
               "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog.plist \
               "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-loop.plist; do
    [[ -f "$plist" ]] || continue
    label="$(basename "$plist" .plist)"
    name="${label#com.${USER}.}"
    name="${name%.backlog-agent}"
    name="${name%.backlog}"
    name="${name%.backlog-loop}"
    repo="$ACTIVE_ROOT/$name"
    if [[ ! -d "$repo" ]]; then
      warn "$label points to $repo which doesn't exist; skipping (run \`dev-projects sync\`)"
      continue
    fi
    # If this is a legacy plist and a newer .backlog-agent.plist exists for the
    # same project, skip it ŌĆö only restart the canonical daemon.
    if [[ "$plist" != *backlog-agent.plist ]]; then
      local agent_plist="$HOME/Library/LaunchAgents/com.${USER}.${name}.backlog-agent.plist"
      if [[ -f "$agent_plist" ]]; then
        continue
      fi
    fi
    # If a tick is in flight (inflight file younger than 30 min), skip this daemon
    # to avoid killing a running Claude session mid-work.
    local inflight="$repo/.claude/backlog-agent-tick.inflight"
    if [[ -f "$inflight" ]]; then
      local age="$(perl -e 'print time - (stat(shift))[9]' "$inflight" 2>/dev/null || echo 0)"
      if (( age < 1800 )); then
        warn "$name: tick in flight (${age}s ago), skipping restart"
        restarted=$((restarted + 1))
        continue
      fi
    fi
    info "restarting $label"
    if launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1; then
      launchctl bootout "gui/$(id -u)/$label" 2>/dev/null || true
      for _ in $(seq 1 15); do
        launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1 || break
        sleep 1
      done
    fi
    rmdir "$repo/.claude/backlog.lock"           2>/dev/null || true
    rmdir "$repo/.claude/backlog-loop.lock"      2>/dev/null || true
    rmdir "$repo/.claude/backlog-agent.lock"     2>/dev/null || true
    if launchctl bootstrap "gui/$(id -u)" "$plist" 2>&1; then
      ok "$label running"
      restarted=$((restarted + 1))
    else
      warn "bootstrap failed for $label"
    fi
  done
  ok "$restarted agent(s) restarted"
  fi

  if (( RESTART_ONLY == 0 )); then
    echo
    snapshot
  fi
}

# ---- subcommand: list ----

do_list() {
  local plist label state
  printf '  %s%-40s %-12s %s%s\n' "$DIM" "LABEL" "STATE" "PLIST" "$RS"
  local found=0
for plist in "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-agent.plist \
             "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog.plist \
             "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-loop.plist; do
  [[ -f "$plist" ]] || continue
  label="$(basename "$plist" .plist)"
  local list_name="${label#com.${USER}.}"
  list_name="${list_name%.backlog-agent}"
  list_name="${list_name%.backlog}"
  list_name="${list_name%.backlog-loop}"
  if [[ "$plist" != *backlog-agent.plist ]]; then
    [[ -f "$HOME/Library/LaunchAgents/com.${USER}.${list_name}.backlog-agent.plist" ]] && continue
  fi
  found=1
  if launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1; then
      state="${GN}running${RS}"
    else
      state="${YL}installed${RS}"
    fi
    printf '  %-40s %-22s %s\n' "$label" "$state" "$plist"
  done
  if (( found == 0 )); then
    printf '  %s(no com.%s.*.backlog* plists installed)%s\n' "$DIM" "$USER" "$RS"
  fi
}

do_daemon_sync() {
  local interval=86400 once=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --interval) interval="$2"; shift 2 ;;
      --once)     once=1; shift ;;
      -*)         echo "backlog-agents daemon-sync: unknown flag: $1" >&2; exit 2 ;;
      *)          echo "backlog-agents daemon-sync: unexpected argument: $1" >&2; exit 2 ;;
    esac
  done
  [[ "$interval" -ge 60 ]] || { echo "backlog-agents daemon-sync: --interval must be >= 60 seconds" >&2; exit 2; }
  if (( once == 1 )); then
    info "single sync (--once)"
    do_sync
    return
  fi
  info "syncing every ${interval}s (ctrl-c to stop)"
  while true; do
    echo
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] sync start"
    do_sync
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] sleeping ${interval}s"
    sleep "$interval"
  done
}

do_install_watchdog() {
  local label="com.${USER}.backlog-agents-sync"
  local plist="$HOME/Library/LaunchAgents/${label}.plist"
  local bin_path
  bin_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

  mkdir -p "$HOME/Library/LaunchAgents"

  if [[ -f "$plist" ]]; then
    info "replacing existing backlog-agents-sync plist"
    launchctl bootout "gui/$(id -u)/${label}" 2>/dev/null || true
    local i=0
    while launchctl print "gui/$(id -u)/${label}" >/dev/null 2>&1 && (( i < 10 )); do
      sleep 1; i=$((i + 1))
    done
  fi

  local label_x bin_path_x home_x bin_dir_x
  label_x="$(xml_escape "$label")"
  bin_path_x="$(xml_escape "$bin_path")"
  local bin_dir; bin_dir="$(dirname "$bin_path")"
  bin_dir_x="$(xml_escape "$bin_dir")"
  home_x="$(xml_escape "$HOME")"

  cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${label_x}</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${bin_path_x}</string>
        <string>daemon-sync</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${bin_dir_x}:${home_x}/dotfiles/bin:${home_x}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>${home_x}</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>60</integer>

    <key>StandardOutPath</key>
    <string>${home_x}/Library/Logs/backlog-agents-sync.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>${home_x}/Library/Logs/backlog-agents-sync.stderr.log</string>
</dict>
</plist>
EOF

  mkdir -p "$HOME/Library/Logs"
  if ! launchctl bootstrap "gui/$(id -u)" "$plist"; then
    echo "backlog-agents: bootstrap failed for ${label}. plist is at $plist." >&2
    exit 1
  fi
  ok "backlog-agents-sync agent installed: ${label}"
  info "  plist: ${plist}"
  info "  logs:  ~/Library/Logs/backlog-agents-sync.{stdout,stderr}.log"
  info "  status: launchctl print gui/\$(id -u)/${label}"
}

do_uninstall_watchdog() {
  local label="com.${USER}.backlog-agents-sync"
  local plist="$HOME/Library/LaunchAgents/${label}.plist"

  if launchctl print "gui/$(id -u)/${label}" >/dev/null 2>&1; then
    launchctl bootout "gui/$(id -u)/${label}" || true
    ok "booted out ${label}"
  fi
  if [[ -f "$plist" ]]; then
    rm "$plist"
    ok "removed ${plist}"
  else
    info "no backlog-agents-sync plist at ${plist}; nothing to remove."
  fi
}

# ---- subcommand: install-monitor / uninstall-monitor ----

do_install_monitor() {
  local label="com.${USER}.backlog-agents-monitor"
  local plist="$HOME/Library/LaunchAgents/${label}.plist"
  local bin_path
  bin_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

  mkdir -p "$HOME/Library/LaunchAgents"

  if [[ -f "$plist" ]]; then
    info "replacing existing backlog-agents-monitor plist"
    launchctl bootout "gui/$(id -u)/${label}" 2>/dev/null || true
    local i=0
    while launchctl print "gui/$(id -u)/${label}" >/dev/null 2>&1 && (( i < 10 )); do
      sleep 1; i=$((i + 1))
    done
  fi

  local label_x bin_path_x home_x bin_dir_x
  label_x="$(xml_escape "$label")"
  bin_path_x="$(xml_escape "$bin_path")"
  local bin_dir; bin_dir="$(dirname "$bin_path")"
  bin_dir_x="$(xml_escape "$bin_dir")"
  home_x="$(xml_escape "$HOME")"

  cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${label_x}</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${bin_path_x}</string>
        <string>monitor</string>
        <string>--fix</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${bin_dir_x}:${home_x}/dotfiles/bin:${home_x}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>${home_x}</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>60</integer>

    <key>StandardOutPath</key>
    <string>${home_x}/Library/Logs/backlog-agents-monitor.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>${home_x}/Library/Logs/backlog-agents-monitor.stderr.log</string>
</dict>
</plist>
EOF

  mkdir -p "$HOME/Library/Logs"
  if ! launchctl bootstrap "gui/$(id -u)" "$plist"; then
    echo "backlog-agents: bootstrap failed for ${label}. plist is at $plist." >&2
    exit 1
  fi
  ok "backlog-agents-monitor installed: ${label}"
  info "  plist: ${plist}"
  info "  logs:  ~/Library/Logs/backlog-agents-monitor.{stdout,stderr}.log"
  info "  status: launchctl print gui/\$(id -u)/${label}"
}

do_uninstall_monitor() {
  local label="com.${USER}.backlog-agents-monitor"
  local plist="$HOME/Library/LaunchAgents/${label}.plist"

  if launchctl print "gui/$(id -u)/${label}" >/dev/null 2>&1; then
    launchctl bootout "gui/$(id -u)/${label}" || true
    ok "booted out ${label}"
  fi
  if [[ -f "$plist" ]]; then
    rm "$plist"
    ok "removed ${plist}"
  else
    info "no backlog-agents-monitor plist at ${plist}; nothing to remove."
  fi
}

# ---- subcommand: migrate-daemons ----

# Migrate old-style plists (com.${USER}.*.backlog.plist and
# com.${USER}.*.backlog-loop.plist) to the canonical
# com.${USER}.*.backlog-agent.plist format.  Runs `backlog-agent
# install-daemon` inside each affected project directory, which boots
# out old daemons, removes old plists, and creates the new plist.
# Safe to run on machines that are already migrated ŌĆö it's a no-op
# when only .backlog-agent plists exist.
do_migrate_daemons() {
  local migrated=0 skipped=0
  local plist label name repo
  for plist in "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog.plist \
               "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-loop.plist; do
    [[ -f "$plist" ]] || continue
    label="$(basename "$plist" .plist)"
    name="${label#com.${USER}.}"
    name="${name%.backlog}"
    name="${name%.backlog-loop}"
    repo="$ACTIVE_ROOT/$name"
    if [[ ! -d "$repo" ]]; then
      warn "$label: project $name not found under $ACTIVE_ROOT; skipping"
      skipped=$((skipped + 1))
      continue
    fi
    info "migrating $label ŌåÆ .backlog-agent.plist"
    if ( cd "$repo" && "$HOME/dev/projects/active/backlog-infra/bin/backlog-agent" install-daemon 2>&1 ); then
      ok "$name migrated"
      migrated=$((migrated + 1))
    else
      warn "$name migration failed"
      skipped=$((skipped + 1))
    fi
  done
  if (( migrated == 0 && skipped == 0 )); then
    info "no old-style plists found ŌĆö already migrated"
  else
    ok "$migrated daemon(s) migrated, $skipped skipped"
  fi
}

# ---- subcommand: monitor ----

do_monitor() {
  local fix=0 interval=120 once=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fix)     fix=1; shift ;;
      --interval) interval="$2"; shift 2 ;;
      --once)    once=1; shift ;;
      -h|--help)
        echo "Usage: backlog-agents monitor [--fix] [--interval <seconds>] [--once]"
        echo "  Scan agent logs for failure patterns and auto-fix where safe."
        echo "  --fix       Actually apply fixes (default: dry-run / report only)"
        echo "  --interval  Seconds between scans (default: 60)"
        echo "  --once      Run a single scan and exit"
        return 0 2>/dev/null || exit 0
        ;;
      *) echo "backlog-agents monitor: unknown flag: $1" >&2; exit 2 ;;
    esac
  done

  local this_host; this_host="$(hostname)"
  this_host="${this_host%.local}"
  local status_file="$ACTIVE_ROOT/backlog-infra/.claude/monitor-status-${this_host}.json"
  local sweeps_total=0 fixed_total=0 flagged_total=0
  local log_tail_lines=150
  local _last_status_commit=0
  local _status_heartbeat=300
  local _self_root; _self_root="$(cd "$ACTIVE_ROOT/backlog-infra" 2>/dev/null && pwd -P || echo '')"
  local _notify_config="$HOME/.config/backlog/notify.json"
  local _last_notify=0

  _notify() {
    local title="${1:-backlog-monitor}" body="${2:-}"
    [[ -n "$body" ]] || return 0
    local now_epoch; now_epoch="$(date +%s)"
    if (( now_epoch - _last_notify < 300 )); then return 0; fi
    _last_notify="$now_epoch"
    local slack_webhook local_notify
    slack_webhook="$(jq -r '.slack_webhook // ""' "$_notify_config" 2>/dev/null || echo '')"
    local_notify="$(jq -r '.local_notify // false' "$_notify_config" 2>/dev/null || echo 'false')"
    if [[ "$local_notify" == "true" ]] && command -v osascript >/dev/null 2>&1; then
      osascript -e "display notification \"${body}\" with title \"${title}\"" 2>/dev/null || true
    fi
    if [[ -n "$slack_webhook" ]] && command -v curl >/dev/null 2>&1; then
      local payload
      payload="$(jq -nc --arg t "$title" --arg b "$body" --arg h "$this_host"         '{"text": "\($t) (\($h)): \($b)"}')"
      curl -s -X POST -H 'Content-type: application/json' --data "$payload" "$slack_webhook" >/dev/null 2>&1 || true
    fi
  }

  _is_self() {
    local p; p="$(cd "${1:-}" 2>/dev/null && pwd -P)" || return 1
    [[ "$p" == "$_self_root" ]]
  }

  _write_status() {
    local had_action="${1:-0}"
    local now_iso; now_iso="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    local now_epoch; now_epoch="$(date +%s)"
    local actions_json="["
    local first=1
    if (( ${#recent_actions[@]:-0} > 0 )); then
      for entry in "${recent_actions[@]}"; do
        [[ $first -eq 1 ]] && first=0 || actions_json+=","
        actions_json+="$entry"
      done
    fi
    actions_json+="]"
    cat > "$status_file" <<JSON
{
  "last_sweep_at": "${now_iso}",
  "running": true,
  "fix_mode": ${fix},
  "host": "${this_host}",
  "sweeps_total": ${sweeps_total},
  "fixed_total": ${fixed_total},
  "flagged_total": ${flagged_total},
  "recent_actions": ${actions_json}
}
JSON
    local should_commit=0
    if (( had_action )); then
      should_commit=1
    elif (( now_epoch - _last_status_commit >= _status_heartbeat )); then
      should_commit=1
    fi
    if (( should_commit )); then
      git -C "$ACTIVE_ROOT/backlog-infra" add "$status_file" 2>/dev/null || true
      git -C "$ACTIVE_ROOT/backlog-infra" pull --rebase origin main >/dev/null 2>&1 || true
      git -C "$ACTIVE_ROOT/backlog-infra" commit -m "monitor: sweep ${sweeps_total} (${fixed_total} fixed, ${flagged_total} flagged)" >/dev/null 2>&1 || true
      git -C "$ACTIVE_ROOT/backlog-infra" push origin main 2>/dev/null || true
      _last_status_commit="$now_epoch"
    else
      git -C "$ACTIVE_ROOT/backlog-infra" checkout -- "$status_file" 2>/dev/null || true
    fi
  }

  local -a recent_actions=()

  _monitor_run() {
    local ts; ts="$(date '+%Y-%m-%d %H:%M:%S')"
    local -a fix_descriptions=()
    local sweep_fixed=0 sweep_flagged=0

    local -a candidates=()
    local root proj_dir
    for root in "${PROJECTS_ROOTS[@]}"; do
      [[ -d "$root" ]] || continue
      for proj_dir in "$root"/*/; do
        [[ -d "$proj_dir" ]] || continue
        candidates+=("${proj_dir%/}")
      done
    done

    local seen='|'
    local -a unique=()
    for proj_dir in "${candidates[@]}"; do
      local real
      real="$(cd "$proj_dir" 2>/dev/null && pwd -P)" || continue
      case "$seen" in *"|$real|"*) continue ;; esac
      seen="${seen}${real}|"
      unique+=("$real")
    done

    for proj_dir in "${unique[@]}"; do
      local log_file="$proj_dir/.claude/backlog-agent.log"
      local cd_file="$proj_dir/.claude/agent-cooldown.json"
      local inflight="$proj_dir/.claude/backlog-agent-tick.inflight"
      local lock_dir="$proj_dir/.claude/backlog-agent.lock"
      local name; name="$(basename "$proj_dir")"
      [[ -f "$log_file" ]] || continue

      local recent; recent="$(tail -n "$log_tail_lines" "$log_file" 2>/dev/null || true)"
      [[ -n "$recent" ]] || continue

      local safe_to_fix=1
      [[ -f "$inflight" ]] && safe_to_fix=0
      [[ -d "$lock_dir" ]] && safe_to_fix=0

      # Pattern 1: git dirty tree
      if echo "$recent" | grep -qiE 'cannot pull with rebase: You have unstaged changes|error: Your local changes.*would be overwritten|cannot rebase: You have unstaged changes'; then
        local tree_actually_dirty=0
        [[ -n $(git -C "$proj_dir" status --porcelain 2>/dev/null) ]] && tree_actually_dirty=1
        if (( tree_actually_dirty )); then
          if (( safe_to_fix && fix )); then
            git -C "$proj_dir" rebase --abort 2>/dev/null || true
            if _is_self "$proj_dir"; then
              local stash_hash=""
              git -C "$proj_dir" stash push -m "monitor-auto-stash $(date -u '+%Y-%m-%dT%H:%M:%SZ')" 2>/dev/null || true
              stash_hash="$(git -C "$proj_dir" stash list --format='%gd' 2>/dev/null | head -1 || true)"
              git -C "$proj_dir" fetch origin 2>/dev/null || true
              git -C "$proj_dir" reset --hard origin/main 2>/dev/null || true
              git -C "$proj_dir" clean -fd 2>/dev/null || true
              fix_descriptions+=("  ${GN}FIXED${RS} ${name}: git dirty tree ŌĆö stash (${stash_hash:-?}) + reset (self-protect)")
              sweep_fixed=$((sweep_fixed + 1))
              recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_dirty\",\"result\":\"stashed\",\"stash\":\"${stash_hash:-?}\"}")
            else
              git -C "$proj_dir" reset --hard "origin/$(git -C "$proj_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo main)" 2>/dev/null || \
                git -C "$proj_dir" reset --hard origin/main 2>/dev/null || true
              git -C "$proj_dir" clean -fd 2>/dev/null || true
              fix_descriptions+=("  ${GN}FIXED${RS} ${name}: git dirty tree ŌĆö reset --hard + clean")
              sweep_fixed=$((sweep_fixed + 1))
              recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_dirty\",\"result\":\"fixed\"}")
            fi
          else
            fix_descriptions+=("  ${YL}FLAG${RS}  ${name}: git dirty tree ($([[ $safe_to_fix -eq 0 ]] && echo 'BLOCKED' || echo 'detected'))")
            sweep_flagged=$((sweep_flagged + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_dirty\",\"result\":\"$([[ $safe_to_fix -eq 0 ]] && echo 'blocked_inflight' || echo 'flagged')\"}")
          fi
        fi
      fi

      # Pattern 2: git fast-forward failure
      if echo "$recent" | grep -qiE 'fatal: Cannot fast-forward'; then
        if (( safe_to_fix && fix )); then
          git -C "$proj_dir" fetch origin 2>/dev/null || true
          if _is_self "$proj_dir"; then
            local stash_hash=""
            git -C "$proj_dir" stash push -m "monitor-auto-stash $(date -u '+%Y-%m-%dT%H:%M:%SZ')" 2>/dev/null || true
            stash_hash="$(git -C "$proj_dir" stash list --format='%gd' 2>/dev/null | head -1 || true)"
            git -C "$proj_dir" reset --hard origin/main 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: git fast-forward conflict ŌĆö stash (${stash_hash:-?}) + reset (self-protect)")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_ff_conflict\",\"result\":\"stashed\",\"stash\":\"${stash_hash:-?}\"}")
          else
            git -C "$proj_dir" reset --hard "origin/$(git -C "$proj_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo main)" 2>/dev/null || \
              git -C "$proj_dir" reset --hard origin/main 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: git fast-forward conflict ŌĆö fetch + reset")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_ff_conflict\",\"result\":\"fixed\"}")
          fi
        fi
      fi

      # Pattern 3: git push failure
      if echo "$recent" | grep -qiE 'failed to push some refs'; then
        if (( safe_to_fix && fix )); then
          git -C "$proj_dir" fetch origin 2>/dev/null || true
          if _is_self "$proj_dir"; then
            local stash_hash=""
            git -C "$proj_dir" stash push -m "monitor-auto-stash $(date -u '+%Y-%m-%dT%H:%M:%SZ')" 2>/dev/null || true
            stash_hash="$(git -C "$proj_dir" stash list --format='%gd' 2>/dev/null | head -1 || true)"
            git -C "$proj_dir" reset --hard origin/main 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: git push rejected ŌĆö stash (${stash_hash:-?}) + reset (self-protect)")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_push_rejected\",\"result\":\"stashed\",\"stash\":\"${stash_hash:-?}\"}")
          else
            git -C "$proj_dir" reset --hard "origin/$(git -C "$proj_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo main)" 2>/dev/null || \
              git -C "$proj_dir" reset --hard origin/main 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: git push rejected ŌĆö fetch + reset")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_push_rejected\",\"result\":\"fixed\"}")
          fi
        fi
      fi

      # Pattern 4: stale lock
      if [[ -d "$lock_dir" ]]; then
        local lock_age
        lock_age="$(( $(date +%s) - $(stat -f %m "$lock_dir" 2>/dev/null || stat -c %Y "$lock_dir" 2>/dev/null || echo 0) ))"
        if (( lock_age > 1800 )); then
          if (( fix )); then
            rm -rf "$lock_dir" 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: stale lock (${lock_age}s old) ŌĆö removed")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"stale_lock\",\"result\":\"fixed\"}")
          fi
        fi
      fi

      # Pattern 5: cooldown issues
      if [[ -f "$cd_file" ]]; then
        local cd_parsed cd_until_epoch cd_duration
        cd_parsed="$(jq -r 'if .parsed_from_reset == false then "false" else "true" end' "$cd_file" 2>/dev/null)"
        cd_until_epoch="$(jq -r '.until_epoch // 0' "$cd_file" 2>/dev/null)"
        cd_duration=$(( cd_until_epoch - $(date +%s) ))

        if [[ "$cd_parsed" == "false" ]] && (( cd_duration <= 0 )); then
          if (( fix )); then
            rm -f "$cd_file" 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: stale fallback cooldown ŌĆö cleared")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"stale_cooldown\",\"result\":\"fixed\"}")
          fi
        elif [[ "$cd_parsed" == "false" ]]; then
          fix_descriptions+=("  ${YL}FLAG${RS}  ${name}: cooldown fallback ŌĆö couldn't parse reset time")
          sweep_flagged=$((sweep_flagged + 1))
          _notify "backlog-monitor ŌĆö cooldown issue" "${name}: couldn't parse reset time from Anthropic plan-limit message"
          _notify "backlog-monitor ŌĆö cooldown issue" "${name}: couldn't parse reset time from Anthropic plan-limit message"
        elif (( cd_duration <= 0 )); then
          if (( fix )); then
            rm -f "$cd_file" 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: expired cooldown ŌĆö cleared")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"expired_cooldown\",\"result\":\"fixed\"}")
          fi
        fi
      fi

      # Pattern 6: _run_status_hook bug
      if echo "$recent" | grep -q '_run_status_hook: command not found'; then
        fix_descriptions+=("  ${YL}FLAG${RS}  ${name}: _run_status_hook not defined (known code bug)")
        sweep_flagged=$((sweep_flagged + 1))
        _notify "backlog-monitor ŌĆö code bug" "${name}: _run_status_hook not defined"
      fi

      # Pattern 7: repeated tick failures without cooldown
      local fail_count
      fail_count="$(echo "$recent" | grep -c 'tick failed' || true)"
      local cooldown_fail
      cooldown_fail="$(echo "$recent" | grep -c 'plan-limit cooldown active' || true)"
      if (( fail_count >= 3 && cooldown_fail == 0 )) && ! [[ -f "$cd_file" ]]; then
        fix_descriptions+=("  ${RD}ALERT${RS} ${name}: ${fail_count} tick failures, no cooldown ŌĆö agent may be stuck")
        sweep_flagged=$((sweep_flagged + 1))
        _notify "backlog-monitor ŌĆö stuck agent" "${name}: ${fail_count} tick failures, no cooldown"
      fi
    done

    sweeps_total=$((sweeps_total + 1))
    fixed_total=$((fixed_total + sweep_fixed))
    flagged_total=$((flagged_total + sweep_flagged))

    # Trim recent_actions to last 20
    while (( ${#recent_actions[@]:-0} > 20 )); do
      recent_actions=("${recent_actions[@]:1}")
    done

    # Print sweep report
    if (( sweep_fixed > 0 || sweep_flagged > 0 )); then
      echo
      printf '  %sŌöüŌöü monitor sweep %sŌöüŌöü%s\n' "$DIM" "$ts" "$RS"
      for desc in "${fix_descriptions[@]}"; do
        printf '%s\n' "$desc"
      done
      local summary=""
      (( sweep_fixed > 0 )) && summary="${summary}${GN}${sweep_fixed} fixed${RS}"
      (( sweep_fixed > 0 && sweep_flagged > 0 )) && summary="${summary}, "
      (( sweep_flagged > 0 )) && summary="${summary}${YL}${sweep_flagged} flagged${RS}"
      echo "  ${DIM}ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ${RS}"
      echo "  ${summary}"
    else
      echo "  ${DIM}ŌöüŌöü sweep ${sweeps_total} OK (no issues)ŌöüŌöü${RS}"
    fi

    _write_status $(( sweep_fixed > 0 || sweep_flagged > 0 ? 1 : 0 ))
  }

  if (( once )); then
    _monitor_run
  else
    _on_monitor_exit() {
      local exit_code=$?
      local now_iso; now_iso="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
      local state; state="$([[ $exit_code -eq 0 ]] && echo 'stopped' || echo 'crashed')"
      cat > "$status_file" <<JSON
{
  "last_sweep_at": "${now_iso}",
  "running": false,
  "exit_code": ${exit_code},
  "exit_state": "${state}",
  "fix_mode": ${fix},
  "host": "${this_host}",
  "sweeps_total": ${sweeps_total},
  "fixed_total": ${fixed_total},
  "flagged_total": ${flagged_total},
  "recent_actions": []
}
JSON
      git -C "$ACTIVE_ROOT/backlog-infra" add "$status_file" 2>/dev/null || true
      git -C "$ACTIVE_ROOT/backlog-infra" pull --rebase origin main >/dev/null 2>&1 || true
      git -C "$ACTIVE_ROOT/backlog-infra" commit -m "monitor: ${state} (sweep ${sweeps_total}, ${fixed_total} fixed, ${flagged_total} flagged)" >/dev/null 2>&1 || true
      git -C "$ACTIVE_ROOT/backlog-infra" push origin main 2>/dev/null || true
      exit "$exit_code"
    }
    trap '_on_monitor_exit' INT TERM EXIT
    info "monitoring fleet (interval=${interval}s, fix=${fix})..."
    while true; do
      _monitor_run
      sleep "$interval"
    done
  fi
}

# ---- subcommand: doctor ----
# Preflight health check. Codifies the by-hand checks we run when the fleet
# misbehaves so "why is the fleet weird" becomes a 2-second read. Strictly
# read-only ŌĆö it reports drift and never mutates state. Exit status: 0 if clean
# (warnings allowed), 1 if any hard check FAILs.
do_doctor() {
  local fails=0 warns=0
  local P="${GN}Ō£ō${RS}" F="${RD}Ō£Ś${RS}" W="${YL}!${RS}"
  _d_pass() { printf '    %s %s\n' "$P" "$1"; }
  _d_warn() { printf '    %s %s\n' "$W" "$1"; warns=$((warns + 1)); }
  _d_fail() { printf '    %s %s\n' "$F" "$1"; fails=$((fails + 1)); }
  _d_head() { printf '\n  %s%s%s\n' "$B" "$1" "$RS"; }

  local manifest="$DOTFILES/active-projects.txt"
  local uid; uid="$(id -u)"
  local this_host; this_host="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo '?')"
  printf '%sbacklog-agents doctor%s  (%s)\n' "$B" "$RS" "$this_host"

  # Parse the manifest into a `|`-delimited set of project names (field 1 is a
  # path under ACTIVE_ROOT; we key on its basename). bash 3.2 compatible.
  local manifest_set='|' manifest_count=0
  if [[ -f "$manifest" ]]; then
    local mline rel mname
    while IFS= read -r mline || [[ -n "$mline" ]]; do
      [[ -z "$mline" || "$mline" == \#* ]] && continue
      rel="${mline%%$'\t'*}"; rel="${rel%% *}"
      [[ -z "$rel" ]] && continue
      mname="$(basename "$rel")"
      manifest_set="${manifest_set}${mname}|"
      manifest_count=$((manifest_count + 1))
    done < "$manifest"
  fi

  # --- 1. manifest <-> project dirs ---
  _d_head "Manifest Ōåö project dirs"
  if [[ ! -f "$manifest" ]]; then
    _d_fail "no manifest at $manifest (run \`dev-projects sync\`)"
  else
    _d_pass "manifest present ($manifest_count project(s))"
    local nm
    local IFS='|'
    for nm in $manifest_set; do
      [[ -z "$nm" ]] && continue
      if [[ ! -d "$ACTIVE_ROOT/$nm" ]]; then
        _d_fail "manifest lists '$nm' but $ACTIVE_ROOT/$nm does not exist"
      elif [[ ! -d "$ACTIVE_ROOT/$nm/.git" ]]; then
        _d_warn "'$nm' exists but is not a git repo"
      fi
    done
    unset IFS
    # Reverse drift: a project with a backlog that the manifest omits.
    local pd pn
    for pd in "$ACTIVE_ROOT"/*/; do
      [[ -d "$pd" ]] || continue
      pn="$(basename "$pd")"
      [[ -n "$(find_backlog_file "${pd%/}")" ]] || continue
      case "$manifest_set" in
        *"|$pn|"*) : ;;
        *) _d_warn "'$pn' has a backlog but is missing from the manifest" ;;
      esac
    done
  fi

  # --- 2. daemons: count, double-daemons, dangling plists ---
  _d_head "launchd daemons"
  local pl label dn loaded_canonical=0
  # Track which projects have a loaded daemon, and which carry a legacy label.
  local loaded_set='|' legacy_loaded_set='|'
  for pl in "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-agent.plist \
            "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog.plist \
            "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-loop.plist; do
    [[ -f "$pl" ]] || continue
    label="$(basename "$pl" .plist)"
    dn="${label#com.${USER}.}"
    dn="${dn%.backlog-agent}"; dn="${dn%.backlog}"; dn="${dn%.backlog-loop}"
    local is_loaded=0
    launchctl print "gui/$uid/$label" >/dev/null 2>&1 && is_loaded=1
    # Dangling: plist points at a project dir that no longer exists.
    if [[ ! -d "$ACTIVE_ROOT/$dn" ]]; then
      _d_fail "$label points at $ACTIVE_ROOT/$dn which does not exist"
    fi
    if [[ "$pl" == *backlog-agent.plist ]]; then
      (( is_loaded )) && { loaded_canonical=$((loaded_canonical + 1)); loaded_set="${loaded_set}${dn}|"; }
    else
      (( is_loaded )) && legacy_loaded_set="${legacy_loaded_set}${dn}|"
    fi
  done
  # Double-daemons: a project running BOTH a canonical and a legacy-label daemon.
  local dd_found=0 ln
  local IFS='|'
  for ln in $legacy_loaded_set; do
    [[ -z "$ln" ]] && continue
    case "$loaded_set" in
      *"|$ln|"*) _d_fail "double-daemon: '$ln' runs both a canonical AND a legacy-label daemon"; dd_found=1 ;;
      *) _d_warn "'$ln' runs only a legacy-label daemon (migrate via \`backlog-agent install-daemon\`)" ;;
    esac
  done
  unset IFS
  (( dd_found == 0 )) && _d_pass "no double-daemons"
  _d_pass "$loaded_canonical canonical daemon(s) loaded"
  # Manifest projects with no loaded daemon.
  local mn
  local IFS='|'
  for mn in $manifest_set; do
    [[ -z "$mn" ]] && continue
    case "$loaded_set" in
      *"|$mn|"*) : ;;
      *) _d_warn "manifest project '$mn' has no loaded canonical daemon" ;;
    esac
  done
  unset IFS

  # --- 3. plists point at canonical (de-symlinked) paths ---
  _d_head "Plist paths canonical"
  local canon_bin=""
  if [[ -f "$ACTIVE_ROOT/backlog-infra/bin/backlog-agent" ]]; then
    canon_bin="$(cd "$ACTIVE_ROOT/backlog-infra/bin" 2>/dev/null && pwd -P)/backlog-agent"
  fi
  local checked=0
  for pl in "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-agent.plist; do
    [[ -f "$pl" ]] || continue
    label="$(basename "$pl" .plist)"
    local prog wdir
    prog="$(/usr/libexec/PlistBuddy -c 'Print :ProgramArguments:1' "$pl" 2>/dev/null || true)"
    wdir="$(/usr/libexec/PlistBuddy -c 'Print :WorkingDirectory' "$pl" 2>/dev/null || true)"
    checked=$((checked + 1))
    if [[ -n "$prog" && -n "$canon_bin" && "$prog" != "$canon_bin" ]]; then
      _d_warn "$label: driver path '$prog' != canonical '$canon_bin'"
    fi
    if [[ -n "$wdir" ]]; then
      local wdir_real; wdir_real="$(cd "$wdir" 2>/dev/null && pwd -P || true)"
      if [[ -z "$wdir_real" ]]; then
        _d_fail "$label: WorkingDirectory '$wdir' does not resolve"
      elif [[ "$wdir_real" != "$wdir" ]]; then
        _d_warn "$label: WorkingDirectory '$wdir' is a symlink ŌåÆ '$wdir_real' (re-install to canonicalize)"
      fi
    fi
  done
  (( checked > 0 )) && _d_pass "checked $checked canonical plist(s)" || _d_warn "no canonical plists found"

  # --- 4. per-project config hygiene (gitignore + status hook) ---
  # Assert every active repo handles the FULL canonical ephemeral .claude/ set
  # (ephemeral_claude_files in _lib.sh), not a hand-picked subset. Per the
  # orphan-stash bug class: a TRACKED ephemeral file is a hard fail (the daemon
  # rewrites/deletes it each tick ŌåÆ autostash pop conflicts ŌåÆ orphan), while an
  # untracked-but-unignored one is a warn (a latent autostash co-trigger).
  _d_head "Per-project config"
  local req_ignores=()
  while IFS= read -r _eph; do [[ -n "$_eph" ]] && req_ignores+=("$_eph"); done < <(ephemeral_claude_files)
  local proj pn gi hook miss
  for proj in "$ACTIVE_ROOT"/*/; do
    proj="${proj%/}"
    [[ -d "$proj" ]] || continue
    [[ -n "$(find_backlog_file "$proj")" ]] || continue
    pn="$(basename "$proj")"
    # gitignore coverage: a missing pattern means the file is unignored, so if it
    # ever appears it is the untracked-unignored autostash co-trigger ŌåÆ warn.
    gi="$proj/.gitignore"
    miss=""
    if [[ -f "$gi" ]]; then
      local pat
      for pat in "${req_ignores[@]}"; do
        grep -qF "$pat" "$gi" 2>/dev/null || miss="${miss}${pat} "
      done
    else
      miss="(no .gitignore) "
    fi
    [[ -n "$miss" ]] && _d_warn "$pn: .gitignore missing ephemeral pattern(s): $miss"
    # tracked ephemeral file ŌåÆ hard fail (must be untracked AND ignored). Guarded
    # on a real work tree so fake-repo test fixtures (bare .git dirs) are skipped.
    if git -C "$proj" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      local tracked tf
      tracked="$(git -C "$proj" ls-files -- "${req_ignores[@]}" 2>/dev/null)"
      if [[ -n "$tracked" ]]; then
        while IFS= read -r tf; do
          [[ -z "$tf" ]] && continue
          _d_fail "$pn: ephemeral file is TRACKED in git (untrack + gitignore it): $tf"
        done <<< "$tracked"
      fi
    fi
    # status hook resolves (mirror the driver's resolution order)
    if   [[ -f "$proj/scripts/backlog-agent-status.mjs" ]]; then hook="$proj/scripts/backlog-agent-status.mjs"
    elif [[ -f "$proj/scripts/loop-status.mjs" ]];           then hook="$proj/scripts/loop-status.mjs"
    elif [[ -f "$ACTIVE_ROOT/backlog-infra/bin/backlog-agent-status.mjs" ]]; then hook="$ACTIVE_ROOT/backlog-infra/bin/backlog-agent-status.mjs"
    else hook=""; fi
    if [[ -z "$hook" ]]; then
      _d_fail "$pn: no status hook resolves (and shared fallback missing)"
    elif command -v node >/dev/null 2>&1 && ! node --check "$hook" >/dev/null 2>&1; then
      _d_fail "$pn: status hook has a syntax error ($hook)"
    fi
  done
  (( fails == 0 )) && _d_pass "status hooks resolve; gitignore checked"

  # --- 5. budgets file + required tools ---
  _d_head "Globals & tools"
  local budgets="$HOME/.claude/backlog-budgets.json"
  if [[ ! -e "$budgets" ]]; then
    _d_warn "no budgets file at $budgets (dashboard budget bars disabled)"
  elif ! jq -e . "$budgets" >/dev/null 2>&1; then
    _d_fail "budgets file is not valid JSON ($budgets)"
  else
    _d_pass "budgets file present and valid"
  fi
  local tool
  for tool in git node jq; do
    command -v "$tool" >/dev/null 2>&1 && _d_pass "$tool present" || _d_fail "$tool MISSING (required)"
  done
  for tool in gawk fswatch; do
    command -v "$tool" >/dev/null 2>&1 && _d_pass "$tool present" \
      || _d_warn "$tool not found (gawk avoids the BSD-awk inplace footgun; fswatch enables event-driven ticks)"
  done

  # --- summary ---
  printf '\n  %sŌĆö%s %d fail, %d warn\n' "$DIM" "$RS" "$fails" "$warns"
  if (( fails > 0 )); then
    printf '  %sŌ£Ś doctor: %d hard failure(s)%s\n' "$RD" "$fails" "$RS"
    return 1
  fi
  printf '  %sŌ£ō doctor: no hard failures%s\n' "$GN" "$RS"
  return 0
}

# ---- subcommand: canary ----
# Blast-radius control for the SHARED driver: validate a driver version before
# it goes fleet-wide. Because bin/ is shared, one bad driver commit breaks every
# project at once (the 2026-05-28 cooldown-add bug did exactly this). The canary
# asserts health against the *current* driver and records a pass keyed to its bin
# SHA; the reaper-restart / fleet-freeze consult `canary --check` so a daemon
# never comes back up on a driver that hasn't passed. Token-free + deterministic:
# the self-test suite already contains the regression test for that bug class.
#
#   backlog-agents canary           run the checks; record a pass for the current SHA
#   backlog-agents canary --check   read-only gate: exit 0 iff the running driver passed
#   --json                          machine-readable result
#
# Overrides (testing): CANARY_STATE_FILE, CANARY_SELFTEST_CMD, CANARY_DOCTOR=0.
do_canary() {
  local check_only=0 json=0 a
  for a in "$@"; do
    case "$a" in
      --check) check_only=1 ;;
      --json)  json=1 ;;
      *) echo "backlog-agents canary: unknown flag: $a" >&2; exit 2 ;;
    esac
  done

  local infra_dir="$ACTIVE_ROOT/backlog-infra"
  local state_file="${CANARY_STATE_FILE:-$HOME/.claude/backlog-canary.json}"
  local cur_sha=""
  [[ -d "$infra_dir/.git" ]] && cur_sha="$(git -C "$infra_dir" log -1 --format=%h -- bin 2>/dev/null || true)"

  if (( check_only )); then
    local passed_sha=""
    [[ -f "$state_file" ]] && passed_sha="$(jq -r '.passed_sha // empty' "$state_file" 2>/dev/null || true)"
    if [[ -n "$cur_sha" && "$passed_sha" == "$cur_sha" ]]; then
      (( json )) && printf '{"ok":true,"sha":"%s"}\n' "$cur_sha" || ok "canary current: driver ${cur_sha} has passed"
      return 0
    fi
    (( json )) && printf '{"ok":false,"sha":"%s","passed_sha":"%s"}\n' "$cur_sha" "$passed_sha" \
      || warn "canary STALE: running driver=${cur_sha:-?}, last passed=${passed_sha:-none} ŌĆö run \`backlog-agents canary\` before letting the fleet pull"
    return 1
  fi

  # Run mode: assert health, then record a pass for the current SHA.
  info "canary: validating driver ${cur_sha:-?}"
  local selftest_rc=0 doctor_rc=0
  local selftest_cmd="${CANARY_SELFTEST_CMD:-bash $infra_dir/test/run.sh}"
  info "  self-test: $selftest_cmd"
  if $selftest_cmd >/dev/null 2>&1; then ok "  self-test passed"; else selftest_rc=1; warn "  self-test FAILED"; fi
  if [[ "${CANARY_DOCTOR:-1}" == "1" ]]; then
    if do_doctor >/dev/null 2>&1; then ok "  doctor passed"; else doctor_rc=1; warn "  doctor reported a HARD failure"; fi
  fi
  if (( selftest_rc || doctor_rc )); then
    warn "canary FAILED for driver ${cur_sha:-?} ŌĆö not recording a pass (do NOT roll this driver fleet-wide)"
    return 1
  fi
  mkdir -p "$(dirname "$state_file")"
  jq -n --arg sha "$cur_sha" --arg at "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
     '{passed_sha:$sha, passed_at:$at, checks:{selftest:"pass", doctor:"pass"}}' > "$state_file"
  ok "canary PASSED ŌĆö recorded driver ${cur_sha} (${state_file})"
  return 0
}

# ---- subcommand: metrics ----
# Efficiency metrics from each project's per-tick ledger
# (.claude/backlog-history.jsonl, polyglot fallback effort-log.jsonl). Reads
# every project under PROJECTS_ROOTS the same way snapshot() does (dedupe by
# realpath) and prints a per-project table plus a fleet summary of:
#   - total ticks            count of history records
#   - completed items        ticks APPROXIMATED as completions (see note)
#   - tokens/completion      sum(tokens) / completed  (efficiency)
#   - success rate           ticks with exit_code==0 / total ticks
#   - retry rate             total ticks / completed  (ticks burned per completion)
#
# NOTE: the history schema has no explicit "completed" flag yet, so a completion
# is APPROXIMATED as a tick with exit_code==0 AND a non-empty work_commit (a
# committed unit of work). This over/under-counts when a tick commits without
# finishing an item, or finishes without a commit. Footnoted in the output and
# revisable once the ledger grows a real completion field.
#
#   backlog-agents metrics          per-project table + fleet summary
#   --json                          machine-readable {projects:[...], fleet:{...}}
do_metrics() {
  local json=0 a
  for a in "$@"; do
    case "$a" in
      --json) json=1 ;;
      *) echo "backlog-agents metrics: unknown flag: $a" >&2; exit 2 ;;
    esac
  done

  # Discover projects exactly like snapshot(): walk roots, dedupe by realpath.
  local -a candidates=()
  local root proj_dir
  for root in "${PROJECTS_ROOTS[@]}"; do
    [[ -d "$root" ]] || continue
    for proj_dir in "$root"/*/; do
      [[ -d "$proj_dir" ]] || continue
      candidates+=("${proj_dir%/}")
    done
  done
  local seen='|'
  local -a unique=()
  for proj_dir in "${candidates[@]:-}"; do
    [[ -n "$proj_dir" ]] || continue
    local real
    real="$(cd "$proj_dir" 2>/dev/null && pwd -P)" || continue
    case "$seen" in *"|$real|"*) continue ;; esac
    seen="${seen}${real}|"
    unique+=("$real")
  done

  # Per-project parallel arrays (bash 3.2: no associative arrays).
  local -a m_name=() m_ticks=() m_done=() m_tokens=() m_ok=()
  # Fleet accumulators.
  local f_ticks=0 f_done=0 f_tokens=0 f_ok=0

  # Single jq pass per history file. A "completion" is exit_code==0 AND a
  # non-empty (non-null) work_commit ŌĆö the documented approximation. Emits four
  # whitespace-separated integers: ticks done tokens ok.
  local jq_prog='
    [ .[] ] as $rs
    | ($rs | length) as $ticks
    | ([$rs[] | select((.exit_code // 1) == 0)] | length) as $ok
    | ([$rs[] | select((.exit_code // 1) == 0
                       and ((.work_commit // "") | tostring) != ""
                       and ((.work_commit // "") | tostring) != "null")] | length) as $done
    | ([$rs[] | .tokens // 0] | add // 0) as $tokens
    | "\($ticks) \($done) \($tokens) \($ok)"
  '

  for proj_dir in "${unique[@]:-}"; do
    [[ -n "$proj_dir" ]] || continue
    local hist; hist="$(find_history_file "$proj_dir")"
    [[ -n "$hist" ]] || continue
    local out ticks done_ tokens ok
    out="$(jq -s -r "$jq_prog" "$hist" 2>/dev/null || echo "0 0 0 0")"
    read -r ticks done_ tokens ok <<< "$out"
    [[ "$ticks" =~ ^[0-9]+$ ]] || ticks=0
    [[ "$done_" =~ ^[0-9]+$ ]] || done_=0
    [[ "$tokens" =~ ^[0-9]+$ ]] || tokens=0
    [[ "$ok" =~ ^[0-9]+$ ]] || ok=0
    (( ticks == 0 )) && continue   # no recorded ticks: nothing to report
    m_name+=("$(basename "$proj_dir")")
    m_ticks+=("$ticks"); m_done+=("$done_"); m_tokens+=("$tokens"); m_ok+=("$ok")
    f_ticks=$(( f_ticks + ticks ))
    f_done=$(( f_done + done_ ))
    f_tokens=$(( f_tokens + tokens ))
    f_ok=$(( f_ok + ok ))
  done

  # Integer-only helpers (bash has no float). Rates are scaled to keep precision.
  # _pct: ok/total as a percentage (one decimal).  _per: a/b as N.N (one decimal).
  _pct() { # numerator denominator -> "NN.N%"
    local n="$1" d="$2"
    (( d == 0 )) && { printf '%s' "ŌĆö"; return; }
    printf '%d.%d%%' $(( n * 100 / d )) $(( (n * 1000 / d) % 10 ))
  }
  _per() { # numerator denominator -> "N.N"
    local n="$1" d="$2"
    (( d == 0 )) && { printf '%s' "ŌĆö"; return; }
    printf '%d.%d' $(( n / d )) $(( (n * 10 / d) % 10 ))
  }
  _tpc() { # tokens completed -> integer tokens/completion (or ŌĆö)
    local t="$1" c="$2"
    (( c == 0 )) && { printf '%s' "ŌĆö"; return; }
    printf '%d' $(( t / c ))
  }

  if (( json )); then
    # Build the projects array with jq from the parallel arrays.
    local proj_json="[]" i
    if (( ${#m_name[@]} )); then
    for i in "${!m_name[@]}"; do
      proj_json="$(jq -c \
        --arg name "${m_name[$i]}" \
        --argjson ticks "${m_ticks[$i]}" \
        --argjson completed "${m_done[$i]}" \
        --argjson tokens "${m_tokens[$i]}" \
        --argjson ok "${m_ok[$i]}" \
        '. + [{
           project: $name,
           ticks: $ticks,
           completed: $completed,
           tokens: $tokens,
           tokens_per_completion: (if $completed > 0 then ($tokens / $completed) else null end),
           success_rate: (if $ticks > 0 then ($ok / $ticks) else null end),
           retry_rate: (if $completed > 0 then ($ticks / $completed) else null end)
         }]' <<< "$proj_json")"
    done
    fi
    jq -n \
      --argjson projects "$proj_json" \
      --argjson ticks "$f_ticks" \
      --argjson completed "$f_done" \
      --argjson tokens "$f_tokens" \
      --argjson ok "$f_ok" \
      '{
         note: "completion APPROXIMATED as exit_code==0 AND non-empty work_commit (history has no explicit completed flag yet)",
         projects: $projects,
         fleet: {
           ticks: $ticks,
           completed: $completed,
           tokens: $tokens,
           tokens_per_completion: (if $completed > 0 then ($tokens / $completed) else null end),
           success_rate: (if $ticks > 0 then ($ok / $ticks) else null end),
           retry_rate: (if $completed > 0 then ($ticks / $completed) else null end)
         }
       }'
    return 0
  fi

  printf '%sMETRICS%s  %sper-tick ledger efficiency%s\n' "${B}${CY}" "${RS}" "$DIM" "$RS"
  if (( ${#m_name[@]} == 0 )); then
    printf '\n  %sNo project history (.claude/backlog-history.jsonl) under: %s%s\n' \
      "$DIM" "${PROJECTS_ROOTS[*]}" "$RS"
    return 0
  fi
  echo
  printf '  %s%-18s %-7s %-6s %-12s %-9s %-7s%s\n' \
    "$DIM" "PROJECT" "TICKS" "DONE" "TOK/DONE" "SUCCESS" "RETRY" "$RS"
  local i
  for i in "${!m_name[@]}"; do
    printf '  %-18s %-7s %-6s %-12s %-9s %-7s\n' \
      "${m_name[$i]}" "${m_ticks[$i]}" "${m_done[$i]}" \
      "$(_tpc "${m_tokens[$i]}" "${m_done[$i]}")" \
      "$(_pct "${m_ok[$i]}" "${m_ticks[$i]}")" \
      "$(_per "${m_ticks[$i]}" "${m_done[$i]}")"
  done
  printf '  %s%-18s %-7s %-6s %-12s %-9s %-7s%s\n' \
    "$B" "FLEET" "$f_ticks" "$f_done" \
    "$(_tpc "$f_tokens" "$f_done")" \
    "$(_pct "$f_ok" "$f_ticks")" \
    "$(_per "$f_ticks" "$f_done")" "$RS"
  echo
  printf '  %s* completion APPROXIMATED as exit_code==0 AND a non-empty work_commit\n' "$DIM"
  printf '    (history has no explicit completed flag yet); RETRY = ticks per completion.%s\n' "$RS"
  return 0
}

# ---- dispatch ----

# Flags only apply to the default (snapshot) command.
FETCH=0; WATCH=0; EFFORT=0; DAY=0; COMPACT=0; ARTIFACTS=0

cmd="${1:-}"
case "$cmd" in
  sync) shift; do_sync "$@" ;;
  list) shift; do_list "$@" ;;
  doctor) shift; do_doctor "$@" ;;
  canary) shift; do_canary "$@" ;;
  metrics) shift; do_metrics "$@" ;;
  daemon-sync) shift; do_daemon_sync "$@" ;;
  install-watchdog) do_install_watchdog ;;
  uninstall-watchdog) do_uninstall_watchdog ;;
  install-monitor) do_install_monitor ;;
  uninstall-monitor) do_uninstall_monitor ;;
  migrate-daemons) do_migrate_daemons ;;
  monitor) shift; do_monitor "$@" ;;
  -h|--help)
    sed -n '2,78p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
    ;;
  *)
    # Default: snapshot. Parse flags here so they're scoped to this path.
    for arg in "$@"; do
      case "$arg" in
        --fetch)  FETCH=1 ;;
        --watch)  WATCH=1 ;;
        --effort) EFFORT=1 ;;
        --day)    DAY=1 ;;
        --compact) COMPACT=1 ;;
        --artifacts) ARTIFACTS=1 ;;
        *) echo "backlog-agents: unknown flag: $arg" >&2; exit 2 ;;
      esac
    done
    if (( WATCH )); then
      trap 'exit 0' INT TERM
      while true; do
        clear
        snapshot
        sleep 10
      done
    else
      snapshot
    fi
    ;;
esac
