  if launchctl print "gui/$(id -u)/${label}" >/dev/null 2>&1; then
    launchctl bootout "gui/$(id -u)/${label}" || true
    ok "booted out ${label}"
  fi
  if [[ -f "$plist" ]]; then
    rm "$plist"
    ok "removed ${plist}"
  else
    info "no backlog-agents-monitor plist at ${plist}; nothing to remove."
  fi
}

# ---- subcommand: install-hooks (secret-scanning pre-push gate) ----
# Install/refresh the secret-scan pre-push hook in every active project's clone
# (docs/secret-scan.md). The per-clone .git/hooks/pre-push is NOT version-
# controlled, so it must be installed per (project × machine). The driver also
# self-heals it on every tick (ensure_prepush_hook); this is the explicit
# one-shot for a fresh machine (gate live before the first tick) + non-daemon
# repos. Idempotent + version-keyed: rewrites a missing/stale-version hook,
# LEAVES a foreign hook (one without our marker) untouched unless --force.
do_install_hooks() {
  local FORCE=0 arg
  for arg in "$@"; do
    case "$arg" in
      --force) FORCE=1 ;;
      *) echo "backlog-agents install-hooks: unknown flag: $arg" >&2; exit 2 ;;
    esac
  done
  local scanner; scanner="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/backlog-secret-scan"
  if [[ ! -x "$scanner" ]]; then
    err "scanner not found/executable at $scanner — cannot install hooks"
    exit 1
  fi
  local installed=0 current=0 foreign=0 skipped=0 proj pn gitdir hook
  for proj in "$ACTIVE_ROOT"/*/; do
    proj="${proj%/}"
    [[ -d "$proj/.git" ]] || { [[ -e "$proj/.git" ]] || continue; }
    pn="$(basename "$proj")"
    gitdir="$(git -C "$proj" rev-parse --git-dir 2>/dev/null || true)"
    [[ -n "$gitdir" ]] || { skipped=$((skipped+1)); continue; }
    case "$gitdir" in /*) : ;; *) gitdir="$proj/$gitdir" ;; esac
    hook="$gitdir/hooks/pre-push"
    # A NON-EMPTY hook without our marker is a real user hook — leave it unless
    # --force. Empty (0-byte) / missing ⇒ safe to (over)write.
    if prepush_hook_is_foreign "$hook"; then
      if (( FORCE )); then
        warn "$pn: replacing FOREIGN pre-push hook (--force)"
      else
        warn "$pn: foreign pre-push hook present — leaving untouched (use --force to replace)"
        foreign=$((foreign+1)); continue
      fi
    fi
    if prepush_hook_is_current "$hook" && (( FORCE == 0 )); then
      current=$((current+1)); continue
    fi
    mkdir -p "$gitdir/hooks" 2>/dev/null || { skipped=$((skipped+1)); continue; }
    if prepush_hook_body "$scanner" > "$hook" 2>/dev/null; then
      chmod +x "$hook" 2>/dev/null || true
      ok "$pn: pre-push gate installed (version ${PREPUSH_HOOK_VERSION})"
      installed=$((installed+1))
    else
      warn "$pn: failed to write $hook"; skipped=$((skipped+1))
    fi
  done
  ok "install-hooks: ${installed} installed/updated, ${current} already current, ${foreign} foreign-left, ${skipped} skipped"
}

# ---- subcommand: migrate-daemons ----

# Migrate old-style plists (com.${USER}.*.backlog.plist and
# com.${USER}.*.backlog-loop.plist) to the canonical
# com.${USER}.*.backlog-agent.plist format.  Runs `backlog-agent
# install-daemon` inside each affected project directory, which boots
# out old daemons, removes old plists, and creates the new plist.
# Safe to run on machines that are already migrated — it's a no-op
# when only .backlog-agent plists exist.
do_migrate_daemons() {
  local migrated=0 skipped=0
  local plist label name repo
  for plist in "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog.plist \
               "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-loop.plist; do
    [[ -f "$plist" ]] || continue
    label="$(basename "$plist" .plist)"
    name="${label#com.${USER}.}"
    name="${name%.backlog}"
    name="${name%.backlog-loop}"
    repo="$ACTIVE_ROOT/$name"
    if [[ ! -d "$repo" ]]; then
      warn "$label: project $name not found under $ACTIVE_ROOT; skipping"
      skipped=$((skipped + 1))
      continue
    fi
    info "migrating $label → .backlog-agent.plist"
    if ( cd "$repo" && "$HOME/dev/projects/active/backlog-infra/bin/backlog-agent" install-daemon 2>&1 ); then
      ok "$name migrated"
      migrated=$((migrated + 1))
    else
      warn "$name migration failed"
      skipped=$((skipped + 1))
    fi
  done
  if (( migrated == 0 && skipped == 0 )); then
    info "no old-style plists found — already migrated"
  else
    ok "$migrated daemon(s) migrated, $skipped skipped"
  fi
}

# ---- subcommand: monitor ----

do_monitor() {
  local fix=0 interval=120 once=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fix)     fix=1; shift ;;
      --interval) interval="$2"; shift 2 ;;
      --once)    once=1; shift ;;
      -h|--help)
        echo "Usage: backlog-agents monitor [--fix] [--interval <seconds>] [--once]"
        echo "  Scan agent logs for failure patterns and auto-fix where safe."
        echo "  --fix       Actually apply fixes (default: dry-run / report only)"
        echo "  --interval  Seconds between scans (default: 60)"
        echo "  --once      Run a single scan and exit"
        return 0 2>/dev/null || exit 0
        ;;
      *) echo "backlog-agents monitor: unknown flag: $1" >&2; exit 2 ;;
    esac
  done

  local this_host; this_host="$(hostname)"
  this_host="${this_host%.local}"
  local status_file="$ACTIVE_ROOT/backlog-infra/.claude/monitor-status-${this_host}.json"
  local sweeps_total=0 fixed_total=0 flagged_total=0
  local log_tail_lines=150
  local _last_status_commit=0
  local _status_heartbeat=300
  # Reconciled notify config (docs/dead-mans-switch.md): the canonical file is
  # ~/.claude/agent-notify.json (shared with the driver: slack_webhook_url / email /
  # local_notify). The legacy ~/.config/backlog/notify.json (slack_webhook /
  # local_notify) is honored as a fallback so an existing setup keeps working.
  local _notify_config="$HOME/.claude/agent-notify.json"
  local _notify_config_legacy="$HOME/.config/backlog/notify.json"
  local _last_notify=0

  # Send to every configured channel with NO throttle. Prefers the canonical config,
  # falls back to legacy; accepts either slack key name. The dead-man's-switch calls
  # this directly (its own per-incident dedup is the throttle — a dead daemon is too
  # important for the cosmetic 300s window).
  _notify_raw() {
    local title="${1:-backlog-monitor}" body="${2:-}"
    [[ -n "$body" ]] || return 0
    local f=""
    if [[ -f "$_notify_config" ]]; then f="$_notify_config"
    elif [[ -f "$_notify_config_legacy" ]]; then f="$_notify_config_legacy"
    else return 0; fi
    local slack email local_notify
    slack="$(jq -r '.slack_webhook_url // .slack_webhook // ""' "$f" 2>/dev/null || echo '')"
    email="$(jq -r '.email // ""' "$f" 2>/dev/null || echo '')"
    local_notify="$(jq -r 'if (.local_notify==true) then "true" else "false" end' "$f" 2>/dev/null || echo 'false')"
    if [[ "$local_notify" == "true" ]] && command -v osascript >/dev/null 2>&1; then
      osascript -e "display notification \"${body}\" with title \"${title}\"" 2>/dev/null || true
    fi
    if [[ -n "$slack" ]] && command -v curl >/dev/null 2>&1; then
      local payload
      payload="$(jq -nc --arg t "$title" --arg b "$body" --arg h "$this_host" '{"text": "\($t) (\($h)): \($b)"}')"
      curl -s -X POST -H 'Content-type: application/json' --data "$payload" "$slack" >/dev/null 2>&1 || true
    fi
    if [[ -n "$email" ]] && command -v mail >/dev/null 2>&1; then
      ( printf '%s\n' "$body" | mail -s "${title} (${this_host})" "$email" >/dev/null 2>&1 || true )
    fi
  }

  # Throttled wrapper for the cosmetic / noisy alerts (cooldown-parse, stuck agent,
  # code bug): at most one send per 300s across all of them.
  _notify() {
    local body="${2:-}"
    [[ -n "$body" ]] || return 0
    local now_epoch; now_epoch="$(date +%s)"
    if (( now_epoch - _last_notify < 300 )); then return 0; fi
    _last_notify="$now_epoch"
    _notify_raw "$@"
  }

  _write_status() {
    local had_action="${1:-0}"
    local now_iso; now_iso="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    local now_epoch; now_epoch="$(date +%s)"
    local actions_json="["
    local first=1
    if (( ${#recent_actions[@]:-0} > 0 )); then
      for entry in "${recent_actions[@]}"; do
        [[ $first -eq 1 ]] && first=0 || actions_json+=","
        actions_json+="$entry"
      done
    fi
    actions_json+="]"
    cat > "$status_file" <<JSON
{
  "last_sweep_at": "${now_iso}",
  "running": true,
  "fix_mode": ${fix},
  "host": "${this_host}",
  "sweeps_total": ${sweeps_total},
  "fixed_total": ${fixed_total},
  "flagged_total": ${flagged_total},
  "recent_actions": ${actions_json}
}
JSON
    local should_commit=0
    if (( had_action )); then
      should_commit=1
    elif (( now_epoch - _last_status_commit >= _status_heartbeat )); then
      should_commit=1
    fi
    if (( should_commit )); then
      git -C "$ACTIVE_ROOT/backlog-infra" add "$status_file" 2>/dev/null || true
      git -C "$ACTIVE_ROOT/backlog-infra" pull --rebase origin main >/dev/null 2>&1 || true
      git -C "$ACTIVE_ROOT/backlog-infra" commit -m "monitor: sweep ${sweeps_total} (${fixed_total} fixed, ${flagged_total} flagged)" >/dev/null 2>&1 || true
      git -C "$ACTIVE_ROOT/backlog-infra" push origin main 2>/dev/null || true
      _last_status_commit="$now_epoch"
    else
      git -C "$ACTIVE_ROOT/backlog-infra" checkout -- "$status_file" 2>/dev/null || true
    fi
  }

  local -a recent_actions=()

  # Dead-man's-switch (docs/dead-mans-switch.md): a daemon whose INDEPENDENT D1
  # heartbeat is older than this is presumed dead (2x the driver's HEARTBEAT_SECONDS
  # of 1800 = a missed beat plus margin). _dms_alerted is a '|'-delimited set of
  # "project@host" keys currently in the alerted state — per-incident dedup so a
  # persistent death alerts once, re-arming when the daemon heartbeats again. Lives
  # in do_monitor scope so it persists across _monitor_run sweeps (a monitor restart
  # re-arms all, which is fine). bash-3.2-safe (no associative arrays).
  local _dms_stale_secs="${DMS_STALE_SECS:-3600}"
  local _dms_alerted='|'

  _monitor_run() {
    local ts; ts="$(date '+%Y-%m-%d %H:%M:%S')"
    local -a fix_descriptions=()
    local sweep_fixed=0 sweep_flagged=0

    local -a candidates=()
    local root proj_dir
    for root in "${PROJECTS_ROOTS[@]}"; do
      [[ -d "$root" ]] || continue
      for proj_dir in "$root"/*/; do
        [[ -d "$proj_dir" ]] || continue
        candidates+=("${proj_dir%/}")
      done
    done

    local seen='|'
    local -a unique=()
    for proj_dir in "${candidates[@]}"; do
      local real
      real="$(cd "$proj_dir" 2>/dev/null && pwd -P)" || continue
      case "$seen" in *"|$real|"*) continue ;; esac
      seen="${seen}${real}|"
      unique+=("$real")
    done

    for proj_dir in "${unique[@]}"; do
      local log_file="$proj_dir/.claude/backlog-agent.log"
      local cd_file="$proj_dir/.claude/agent-cooldown.json"
      local inflight="$proj_dir/.claude/backlog-agent-tick.inflight"
      local lock_dir="$proj_dir/.claude/backlog-agent.lock"
      local name; name="$(basename "$proj_dir")"
      [[ -f "$log_file" ]] || continue

      local recent; recent="$(tail -n "$log_tail_lines" "$log_file" 2>/dev/null || true)"
      [[ -n "$recent" ]] || continue

      local safe_to_fix=1
      [[ -f "$inflight" ]] && safe_to_fix=0
      [[ -d "$lock_dir" ]] && safe_to_fix=0

      # Pattern 1: git dirty tree
      if echo "$recent" | grep -qiE 'cannot pull with rebase: You have unstaged changes|error: Your local changes.*would be overwritten|cannot rebase: You have unstaged changes'; then
        local tree_actually_dirty=0
        [[ -n $(git -C "$proj_dir" status --porcelain 2>/dev/null) ]] && tree_actually_dirty=1
        if (( tree_actually_dirty )); then
          if (( safe_to_fix && fix )) && ! _is_infra_project "$name"; then
            git -C "$proj_dir" rebase --abort 2>/dev/null || true
            git -C "$proj_dir" reset --hard "origin/$(git -C "$proj_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo main)" 2>/dev/null || \
              git -C "$proj_dir" reset --hard origin/main 2>/dev/null || true
            git -C "$proj_dir" clean -fd 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: git dirty tree — reset --hard + clean")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_dirty\",\"result\":\"fixed\"}")
          elif _is_infra_project "$name"; then
            # The infra repo is operated INTERACTIVELY and its daemon is HELD — the
            # monitor must NEVER stash/reset it (it would eat in-flight interactive
            # work, and the held daemon's log lines are frozen/stale so a fix would
            # re-fire every sweep). Flag only — the same exclusion as do_sync + the
            # dead-man's-switch watcher.
            fix_descriptions+=("  ${YL}FLAG${RS}  ${name}: git dirty tree — infra repo (interactive, daemon held); flag only, not auto-reset")
            sweep_flagged=$((sweep_flagged + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_dirty\",\"result\":\"flagged_infra\"}")
          else
            fix_descriptions+=("  ${YL}FLAG${RS}  ${name}: git dirty tree ($([[ $safe_to_fix -eq 0 ]] && echo 'BLOCKED' || echo 'detected'))")
            sweep_flagged=$((sweep_flagged + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_dirty\",\"result\":\"$([[ $safe_to_fix -eq 0 ]] && echo 'blocked_inflight' || echo 'flagged')\"}")
          fi
        fi
      fi

      # Pattern 2: git fast-forward failure
      if echo "$recent" | grep -qiE 'fatal: Cannot fast-forward'; then
        if _is_infra_project "$name"; then
          # infra repo: interactive + daemon held — flag only, never reset.
          fix_descriptions+=("  ${YL}FLAG${RS}  ${name}: git fast-forward conflict — infra repo (interactive, daemon held); flag only, not auto-reset")
          sweep_flagged=$((sweep_flagged + 1))
          recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_ff_conflict\",\"result\":\"flagged_infra\"}")
        elif (( safe_to_fix && fix )); then
          git -C "$proj_dir" fetch origin 2>/dev/null || true
          git -C "$proj_dir" reset --hard "origin/$(git -C "$proj_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo main)" 2>/dev/null || \
            git -C "$proj_dir" reset --hard origin/main 2>/dev/null || true
          fix_descriptions+=("  ${GN}FIXED${RS} ${name}: git fast-forward conflict — fetch + reset")
          sweep_fixed=$((sweep_fixed + 1))
          recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_ff_conflict\",\"result\":\"fixed\"}")
        fi
      fi

      # Pattern 3: git push failure
      if echo "$recent" | grep -qiE 'failed to push some refs'; then
        if _is_infra_project "$name"; then
          # infra repo: interactive + daemon held — flag only, never reset. (This is
          # the case that re-fired every sweep off the held daemon's frozen log.)
          fix_descriptions+=("  ${YL}FLAG${RS}  ${name}: git push rejected — infra repo (interactive, daemon held); flag only, not auto-reset")
          sweep_flagged=$((sweep_flagged + 1))
          recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_push_rejected\",\"result\":\"flagged_infra\"}")
        elif (( safe_to_fix && fix )); then
          git -C "$proj_dir" fetch origin 2>/dev/null || true
          git -C "$proj_dir" reset --hard "origin/$(git -C "$proj_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo main)" 2>/dev/null || \
            git -C "$proj_dir" reset --hard origin/main 2>/dev/null || true
          fix_descriptions+=("  ${GN}FIXED${RS} ${name}: git push rejected — fetch + reset")
          sweep_fixed=$((sweep_fixed + 1))
          recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"git_push_rejected\",\"result\":\"fixed\"}")
        fi
      fi

      # Pattern 4: stale lock
      if [[ -d "$lock_dir" ]]; then
        local lock_age
        lock_age="$(( $(date +%s) - $(stat -f %m "$lock_dir" 2>/dev/null || stat -c %Y "$lock_dir" 2>/dev/null || echo 0) ))"
        if (( lock_age > 1800 )); then
          if (( fix )); then
            rm -rf "$lock_dir" 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: stale lock (${lock_age}s old) — removed")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"stale_lock\",\"result\":\"fixed\"}")
          fi
        fi
      fi

      # Pattern 5: cooldown issues
      if [[ -f "$cd_file" ]]; then
        local cd_parsed cd_until_epoch cd_duration
        cd_parsed="$(jq -r 'if .parsed_from_reset == false then "false" else "true" end' "$cd_file" 2>/dev/null)"
        cd_until_epoch="$(jq -r '.until_epoch // 0' "$cd_file" 2>/dev/null)"
        cd_duration=$(( cd_until_epoch - $(date +%s) ))

        if [[ "$cd_parsed" == "false" ]] && (( cd_duration <= 0 )); then
          if (( fix )); then
            rm -f "$cd_file" 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: stale fallback cooldown — cleared")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"stale_cooldown\",\"result\":\"fixed\"}")
          fi
        elif [[ "$cd_parsed" == "false" ]]; then
          fix_descriptions+=("  ${YL}FLAG${RS}  ${name}: cooldown fallback — couldn't parse reset time")
          sweep_flagged=$((sweep_flagged + 1))
          _notify "backlog-monitor — cooldown issue" "${name}: couldn't parse reset time from Anthropic plan-limit message"
          _notify "backlog-monitor — cooldown issue" "${name}: couldn't parse reset time from Anthropic plan-limit message"
        elif (( cd_duration <= 0 )); then
          if (( fix )); then
            rm -f "$cd_file" 2>/dev/null || true
            fix_descriptions+=("  ${GN}FIXED${RS} ${name}: expired cooldown — cleared")
            sweep_fixed=$((sweep_fixed + 1))
            recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${name}\",\"action\":\"expired_cooldown\",\"result\":\"fixed\"}")
          fi
        fi
      fi

      # Pattern 6: _run_status_hook bug
      if echo "$recent" | grep -q '_run_status_hook: command not found'; then
        fix_descriptions+=("  ${YL}FLAG${RS}  ${name}: _run_status_hook not defined (known code bug)")
        sweep_flagged=$((sweep_flagged + 1))
        _notify "backlog-monitor — code bug" "${name}: _run_status_hook not defined"
      fi

      # Pattern 7: repeated tick failures without cooldown
      local fail_count
      fail_count="$(echo "$recent" | grep -c 'tick failed' || true)"
      local cooldown_fail
      cooldown_fail="$(echo "$recent" | grep -c 'plan-limit cooldown active' || true)"
      if (( fail_count >= 3 && cooldown_fail == 0 )) && ! [[ -f "$cd_file" ]]; then
        fix_descriptions+=("  ${RD}ALERT${RS} ${name}: ${fail_count} tick failures, no cooldown — agent may be stuck")
        sweep_flagged=$((sweep_flagged + 1))
        _notify "backlog-monitor — stuck agent" "${name}: ${fail_count} tick failures, no cooldown"
      fi
    done

    # Pattern 8: dead-man's-switch — STALE-too-long daemon (docs/dead-mans-switch.md).
    # The OUTSIDE-the-daemon half of the switch: a dead daemon can't alert about
    # itself, so the monitor reads the INDEPENDENT D1 heartbeat (written every tick
    # incl. idle/cooldown, decoupled from git) for each (project, host) it knows and
    # fires when one hasn't heartbeated for > _dms_stale_secs. Reading D1 (not the
    # git-borne status file) is the whole point — the cooldown-add incident showed a
    # FRESH-looking dashboard while the hook silently failed. Catches per-daemon death
    # AND a whole OTHER machine's death (its synced status file still names it, but its
    # heartbeat goes stale) — as long as at least one machine's monitor lives. FAIL-OPEN:
    # 404 / unreachable / null epoch ⇒ skip (can't conclude death; mirrors the reaper).
    # infra is EXCLUDED (its daemon is held by policy → legitimately not heartbeating).
    local -a dms_trips=()
    local now_epoch_dms; now_epoch_dms="$(date +%s)"
    local dms_proj dms_pname dms_sfile dms_host dms_epoch dms_age dms_key
    for dms_proj in "${unique[@]}"; do
      dms_pname="$(basename "$dms_proj")"
      _is_infra_project "$dms_pname" && continue
      for dms_sfile in "$dms_proj"/.claude/backlog-status-*.json; do
        [[ -f "$dms_sfile" ]] || continue
        dms_host="$(basename "$dms_sfile" .json)"; dms_host="${dms_host#backlog-status-}"
        dms_host="${dms_host%.local}"
        [[ -n "$dms_host" ]] || continue
        dms_key="${dms_pname}@${dms_host}"
        dms_epoch="$(_heartbeat_epoch "$dms_pname" "$dms_host")"
        if [[ -z "$dms_epoch" ]]; then
          continue   # fail-open: can't read liveness → don't conclude death
        fi
        dms_age=$(( now_epoch_dms - dms_epoch ))
        if (( dms_age > _dms_stale_secs )); then
          case "$_dms_alerted" in
            *"|${dms_key}|"*) : ;;   # already alerted this incident → throttle
            *)
              _dms_alerted="${_dms_alerted}${dms_key}|"
              dms_trips+=("${dms_key} (no heartbeat for $(( dms_age / 60 ))m)")
              fix_descriptions+=("  ${RD}DEAD-MAN${RS} ${dms_pname}@${dms_host}: no D1 heartbeat for $(( dms_age / 60 ))m (>${_dms_stale_secs}s) — daemon presumed dead")
              sweep_flagged=$((sweep_flagged + 1))
              recent_actions+=("{\"ts\":\"$(date -u '+%Y-%m-%dT%H:%M:%SZ')\",\"project\":\"${dms_pname}\",\"host\":\"${dms_host}\",\"action\":\"dead_mans_switch\",\"result\":\"alerted\",\"age_sec\":${dms_age}}")
              ;;
          esac
        else
          # daemon is heartbeating again → re-arm so a future death re-alerts.
          _dms_alerted="${_dms_alerted//|${dms_key}|/|}"
        fi
      done
    done
    if (( ${#dms_trips[@]:-0} > 0 )); then
      local dms_body; dms_body="$(printf '%s; ' "${dms_trips[@]}")"
      _notify_raw "backlog-monitor — DEAD daemon(s)" "${dms_body%; }"
    fi

    sweeps_total=$((sweeps_total + 1))
    fixed_total=$((fixed_total + sweep_fixed))
    flagged_total=$((flagged_total + sweep_flagged))

    # Trim recent_actions to last 20
    while (( ${#recent_actions[@]:-0} > 20 )); do
      recent_actions=("${recent_actions[@]:1}")
    done

    # Print sweep report
    if (( sweep_fixed > 0 || sweep_flagged > 0 )); then
      echo
      printf '  %s━━ monitor sweep %s━━%s\n' "$DIM" "$ts" "$RS"
      for desc in "${fix_descriptions[@]}"; do
        printf '%s\n' "$desc"
      done
      local summary=""
      (( sweep_fixed > 0 )) && summary="${summary}${GN}${sweep_fixed} fixed${RS}"
      (( sweep_fixed > 0 && sweep_flagged > 0 )) && summary="${summary}, "
      (( sweep_flagged > 0 )) && summary="${summary}${YL}${sweep_flagged} flagged${RS}"
      echo "  ${DIM}══════════════════════════════════════${RS}"
      echo "  ${summary}"
    else
      echo "  ${DIM}━━ sweep ${sweeps_total} OK (no issues)━━${RS}"
    fi

    _write_status $(( sweep_fixed > 0 || sweep_flagged > 0 ? 1 : 0 ))
  }

  if (( once )); then
    _monitor_run
  else
    _on_monitor_exit() {
      local exit_code=$?
      local now_iso; now_iso="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
      local state; state="$([[ $exit_code -eq 0 ]] && echo 'stopped' || echo 'crashed')"
      cat > "$status_file" <<JSON
{
  "last_sweep_at": "${now_iso}",
  "running": false,
  "exit_code": ${exit_code},
  "exit_state": "${state}",
  "fix_mode": ${fix},
  "host": "${this_host}",
  "sweeps_total": ${sweeps_total},
  "fixed_total": ${fixed_total},
  "flagged_total": ${flagged_total},
  "recent_actions": []
}
JSON
      git -C "$ACTIVE_ROOT/backlog-infra" add "$status_file" 2>/dev/null || true
      git -C "$ACTIVE_ROOT/backlog-infra" pull --rebase origin main >/dev/null 2>&1 || true
      git -C "$ACTIVE_ROOT/backlog-infra" commit -m "monitor: ${state} (sweep ${sweeps_total}, ${fixed_total} fixed, ${flagged_total} flagged)" >/dev/null 2>&1 || true
      git -C "$ACTIVE_ROOT/backlog-infra" push origin main 2>/dev/null || true
      exit "$exit_code"
    }
    trap '_on_monitor_exit' INT TERM EXIT
    info "monitoring fleet (interval=${interval}s, fix=${fix})..."
    while true; do
      _monitor_run
      sleep "$interval"
    done
  fi
}

# ---- subcommand: doctor ----
# Preflight health check. Codifies the by-hand checks we run when the fleet
# misbehaves so "why is the fleet weird" becomes a 2-second read. Strictly
# read-only — it reports drift and never mutates state. Exit status: 0 if clean
# (warnings allowed), 1 if any hard check FAILs.
do_doctor() {
  local fails=0 warns=0
  local P="${GN}✓${RS}" F="${RD}✗${RS}" W="${YL}!${RS}"
  _d_pass() { printf '    %s %s\n' "$P" "$1"; }
  _d_warn() { printf '    %s %s\n' "$W" "$1"; warns=$((warns + 1)); }
  _d_fail() { printf '    %s %s\n' "$F" "$1"; fails=$((fails + 1)); }
  _d_head() { printf '\n  %s%s%s\n' "$B" "$1" "$RS"; }

  local manifest="$DOTFILES/active-projects.txt"
  local uid; uid="$(id -u)"
  local this_host; this_host="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo '?')"
  printf '%sbacklog-agents doctor%s  (%s)\n' "$B" "$RS" "$this_host"

  # Parse the manifest into a `|`-delimited set of project names (field 1 is a
  # path under ACTIVE_ROOT; we key on its basename). bash 3.2 compatible.
  local manifest_set='|' manifest_count=0
  if [[ -f "$manifest" ]]; then
    local mline rel mname
    while IFS= read -r mline || [[ -n "$mline" ]]; do
      [[ -z "$mline" || "$mline" == \#* ]] && continue
      rel="${mline%%$'\t'*}"; rel="${rel%% *}"
      [[ -z "$rel" ]] && continue
      mname="$(basename "$rel")"
      manifest_set="${manifest_set}${mname}|"
      manifest_count=$((manifest_count + 1))
    done < "$manifest"
  fi

  # --- 1. manifest <-> project dirs ---
  _d_head "Manifest ↔ project dirs"
  if [[ ! -f "$manifest" ]]; then
    _d_fail "no manifest at $manifest (run \`dev-projects sync\`)"
  else
    _d_pass "manifest present ($manifest_count project(s))"
    local nm
    local IFS='|'
    for nm in $manifest_set; do
      [[ -z "$nm" ]] && continue
      if [[ ! -d "$ACTIVE_ROOT/$nm" ]]; then
        _d_fail "manifest lists '$nm' but $ACTIVE_ROOT/$nm does not exist"
      elif [[ ! -d "$ACTIVE_ROOT/$nm/.git" ]]; then
        _d_warn "'$nm' exists but is not a git repo"
      fi
    done
    unset IFS
    # Reverse drift: a project with a backlog that the manifest omits.
    local pd pn
    for pd in "$ACTIVE_ROOT"/*/; do
      [[ -d "$pd" ]] || continue
      pn="$(basename "$pd")"
      [[ -n "$(find_backlog_file "${pd%/}")" ]] || continue
      case "$manifest_set" in
        *"|$pn|"*) : ;;
        *) _d_warn "'$pn' has a backlog but is missing from the manifest" ;;
      esac
    done
  fi

  # --- 2. daemons: count, double-daemons, dangling plists ---
  _d_head "launchd daemons"
  local pl label dn loaded_canonical=0
  # Track which projects have a loaded daemon, and which carry a legacy label.
  local loaded_set='|' legacy_loaded_set='|'
  for pl in "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-agent.plist \
            "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog.plist \
            "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-loop.plist; do
    [[ -f "$pl" ]] || continue
    label="$(basename "$pl" .plist)"
    dn="${label#com.${USER}.}"
    dn="${dn%.backlog-agent}"; dn="${dn%.backlog}"; dn="${dn%.backlog-loop}"
    local is_loaded=0
    launchctl print "gui/$uid/$label" >/dev/null 2>&1 && is_loaded=1
    # Dangling: plist points at a project dir that no longer exists.
    if [[ ! -d "$ACTIVE_ROOT/$dn" ]]; then
      _d_fail "$label points at $ACTIVE_ROOT/$dn which does not exist"
    fi
    if [[ "$pl" == *backlog-agent.plist ]]; then
      (( is_loaded )) && { loaded_canonical=$((loaded_canonical + 1)); loaded_set="${loaded_set}${dn}|"; }
    else
      (( is_loaded )) && legacy_loaded_set="${legacy_loaded_set}${dn}|"
    fi
  done
  # Double-daemons: a project running BOTH a canonical and a legacy-label daemon.
  local dd_found=0 ln
  local IFS='|'
  for ln in $legacy_loaded_set; do
    [[ -z "$ln" ]] && continue
    case "$loaded_set" in
      *"|$ln|"*) _d_fail "double-daemon: '$ln' runs both a canonical AND a legacy-label daemon"; dd_found=1 ;;
      *) _d_warn "'$ln' runs only a legacy-label daemon (migrate via \`backlog-agent install-daemon\`)" ;;
    esac
  done
  unset IFS
  (( dd_found == 0 )) && _d_pass "no double-daemons"
  _d_pass "$loaded_canonical canonical daemon(s) loaded"
  # Manifest projects with no loaded daemon.
  local mn
  local IFS='|'
  for mn in $manifest_set; do
    [[ -z "$mn" ]] && continue
    case "$loaded_set" in
      *"|$mn|"*) : ;;
      *) _d_warn "manifest project '$mn' has no loaded canonical daemon" ;;
    esac
  done
  unset IFS

  # --- 3. plists point at canonical (de-symlinked) paths ---
  _d_head "Plist paths canonical"
  local canon_bin=""
  if [[ -f "$ACTIVE_ROOT/backlog-infra/bin/backlog-agent" ]]; then
    canon_bin="$(cd "$ACTIVE_ROOT/backlog-infra/bin" 2>/dev/null && pwd -P)/backlog-agent"
  fi
  local checked=0
  for pl in "$HOME"/Library/LaunchAgents/com."${USER}".*.backlog-agent.plist; do
    [[ -f "$pl" ]] || continue
    label="$(basename "$pl" .plist)"
    local prog wdir
    prog="$(/usr/libexec/PlistBuddy -c 'Print :ProgramArguments:1' "$pl" 2>/dev/null || true)"
    wdir="$(/usr/libexec/PlistBuddy -c 'Print :WorkingDirectory' "$pl" 2>/dev/null || true)"
    checked=$((checked + 1))
    if [[ -n "$prog" && -n "$canon_bin" && "$prog" != "$canon_bin" ]]; then
      _d_warn "$label: driver path '$prog' != canonical '$canon_bin'"
    fi
    if [[ -n "$wdir" ]]; then
      local wdir_real; wdir_real="$(cd "$wdir" 2>/dev/null && pwd -P || true)"
      if [[ -z "$wdir_real" ]]; then
        _d_fail "$label: WorkingDirectory '$wdir' does not resolve"
      elif [[ "$wdir_real" != "$wdir" ]]; then
        _d_warn "$label: WorkingDirectory '$wdir' is a symlink → '$wdir_real' (re-install to canonicalize)"
      fi
    fi
  done
  (( checked > 0 )) && _d_pass "checked $checked canonical plist(s)" || _d_warn "no canonical plists found"

  # --- 4. per-project config hygiene (gitignore + status hook) ---
  # Assert every active repo ignores the full canonical ephemeral set
  # ($EPHEMERAL_CLAUDE_IGNORES). A *tracked* ephemeral file is a HARD failure —
  # the daemon rewrites it each tick → orphaned autostash every tick. An
  # untracked-but-unignored one is a WARN — it only orphans when autostash
  # `--include-untracked` happens to sweep it. We test ignore-ness with
  # `git check-ignore` (honours global + repo rules, dir patterns, the lot)
  # rather than grepping the file, and tracked-ness with `git ls-files`.
  _d_head "Per-project config"
  local proj pn hook pat path tracked_eph unignored_eph
  for proj in "$ACTIVE_ROOT"/*/; do
    proj="${proj%/}"
    [[ -d "$proj" ]] || continue
    [[ -n "$(find_backlog_file "$proj")" ]] || continue
    pn="$(basename "$proj")"
    # Ephemeral .claude/ set: tracked → hard-fail, unignored → warn.
    if [[ -d "$proj/.git" ]]; then
      tracked_eph=""; unignored_eph=""
      for pat in "${EPHEMERAL_CLAUDE_IGNORES[@]}"; do
        path="${pat%/}"   # slash-stripped form for ls-files (no dir-as-file)
        # ls-files matches any tracked file at/under the path (a tracked lock
        # *dir* shows up via its contents); check-ignore keeps the original
        # pattern so a dir-only `foo/` rule still matches `foo/`.
        if git -C "$proj" ls-files --error-unmatch -- "$path" >/dev/null 2>&1; then
          tracked_eph="${tracked_eph}${path} "
        elif ! git -C "$proj" check-ignore -q -- "$pat" 2>/dev/null; then
          unignored_eph="${unignored_eph}${path} "
        fi
      done
      [[ -n "$tracked_eph" ]] && _d_fail "$pn: TRACKED ephemeral file(s) (untrack + gitignore): $tracked_eph"
      [[ -n "$unignored_eph" ]] && _d_warn "$pn: ephemeral path(s) not gitignored: $unignored_eph"
    else
      _d_warn "$pn: not a git repo; skipped ephemeral-ignore check"
    fi
    # status hook resolves (mirror the driver's resolution order)
    if   [[ -f "$proj/scripts/backlog-agent-status.mjs" ]]; then hook="$proj/scripts/backlog-agent-status.mjs"
    elif [[ -f "$proj/scripts/loop-status.mjs" ]];           then hook="$proj/scripts/loop-status.mjs"
    elif [[ -f "$ACTIVE_ROOT/backlog-infra/bin/backlog-agent-status.mjs" ]]; then hook="$ACTIVE_ROOT/backlog-infra/bin/backlog-agent-status.mjs"
    else hook=""; fi
    if [[ -z "$hook" ]]; then
      _d_fail "$pn: no status hook resolves (and shared fallback missing)"
    elif command -v node >/dev/null 2>&1 && ! node --check "$hook" >/dev/null 2>&1; then
      _d_fail "$pn: status hook has a syntax error ($hook)"
    fi
    # Secret-scanning pre-push gate (docs/secret-scan.md): assert this clone
    # carries the CURRENT-version hook. Missing/empty/stale ⇒ warn (the driver
    # self-heals on the next tick; `install-hooks` is the one-shot). A NON-EMPTY
    # foreign pre-push hook ⇒ warn (we won't clobber it without --force).
    if [[ -e "$proj/.git" ]]; then
      local pp_gitdir pp_hook
      pp_gitdir="$(git -C "$proj" rev-parse --git-dir 2>/dev/null || true)"
      if [[ -n "$pp_gitdir" ]]; then
        case "$pp_gitdir" in /*) : ;; *) pp_gitdir="$proj/$pp_gitdir" ;; esac
        pp_hook="$pp_gitdir/hooks/pre-push"
        if prepush_hook_is_foreign "$pp_hook"; then
          _d_warn "$pn: foreign pre-push hook (no secret gate; \`install-hooks --force\` to replace)"
        elif ! prepush_hook_is_current "$pp_hook"; then
          _d_warn "$pn: no current pre-push secret gate (run \`backlog-agents install-hooks\` or wait for the next tick)"
        fi
      fi
    fi
  done
  (( fails == 0 )) && _d_pass "status hooks resolve; ephemeral .claude/ set ignored & untracked"

  # --- 5. budgets file + required tools ---
  _d_head "Globals & tools"
  local budgets="$HOME/.claude/backlog-budgets.json"
  if [[ ! -e "$budgets" ]]; then
    _d_warn "no budgets file at $budgets (dashboard budget bars disabled)"
  elif ! jq -e . "$budgets" >/dev/null 2>&1; then
    _d_fail "budgets file is not valid JSON ($budgets)"
  else
    _d_pass "budgets file present and valid"
  fi
  local tool
  for tool in git node jq; do
    command -v "$tool" >/dev/null 2>&1 && _d_pass "$tool present" || _d_fail "$tool MISSING (required)"
  done
  for tool in gawk fswatch; do
    command -v "$tool" >/dev/null 2>&1 && _d_pass "$tool present" \
      || _d_warn "$tool not found (gawk avoids the BSD-awk inplace footgun; fswatch enables event-driven ticks)"
  done

  # --- summary ---
  printf '\n  %s—%s %d fail, %d warn\n' "$DIM" "$RS" "$fails" "$warns"
  if (( fails > 0 )); then
    printf '  %s✗ doctor: %d hard failure(s)%s\n' "$RD" "$fails" "$RS"
    return 1
  fi
  printf '  %s✓ doctor: no hard failures%s\n' "$GN" "$RS"
  return 0
}

# ---- subcommand: canary ----
# Blast-radius control for the SHARED driver: validate a driver version before
# it goes fleet-wide. Because bin/ is shared, one bad driver commit breaks every
# project at once (the 2026-05-28 cooldown-add bug did exactly this). The canary
# asserts health against the *current* driver and records a pass keyed to its bin
# SHA; the reaper-restart / fleet-freeze consult `canary --check` so a daemon
# never comes back up on a driver that hasn't passed. Token-free + deterministic:
# the self-test suite already contains the regression test for that bug class.
#
#   backlog-agents canary           run the checks; record a pass for the current SHA
#   backlog-agents canary --check   read-only gate: exit 0 iff the running driver passed
#   --json                          machine-readable result
#
# Overrides (testing): CANARY_STATE_FILE, CANARY_SELFTEST_CMD, CANARY_DOCTOR=0.
do_canary() {
  local check_only=0 json=0 a
  for a in "$@"; do
    case "$a" in
      --check) check_only=1 ;;
      --json)  json=1 ;;
      *) echo "backlog-agents canary: unknown flag: $a" >&2; exit 2 ;;
    esac
  done

  local infra_dir="$ACTIVE_ROOT/backlog-infra"
  local state_file="${CANARY_STATE_FILE:-$HOME/.claude/backlog-canary.json}"
  local cur_sha=""
  [[ -d "$infra_dir/.git" ]] && cur_sha="$(git -C "$infra_dir" log -1 --format=%h -- bin 2>/dev/null || true)"

  if (( check_only )); then
    local passed_sha=""
    [[ -f "$state_file" ]] && passed_sha="$(jq -r '.passed_sha // empty' "$state_file" 2>/dev/null || true)"
    if [[ -n "$cur_sha" && "$passed_sha" == "$cur_sha" ]]; then
      (( json )) && printf '{"ok":true,"sha":"%s"}\n' "$cur_sha" || ok "canary current: driver ${cur_sha} has passed"
      return 0
    fi
    (( json )) && printf '{"ok":false,"sha":"%s","passed_sha":"%s"}\n' "$cur_sha" "$passed_sha" \
      || warn "canary STALE: running driver=${cur_sha:-?}, last passed=${passed_sha:-none} — run \`backlog-agents canary\` before letting the fleet pull"
    return 1
  fi

  # Run mode: assert health, then record a pass for the current SHA.
  info "canary: validating driver ${cur_sha:-?}"
  local selftest_rc=0 doctor_rc=0
  local selftest_cmd="${CANARY_SELFTEST_CMD:-bash $infra_dir/test/run.sh}"
  info "  self-test: $selftest_cmd"
  if $selftest_cmd >/dev/null 2>&1; then ok "  self-test passed"; else selftest_rc=1; warn "  self-test FAILED"; fi
  if [[ "${CANARY_DOCTOR:-1}" == "1" ]]; then
    if do_doctor >/dev/null 2>&1; then ok "  doctor passed"; else doctor_rc=1; warn "  doctor reported a HARD failure"; fi
  fi
  if (( selftest_rc || doctor_rc )); then
    warn "canary FAILED for driver ${cur_sha:-?} — not recording a pass (do NOT roll this driver fleet-wide)"
    return 1
  fi
  mkdir -p "$(dirname "$state_file")"
  jq -n --arg sha "$cur_sha" --arg at "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
     '{passed_sha:$sha, passed_at:$at, checks:{selftest:"pass", doctor:"pass"}}' > "$state_file"
  ok "canary PASSED — recorded driver ${cur_sha} (${state_file})"
  return 0
}

# ---- subcommand: freeze / unfreeze (W3, docs/fleet-freeze.md) ----
# The fleet-freeze flag lives as a single fleet-wide row in the D1 telemetry bus
# (GET/POST /api/fleet-control). The per-tick READ is in the driver
# (`backlog-agent` _d1_freeze_get, jq-free, fail-open); the WRITES + the fleet-
# wide clear EVALUATION live here because this CLI already speaks jq + computes
# version-skew. Arm holds every NON-exempt daemon to heartbeat-only; the exempt
# (backlog-infra) daemon keeps ticking and runs `freeze --eval` each tick.
#
#   backlog-agents freeze [--reason R]          manual arm (armed_by=manual)
#   backlog-agents freeze --arm --sha S --by H  auto-arm (called by the driver)
#   backlog-agents freeze --status              human-readable current state
#   backlog-agents freeze --check               exit 0 iff currently frozen
#   backlog-agents freeze --eval                auto-clear iff skew-zero + canary
#   backlog-agents unfreeze                     manual override clear
#
# Overrides (testing): FREEZE_URL, HEALTH_URL, FREEZE_LIVENESS_SECS.
FREEZE_URL="${FREEZE_URL:-https://kash-backlogs.pages.dev/api/fleet-control}"
HEALTH_URL="${HEALTH_URL:-https://kash-backlogs.pages.dev/api/health}"
COOLDOWN_URL="${COOLDOWN_URL:-https://kash-backlogs.pages.dev/api/cooldown}"
# Per-(project,host) liveness point-read (the same signal the reaper uses); the
# dead-man's-switch staleness watcher in `monitor` consults it. docs/dead-mans-switch.md.
HEARTBEAT_URL="${HEARTBEAT_URL:-https://kash-backlogs.pages.dev/api/heartbeat}"
# DECISION B liveness window: a host whose heartbeat is older than this is not
# counted toward skew-zero (a powered-off laptop must not pin the freeze). 90m,
# mirroring the reaper's stale-claim threshold.
FREEZE_LIVENESS_SECS="${FREEZE_LIVENESS_SECS:-5400}"

_health_key() {
  local f="$HOME/.config/backlog/health-key"
  [[ -f "$f" ]] && tr -d '[:space:]' < "$f" 2>/dev/null || true
}

# Point-read a single (project, host) heartbeat_epoch from the D1 bus — the same
# /api/heartbeat liveness signal the reaper consults (written every tick incl.
# idle/cooldown, decoupled from git commits). Echoes the integer epoch on success;
# echoes NOTHING on any failure (no curl, network, non-200, found:false, null) so
# the dead-man's-switch watcher treats "no answer" as FAIL-OPEN (can't conclude a
# daemon is dead). jq-free integer extract, mirroring the driver's _d1_heartbeat_epoch.
_heartbeat_epoch() {
  command -v curl >/dev/null 2>&1 || return 0
  local proj="${1:-}" host="${2:-}"
  [[ -n "$proj" ]] || return 0
  # Minimal URL-encode of spaces (fleet project/host names are otherwise slugs).
  local p="${proj// /%20}" h="${host// /%20}"
  local key auth=() body code epoch
  key="$(_health_key)"; [[ -n "$key" ]] && auth=(-H "Authorization: Bearer $key")
  body="$(curl -s -m 5 ${auth[@]+"${auth[@]}"} -w $'\n%{http_code}' \
          "${HEARTBEAT_URL}?project=${p}&host=${h}" 2>/dev/null)" || return 0
  code="$(printf '%s' "$body" | tail -n1)"; body="$(printf '%s' "$body" | sed '$d')"
  [[ "$code" == "200" ]] || return 0
  printf '%s' "$body" | grep -q '"found"[[:space:]]*:[[:space:]]*true' || return 0
  epoch="$(printf '%s' "$body" | grep -oE '"heartbeat_epoch"[[:space:]]*:[[:space:]]*[0-9]+' \
           | grep -oE '[0-9]+$' | head -n1 || true)"
  [[ -n "$epoch" ]] && printf '%s' "$epoch"
  return 0
}

# Reference driver SHA = origin/main's last bin commit (short). Empty if no repo.
_driver_ref_sha() {
  local infra_dir="$ACTIVE_ROOT/backlog-infra" r=""
  if [[ -d "$infra_dir/.git" ]]; then
    git -C "$infra_dir" fetch origin main -q 2>/dev/null || true
    r="$(git -C "$infra_dir" log -1 --format=%h origin/main -- bin 2>/dev/null || true)"
    [[ -z "$r" ]] && r="$(git -C "$infra_dir" log -1 --format=%h -- bin 2>/dev/null || true)"
  fi
  printf '%s' "$r"
}

# GET the freeze row; echoes the raw JSON body. Returns non-zero on any failure
# (no curl, network, non-200) so callers can decide (fail-open at the gate;
# stay-frozen at the eval — see do_freeze).
_fleet_control_get() {
  command -v curl >/dev/null 2>&1 || return 1
  local key auth=() body code
  key="$(_health_key)"; [[ -n "$key" ]] && auth=(-H "Authorization: Bearer $key")
  body="$(curl -s -m 5 ${auth[@]+"${auth[@]}"} -w $'\n%{http_code}' "$FREEZE_URL" 2>/dev/null)" || return 1
  code="$(printf '%s' "$body" | tail -n1)"; body="$(printf '%s' "$body" | sed '$d')"
  [[ "$code" == "200" ]] || return 1
  printf '%s' "$body"
}

# POST arm/clear ONE control. $1=frozen(0/1) $2=reason $3=armed_by $4=arming_sha
# $5=control-key (freeze|pause|stop, default freeze — so the existing freeze/
# unfreeze 4-arg callers stay on the freeze row unchanged). Needs the bearer key
# (writes are privileged). Returns non-zero on any failure.
_fleet_control_post() {
  command -v curl >/dev/null 2>&1 || { warn "control: curl not available"; return 1; }
  local key; key="$(_health_key)"
  [[ -z "$key" ]] && { warn "control: no health key at ~/.config/backlog/health-key — cannot write the flag"; return 1; }
  local payload
  payload="$(jq -cn --argjson frozen "${1:-0}" --arg reason "${2:-}" --arg by "${3:-}" --arg sha "${4:-}" --arg ck "${5:-freeze}" \
    '{key:$ck,
      frozen:$frozen,
      reason:(if $reason=="" then null else $reason end),
      armed_by:(if $by=="" then null else $by end),
      arming_sha:(if $sha=="" then null else $sha end)}')" || { warn "control: failed to build payload"; return 1; }
  local body code
  body="$(curl -s -m 8 -X POST -H "Authorization: Bearer $key" -H "Content-Type: application/json" \
          -d "$payload" -w $'\n%{http_code}' "$FREEZE_URL" 2>/dev/null)" || { warn "freeze: POST failed (network)"; return 1; }
  code="$(printf '%s' "$body" | tail -n1)"
  [[ "$code" == "200" ]] || { warn "freeze: POST returned HTTP ${code:-?}"; return 1; }
  return 0
}

# True (0) iff every LIVE host (fresh heartbeat) reporting a driver_sha is on the
# reference SHA — i.e. the in-flight change has PROPAGATED everywhere. Conservative
# for the CLEAR direction: any fresh host on a different SHA, an unreadable
# /api/health, or no reference ⇒ non-zero (stay frozen). Hosts with a null
# driver_sha aren't counted (can't judge; likely non-daemon/loop rows).
_fleet_skew_zero() {
  local ref; ref="$(_driver_ref_sha)"
  [[ -z "$ref" ]] && return 1
  command -v curl >/dev/null 2>&1 || return 1
  local body code
  body="$(curl -s -m 8 -w $'\n%{http_code}' "$HEALTH_URL" 2>/dev/null)" || return 1
  code="$(printf '%s' "$body" | tail -n1)"; body="$(printf '%s' "$body" | sed '$d')"
  [[ "$code" == "200" ]] || return 1
  local skewed
  skewed="$(printf '%s' "$body" | jq -r --arg ref "$ref" --argjson win "$FREEZE_LIVENESS_SECS" '
    [ (.projects // {}) | to_entries[].value
      | select(.driver_sha != null and (.age_sec // 999999) < $win)
      | select(.driver_sha != $ref) ] | length' 2>/dev/null || echo "")"
  [[ "$skewed" == "0" ]]
}

do_freeze() {
  local ARM=0 STATUS=0 CHECK=0 EVAL=0 reason="" sha="" by="manual"
  while (( $# )); do
    case "$1" in
      --arm)    ARM=1 ;;
      --status) STATUS=1 ;;
      --check)  CHECK=1 ;;
      --eval)   EVAL=1 ;;
      --reason) shift; reason="${1:-}" ;;
      --sha)    shift; sha="${1:-}" ;;
      --by)     shift; by="${1:-}" ;;
      *) echo "backlog-agents freeze: unknown flag: $1" >&2; exit 2 ;;
    esac
    shift
  done

  # --status / --check: read current state (no write).
  if (( STATUS || CHECK )); then
    local body frozen
    if ! body="$(_fleet_control_get)"; then
      (( CHECK )) && return 1
      warn "freeze: cannot read flag (D1 unreachable)"; return 1
    fi
    frozen="$(printf '%s' "$body" | jq -r '.frozen // 0' 2>/dev/null || echo 0)"
    if (( STATUS )); then
      if [[ "$frozen" == "1" ]]; then
        warn "fleet is FROZEN — armed_by=$(printf '%s' "$body" | jq -r '.armed_by // "—"') \
sha=$(printf '%s' "$body" | jq -r '.arming_sha // "—"') reason: $(printf '%s' "$body" | jq -r '.reason // "—"')"
      else
        ok "fleet is thawed (not frozen)"
      fi
    fi
    [[ "$frozen" == "1" ]]   # --check: exit 0 iff frozen
    return
  fi

  # --eval: auto-clear iff the change has propagated (skew zero across live
  # hosts) AND validated (canary green locally, via _sync_gate_check). Both must
  # hold; any uncertainty ⇒ stay frozen (the safe CLEAR direction).
  if (( EVAL )); then
    local body frozen
    if ! body="$(_fleet_control_get)"; then
      warn "freeze --eval: cannot read flag (D1 unreachable); leaving as-is"; return 1
    fi
    frozen="$(printf '%s' "$body" | jq -r '.frozen // 0' 2>/dev/null || echo 0)"
    [[ "$frozen" != "1" ]] && { ok "freeze --eval: not frozen, nothing to clear"; return 0; }
    if ! _sync_gate_check >/dev/null 2>&1; then
      info "freeze --eval: local driver not yet validated (version-skew or canary) — staying frozen"; return 1
    fi
    if ! _fleet_skew_zero; then
      info "freeze --eval: version-skew across live hosts is not zero (fix not propagated) — staying frozen"; return 1
    fi
    if _fleet_control_post 0 "auto-clear: skew zero + canary green" "$(hostname 2>/dev/null | sed -E 's/\.local$//')" ""; then
      ok "freeze --eval: clear condition met — fleet THAWED"; return 0
    fi
    return 1
  fi

  # Default / --arm: arm the freeze.
  [[ -z "$reason" ]] && reason="manual freeze"
  local arm_sha="$sha"
  [[ -z "$arm_sha" ]] && arm_sha="$(_driver_ref_sha)"
  if _fleet_control_post 1 "$reason" "$by" "$arm_sha"; then
    ok "fleet FROZEN (armed_by=${by}, sha=${arm_sha:-—}) — reason: ${reason}"
    ok "non-exempt daemons hold to heartbeat-only; clears on skew-zero + canary, or \`backlog-agents unfreeze\`"
    return 0
  fi
  return 1
}

do_unfreeze() {
  if _fleet_control_post 0 "manual unfreeze" "manual" ""; then
    ok "fleet THAWED (manual override) — daemons resume on their next tick"
    return 0
  fi
  return 1
}

# ---- subcommands: pause / resume / stop / start (W3, docs/fleet-freeze.md) ----
# The MANUAL siblings of freeze, on the SAME fleet_control table (DECISION F).
# Precedence stop > pause > freeze is resolved at the GET endpoint, so these only
# need to arm/clear their own control row; the driver reads the combined "mode".
#   pause  -> heartbeat-only hold (infra-exempt, like freeze; reversible by resume)
#   stop   -> full halt (daemon exits its loop; reversible by start; bootout = hard)
# All cross-machine + uniform (every daemon reads the same D1 control). Unlike
# freeze there is NO auto-arm / auto-clear — pause/stop are deliberate operator
# actions cleared only by `resume` / `start` (or `freeze --status` to inspect).
#
#   backlog-agents pause [--reason R]   arm the pause hold
#   backlog-agents resume               clear the pause hold
#   backlog-agents stop  [--reason R]   arm the full-halt
#   backlog-agents start                clear the full-halt
#   backlog-agents <ctl> --status       human-readable state of this control
#   backlog-agents <ctl> --check        exit 0 iff this control is active

# Generic arm/clear/inspect for a control key. $1=key(pause|stop) $2=verb(arm|clear)
# then optional flags (--reason / --status / --check). --status/--check read the
# combined control; arm/clear POST the row.
_do_control() {
  local ck="$1" verb="$2"; shift 2
  local reason="" STATUS=0 CHECK=0
  while (( $# )); do
    case "$1" in
      --status) STATUS=1 ;;
      --check)  CHECK=1 ;;
      --reason) shift; reason="${1:-}" ;;
      *) echo "backlog-agents ${ck}: unknown flag: $1" >&2; exit 2 ;;
    esac
    shift
  done

  # --status / --check: read this control's active bit from the combined state.
  if (( STATUS || CHECK )); then
    local body active
    if ! body="$(_fleet_control_get)"; then
      (( CHECK )) && return 1
      warn "${ck}: cannot read control (D1 unreachable)"; return 1
    fi
    active="$(printf '%s' "$body" | jq -r --arg k "$ck" '.controls[$k].active // 0' 2>/dev/null || echo 0)"
    if (( STATUS )); then
      if [[ "$active" == "1" ]]; then
        warn "${ck} is ACTIVE — by=$(printf '%s' "$body" | jq -r --arg k "$ck" '.controls[$k].armed_by // "—"') \
reason: $(printf '%s' "$body" | jq -r --arg k "$ck" '.controls[$k].reason // "—"')"
      else
        ok "${ck} is clear (not active)"
      fi
    fi
    [[ "$active" == "1" ]]   # --check: exit 0 iff active
    return
  fi

  # arm / clear (POST). by=manual; pause/stop carry no arming SHA.
  local by frozen
  by="$(hostname 2>/dev/null | sed -E 's/\.local$//')"; [[ -z "$by" ]] && by="manual"
  if [[ "$verb" == "arm" ]]; then
    frozen=1; [[ -z "$reason" ]] && reason="manual ${ck}"
  else
    frozen=0; reason="manual ${verb} (${ck} cleared)"
  fi
  if _fleet_control_post "$frozen" "$reason" "$by" "" "$ck"; then
    if [[ "$verb" == "arm" ]]; then
      case "$ck" in
        pause) ok "fleet PAUSED (by=${by}) — reason: ${reason}"
               ok "non-exempt daemons hold to heartbeat-only (claim retained); \`backlog-agents resume\` to resume" ;;
        stop)  ok "fleet STOP armed (by=${by}) — reason: ${reason}"
               ok "every daemon halts (exits its loop, no heartbeat) on its next tick; \`backlog-agents start\` to bring back, \`launchctl bootout\` for a hard local halt" ;;
      esac
    else
      case "$ck" in
        pause) ok "fleet RESUMED (pause cleared) — daemons resume work on their next tick" ;;
        stop)  ok "fleet START (stop cleared) — daemons resume on their next launchd respawn / tick" ;;
      esac
    fi
    return 0
  fi
  return 1
}

do_pause()  { _do_control pause arm   "$@"; }
do_resume() { _do_control pause clear "$@"; }
do_stop()   { _do_control stop  arm   "$@"; }
do_start()  { _do_control stop  clear "$@"; }

# ---- subcommand: cooldown (W2, account-level shared cooldown) ----------------
# The Anthropic plan limit is per-ACCOUNT, shared across every machine + project.
# When any daemon hits it, start_cooldown (bin/backlog-agent) publishes a single
# cooldown to the D1 bus (a dedicated /api/cooldown row carrying the reset
# until_epoch), and every daemon's top-of-tick consults it FIRST — so the whole
# fleet stands down at once instead of each daemon×project failing its own claude
# call. It AUTO-EXPIRES at until_epoch (no manual clear needed). This subcommand
# is the read + manual-override surface, mirroring freeze/unfreeze:
#   backlog-agents cooldown [--status]   human-readable state (default)
#   backlog-agents cooldown --check      exit 0 iff an account cooldown is active
#   backlog-agents cooldown --clear      manually lapse the signal (e.g. a bad
#                                        reset-time parse) — the fleet resumes next tick

# GET the cooldown row; echo the raw JSON. Non-zero on any failure (no curl,
# network, non-200) so callers decide.
_cooldown_get() {
  command -v curl >/dev/null 2>&1 || return 1
  local key auth=() body code
  key="$(_health_key)"; [[ -n "$key" ]] && auth=(-H "Authorization: Bearer $key")
  body="$(curl -s -m 5 ${auth[@]+"${auth[@]}"} -w $'\n%{http_code}' "$COOLDOWN_URL" 2>/dev/null)" || return 1
  code="$(printf '%s' "$body" | tail -n1)"; body="$(printf '%s' "$body" | sed '$d')"
  [[ "$code" == "200" ]] || return 1
  printf '%s' "$body"
}

# POST to /api/cooldown. $1=until_epoch (integer; 0/empty ⇒ a CLEAR). Bearer-auth.
_cooldown_post() {
  command -v curl >/dev/null 2>&1 || { warn "cooldown: curl not available"; return 1; }
  local key; key="$(_health_key)"
  [[ -z "$key" ]] && { warn "cooldown: no health key at ~/.config/backlog/health-key — cannot write"; return 1; }
  local until_epoch="${1:-0}" by payload
  by="$(hostname 2>/dev/null | sed -E 's/\.local$//')"; [[ -z "$by" ]] && by="manual"
  payload="$(jq -cn --argjson ue "${until_epoch:-0}" --arg by "$by" \
    '{until_epoch: (if $ue==0 then null else $ue end), reason:"manual override", armed_by:$by, clear: ($ue==0)}')" \
    || { warn "cooldown: failed to build payload"; return 1; }
  local body code
  body="$(curl -s -m 8 -X POST -H "Authorization: Bearer $key" -H "Content-Type: application/json" \
          -d "$payload" -w $'\n%{http_code}' "$COOLDOWN_URL" 2>/dev/null)" || { warn "cooldown: POST failed (network)"; return 1; }
  code="$(printf '%s' "$body" | tail -n1)"
  [[ "$code" == "200" ]] || { warn "cooldown: POST returned HTTP ${code:-?}"; return 1; }
  return 0
}

do_cooldown() {
  local STATUS=0 CHECK=0 CLEAR=0
  while (( $# )); do
    case "$1" in
      --status) STATUS=1 ;;
      --check)  CHECK=1 ;;
      --clear)  CLEAR=1 ;;
      *) echo "backlog-agents cooldown: unknown flag: $1" >&2; exit 2 ;;
    esac
    shift
  done

  # --clear: manually lapse the D1 signal (writes until_epoch=null).
  if (( CLEAR )); then
    if _cooldown_post 0; then
      ok "account cooldown CLEARED — the fleet resumes on each daemon's next tick"
      return 0
    fi
    return 1
  fi

  # default / --status / --check: read the current state.
  local body active until_epoch by now remain
  if ! body="$(_cooldown_get)"; then
    (( CHECK )) && return 1
    warn "cooldown: cannot read signal (D1 unreachable)"; return 1
  fi
  active="$(printf '%s' "$body" | jq -r 'if (.active==true or .active==1) then 1 else 0 end' 2>/dev/null || echo 0)"
  if [[ "$active" == "1" ]]; then
    until_epoch="$(printf '%s' "$body" | jq -r '.until_epoch // 0' 2>/dev/null || echo 0)"
    by="$(printf '%s' "$body" | jq -r '.armed_by // "—"' 2>/dev/null || echo '—')"
    now="$(date +%s)"; remain=$(( until_epoch - now )); (( remain < 0 )) && remain=0
    (( STATUS || (! CHECK) )) && warn "account cooldown is ACTIVE — armed_by=${by}, resumes in $(( remain / 60 ))m (until_epoch=${until_epoch})"
  else
    (( STATUS || (! CHECK) )) && ok "account cooldown is clear (no fleet-wide plan-limit signal)"
  fi
  # Only --check reflects the active bit in its exit code; --status / the bare
  # command are informational and exit 0 regardless.
  if (( CHECK )); then [[ "$active" == "1" ]]; return; fi
  return 0
}

# ---- subcommand: metrics ----
# Efficiency metrics from each project's per-tick ledger
# (.claude/backlog-history.jsonl, polyglot fallback effort-log.jsonl). Reads
# every project under PROJECTS_ROOTS the same way snapshot() does (dedupe by
# realpath) and prints a per-project table plus a fleet summary of:
#   - total ticks            count of history records
#   - completed items        ticks APPROXIMATED as completions (see note)
#   - tokens/completion      sum(tokens) / completed  (efficiency)
#   - success rate           ticks with exit_code==0 / total ticks
#   - retry rate             total ticks / completed  (ticks burned per completion)
#
# NOTE: the history schema has no explicit "completed" flag yet, so a completion
# is APPROXIMATED as a tick with exit_code==0 AND a non-empty work_commit (a
# committed unit of work). This over/under-counts when a tick commits without
# finishing an item, or finishes without a commit. Footnoted in the output and
# revisable once the ledger grows a real completion field.
#
#   backlog-agents metrics          per-project table + fleet summary
#   --json                          machine-readable {projects:[...], fleet:{...}}
do_metrics() {
  local json=0 a
  for a in "$@"; do
    case "$a" in
      --json) json=1 ;;
      *) echo "backlog-agents metrics: unknown flag: $a" >&2; exit 2 ;;
    esac
  done

  # Discover projects exactly like snapshot(): walk roots, dedupe by realpath.
  local -a candidates=()
  local root proj_dir
  for root in "${PROJECTS_ROOTS[@]}"; do
    [[ -d "$root" ]] || continue
    for proj_dir in "$root"/*/; do
      [[ -d "$proj_dir" ]] || continue
      candidates+=("${proj_dir%/}")
    done
  done
  local seen='|'
  local -a unique=()
  for proj_dir in "${candidates[@]:-}"; do
    [[ -n "$proj_dir" ]] || continue
    local real
    real="$(cd "$proj_dir" 2>/dev/null && pwd -P)" || continue
    case "$seen" in *"|$real|"*) continue ;; esac
    seen="${seen}${real}|"
    unique+=("$real")
  done

  # Per-project parallel arrays (bash 3.2: no associative arrays).
  local -a m_name=() m_ticks=() m_done=() m_tokens=() m_ok=()
  # Fleet accumulators.
  local f_ticks=0 f_done=0 f_tokens=0 f_ok=0

  # Single jq pass per history file. A "completion" is exit_code==0 AND a
  # non-empty (non-null) work_commit — the documented approximation. Emits four
  # whitespace-separated integers: ticks done tokens ok.
  local jq_prog='
    [ .[] ] as $rs
    | ($rs | length) as $ticks
    | ([$rs[] | select((.exit_code // 1) == 0)] | length) as $ok
    | ([$rs[] | select((.exit_code // 1) == 0
                       and ((.work_commit // "") | tostring) != ""
                       and ((.work_commit // "") | tostring) != "null")] | length) as $done
    | ([$rs[] | .tokens // 0] | add // 0) as $tokens
    | "\($ticks) \($done) \($tokens) \($ok)"
  '

  for proj_dir in "${unique[@]:-}"; do
    [[ -n "$proj_dir" ]] || continue
    local hist; hist="$(find_history_file "$proj_dir")"
    [[ -n "$hist" ]] || continue
    local out ticks done_ tokens ok
    out="$(jq -s -r "$jq_prog" "$hist" 2>/dev/null || echo "0 0 0 0")"
    read -r ticks done_ tokens ok <<< "$out"
    [[ "$ticks" =~ ^[0-9]+$ ]] || ticks=0
    [[ "$done_" =~ ^[0-9]+$ ]] || done_=0
    [[ "$tokens" =~ ^[0-9]+$ ]] || tokens=0
    [[ "$ok" =~ ^[0-9]+$ ]] || ok=0
    (( ticks == 0 )) && continue   # no recorded ticks: nothing to report
    m_name+=("$(basename "$proj_dir")")
    m_ticks+=("$ticks"); m_done+=("$done_"); m_tokens+=("$tokens"); m_ok+=("$ok")
    f_ticks=$(( f_ticks + ticks ))
    f_done=$(( f_done + done_ ))
    f_tokens=$(( f_tokens + tokens ))
    f_ok=$(( f_ok + ok ))
  done

  # Integer-only helpers (bash has no float). Rates are scaled to keep precision.
  # _pct: ok/total as a percentage (one decimal).  _per: a/b as N.N (one decimal).
  _pct() { # numerator denominator -> "NN.N%"
    local n="$1" d="$2"
    (( d == 0 )) && { printf '%s' "—"; return; }
    printf '%d.%d%%' $(( n * 100 / d )) $(( (n * 1000 / d) % 10 ))
  }
  _per() { # numerator denominator -> "N.N"
    local n="$1" d="$2"
    (( d == 0 )) && { printf '%s' "—"; return; }
    printf '%d.%d' $(( n / d )) $(( (n * 10 / d) % 10 ))
  }
  _tpc() { # tokens completed -> integer tokens/completion (or —)
    local t="$1" c="$2"
    (( c == 0 )) && { printf '%s' "—"; return; }
    printf '%d' $(( t / c ))
  }

  if (( json )); then
    # Build the projects array with jq from the parallel arrays.
    local proj_json="[]" i
    if (( ${#m_name[@]} )); then
    for i in "${!m_name[@]}"; do
      proj_json="$(jq -c \
        --arg name "${m_name[$i]}" \
        --argjson ticks "${m_ticks[$i]}" \
        --argjson completed "${m_done[$i]}" \
        --argjson tokens "${m_tokens[$i]}" \
        --argjson ok "${m_ok[$i]}" \
        '. + [{
           project: $name,
           ticks: $ticks,
           completed: $completed,
           tokens: $tokens,
           tokens_per_completion: (if $completed > 0 then ($tokens / $completed) else null end),
           success_rate: (if $ticks > 0 then ($ok / $ticks) else null end),
           retry_rate: (if $completed > 0 then ($ticks / $completed) else null end)
         }]' <<< "$proj_json")"
    done
    fi
    jq -n \
      --argjson projects "$proj_json" \
      --argjson ticks "$f_ticks" \
      --argjson completed "$f_done" \
      --argjson tokens "$f_tokens" \
      --argjson ok "$f_ok" \
      '{
         note: "completion APPROXIMATED as exit_code==0 AND non-empty work_commit (history has no explicit completed flag yet)",
         projects: $projects,
         fleet: {
           ticks: $ticks,
           completed: $completed,
           tokens: $tokens,
           tokens_per_completion: (if $completed > 0 then ($tokens / $completed) else null end),
           success_rate: (if $ticks > 0 then ($ok / $ticks) else null end),
           retry_rate: (if $completed > 0 then ($ticks / $completed) else null end)
         }
       }'
    return 0
  fi

  printf '%sMETRICS%s  %sper-tick ledger efficiency%s\n' "${B}${CY}" "${RS}" "$DIM" "$RS"
  if (( ${#m_name[@]} == 0 )); then
    printf '\n  %sNo project history (.claude/backlog-history.jsonl) under: %s%s\n' \
      "$DIM" "${PROJECTS_ROOTS[*]}" "$RS"
    return 0
  fi
  echo
  printf '  %s%-18s %-7s %-6s %-12s %-9s %-7s%s\n' \
    "$DIM" "PROJECT" "TICKS" "DONE" "TOK/DONE" "SUCCESS" "RETRY" "$RS"
  local i
  for i in "${!m_name[@]}"; do
    printf '  %-18s %-7s %-6s %-12s %-9s %-7s\n' \
      "${m_name[$i]}" "${m_ticks[$i]}" "${m_done[$i]}" \
      "$(_tpc "${m_tokens[$i]}" "${m_done[$i]}")" \
      "$(_pct "${m_ok[$i]}" "${m_ticks[$i]}")" \
      "$(_per "${m_ticks[$i]}" "${m_done[$i]}")"
  done
  printf '  %s%-18s %-7s %-6s %-12s %-9s %-7s%s\n' \
    "$B" "FLEET" "$f_ticks" "$f_done" \
    "$(_tpc "$f_tokens" "$f_done")" \
    "$(_pct "$f_ok" "$f_ticks")" \
    "$(_per "$f_ticks" "$f_done")" "$RS"
  echo
  printf '  %s* completion APPROXIMATED as exit_code==0 AND a non-empty work_commit\n' "$DIM"
  printf '    (history has no explicit completed flag yet); RETRY = ticks per completion.%s\n' "$RS"
  return 0
}

# ---- dispatch ----

# Flags only apply to the default (snapshot) command.
FETCH=0; WATCH=0; EFFORT=0; DAY=0; COMPACT=0; ARTIFACTS=0

cmd="${1:-}"
case "$cmd" in
  sync) shift; do_sync "$@" ;;
  list) shift; do_list "$@" ;;
  doctor) shift; do_doctor "$@" ;;
  canary) shift; do_canary "$@" ;;
  freeze) shift; do_freeze "$@" ;;
  unfreeze) shift; do_unfreeze "$@" ;;
  pause) shift; do_pause "$@" ;;
  resume) shift; do_resume "$@" ;;
  stop) shift; do_stop "$@" ;;
  start) shift; do_start "$@" ;;
  cooldown) shift; do_cooldown "$@" ;;
  metrics) shift; do_metrics "$@" ;;
  daemon-sync) shift; do_daemon_sync "$@" ;;
  install-watchdog) do_install_watchdog ;;
  uninstall-watchdog) do_uninstall_watchdog ;;
  install-monitor) do_install_monitor ;;
  uninstall-monitor) do_uninstall_monitor ;;
  install-hooks) shift; do_install_hooks "$@" ;;
  migrate-daemons) do_migrate_daemons ;;
  monitor) shift; do_monitor "$@" ;;
  -h|--help)
    sed -n '2,127p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
    ;;
  *)
    # Default: snapshot. Parse flags here so they're scoped to this path.
    for arg in "$@"; do
      case "$arg" in
        --fetch)  FETCH=1 ;;
        --watch)  WATCH=1 ;;
        --effort) EFFORT=1 ;;
        --day)    DAY=1 ;;
        --compact) COMPACT=1 ;;
        --artifacts) ARTIFACTS=1 ;;
        *) echo "backlog-agents: unknown flag: $arg" >&2; exit 2 ;;
      esac
    done
    if (( WATCH )); then
      trap 'exit 0' INT TERM
      while true; do
        clear
        snapshot
        sleep 10
      done
    else
      snapshot
    fi
    ;;
esac
