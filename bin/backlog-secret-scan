#!/usr/bin/env bash
# backlog-secret-scan — the secret-scanning gate's scanner (P1·W2; docs/secret-scan.md).
#
# ONE source of truth for the regex set, shared by:
#   - the per-clone .git/hooks/pre-push stub  (mode --prepush)  → PREVENTS a push
#   - the driver Guard 5 post-push flag        (mode --range)    → DETECTS + alerts
#   - the CLI / doctor / tests                                   → any mode
#
# Standalone on purpose: it sources NOTHING (not _lib.sh) so a tiny pre-push hook
# can exec it without loading the 2500-line driver. Dependency-light: bash + git
# + grep/sed. `gitleaks` is used when present (authoritative, honors .gitleaks.toml)
# else the builtin high-confidence regex FLOOR runs — so the gate is never silently
# absent on a machine without gitleaks.
#
# Modes:
#   --prepush            read the git pre-push stdin protocol
#                        (<local ref> <local oid> <remote ref> <remote oid> lines),
#                        scan the NEW commits each ref pushes (rev-list --not --remotes),
#                        and REJECT (exit 1) if any added line carries a secret.
#   --range BASE HEAD    scan the added lines of BASE..HEAD's diff.
#   --commit SHA         scan one commit's added lines.
#   --staged             scan staged changes (future pre-commit consumer; unused today).
#
# Failure mode (docs/secret-scan.md): secret found → exit 1 (fail CLOSED); a git/
# scan error or an unreadable range → warn + exit 0 (fail OPEN — never wedge the
# fleet on a git hiccup); SECRET_SCAN_DISABLE=1 → skip.
#
# Allowlist (builtin path): an inline `pragma: allowlist secret` on the line, or a
# committed .secret-scan-allow file at the repo root (one extended-regex per line).
# gitleaks path: native .gitleaks.toml.

set -uo pipefail   # NOT -e: a non-zero grep/git is normal control flow here.

PROG="backlog-secret-scan"
SCANNER_PREF="${SECRET_SCANNER:-auto}"   # auto | builtin | gitleaks
ALLOW_FILE=".secret-scan-allow"

# Hard-disable (tests / emergency): behave as a clean pass.
[[ "${SECRET_SCAN_DISABLE:-0}" == "1" ]] && exit 0

# --- builtin high-confidence regex set (extended regex; low false-positive) ---
# Tuned conservative: the gate fails CLOSED, so a noisy rule wedges real pushes.
# Generic "password=" / high-entropy rules are deliberately omitted from the floor
# (gitleaks carries those when present). Each entry: a single ERE alternative.
BUILTIN_PATTERNS=(
  'AKIA[0-9A-Z]{16}'                                   # AWS Access Key ID
  'ASIA[0-9A-Z]{16}'                                   # AWS temp (STS) key ID
  '-----BEGIN [A-Z0-9 ]*PRIVATE KEY-----'             # PEM / OpenSSH private key block
  '\bgh[pousr]_[A-Za-z0-9]{36,}'                       # GitHub PAT / OAuth / app tokens
  '\bgithub_pat_[A-Za-z0-9_]{60,}'                     # GitHub fine-grained PAT
  '\bsk-ant-[A-Za-z0-9_-]{20,}'                        # Anthropic API key
  '\bsk-[A-Za-z0-9]{20,}'                              # OpenAI-style secret key
  '\bxox[baprs]-[A-Za-z0-9-]{10,}'                     # Slack token
  '\bAIza[0-9A-Za-z_-]{35}'                            # Google API key
  '\b[sr]k_live_[0-9A-Za-z]{20,}'                      # Stripe live secret/restricted key
  'hooks\.slack\.com/services/[A-Za-z0-9/_+-]{20,}'    # Slack incoming webhook
  'discord(app)?\.com/api/webhooks/[0-9]+/[A-Za-z0-9_-]{20,}'  # Discord webhook
  '\bglpat-[A-Za-z0-9_-]{20,}'                          # GitLab PAT
  '\bSG\.[A-Za-z0-9_-]{16,}\.[A-Za-z0-9_-]{16,}'       # SendGrid key
)

warn() { printf '%s: %s\n' "$PROG" "$*" >&2; }

# Does `gitleaks` exist and do we want it?
_use_gitleaks() {
  case "$SCANNER_PREF" in
    builtin)  return 1 ;;
    gitleaks) command -v gitleaks >/dev/null 2>&1; return $? ;;
    *)        command -v gitleaks >/dev/null 2>&1; return $? ;;  # auto
  esac
}

# Read the repo-root allow-regex file (if any) into ALLOW_RES (one per line).
ALLOW_RES=""
_load_allow() {
  ALLOW_RES=""
  local root
  root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  [[ -n "$root" && -f "$root/$ALLOW_FILE" ]] || return 0
  ALLOW_RES="$(grep -vE '^[[:space:]]*(#|$)' "$root/$ALLOW_FILE" 2>/dev/null || true)"
}

# True if a candidate line is allowlisted: carries the inline pragma OR matches
# any committed allow-regex.
_is_allowed() {
  local line="$1"
  printf '%s' "$line" | grep -qiE 'pragma:[[:space:]]*allowlist[[:space:]]+secret' && return 0
  [[ -z "$ALLOW_RES" ]] && return 1
  local re
  while IFS= read -r re; do
    [[ -z "$re" ]] && continue
    # -e: an allow-regex may legitimately start with '-'.
    printf '%s' "$line" | grep -qE -e "$re" && return 0
  done <<< "$ALLOW_RES"
  return 1
}

# Scan a blob of unified-diff text on stdin for secrets in ADDED lines only.
# Echoes one redacted finding per offending pattern hit; returns 1 if any found.
# Added lines: start with '+' but not '+++ '. Strip the leading '+'.
_scan_added() {
  local found=0 added line
  # Collect added lines (drop the +++ file headers).
  added="$(grep -E '^\+' 2>/dev/null | grep -vE '^\+\+\+ ' 2>/dev/null | sed -E 's/^\+//' || true)"
  [[ -z "$added" ]] && return 0
  local p
  for p in "${BUILTIN_PATTERNS[@]}"; do
    # Pull each matching added line so we can apply the allowlist per line.
    # `grep -e`: the PEM pattern (and others) start with '-', which grep would
    # otherwise parse as an option.
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      if _is_allowed "$line"; then continue; fi
      # Redact: show the first 4 chars of the match then mask, so the log/alert
      # never re-prints the full secret.
      local m
      m="$(printf '%s' "$line" | grep -oE -e "$p" | head -n1 || true)"
      [[ -z "$m" ]] && continue
      printf '  secret-like token (%s…) on an added line\n' "$(printf '%s' "$m" | cut -c1-4)"
      found=1
    done < <(printf '%s\n' "$added" | grep -nE -e "$p" 2>/dev/null | sed -E 's/^[0-9]+://' || true)
  done
  return $found
}

# Builtin scan of a diff produced by the caller (passed on stdin).
_builtin_scan_stream() { _scan_added; }

# Scan BASE..HEAD via the builtin floor. Fail-OPEN (exit 0) if the diff can't be
# produced. Returns 1 on a finding.
_builtin_scan_range() {
  local base="$1" head="$2" diff
  diff="$(git diff --no-color --unified=0 "$base" "$head" 2>/dev/null)" || { warn "could not diff $base..$head; allowing (fail-open)"; return 0; }
  printf '%s\n' "$diff" | _scan_added
}

# Scan a single commit (handles root commits — git show needs no parent).
_builtin_scan_commit() {
  local sha="$1" diff
  diff="$(git show --no-color --format= --unified=0 "$sha" 2>/dev/null)" || { warn "could not show $sha; allowing (fail-open)"; return 0; }
  printf '%s\n' "$diff" | _scan_added
}

# gitleaks over a base..head range. Returns: 0 clean, 1 finding, 2 exec error.
_gitleaks_range() {
  local base="$1" head="$2" rc=0 root
  root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  gitleaks detect --no-banner --redact --exit-code 1 \
    --source "$root" --log-opts "${base}..${head}" >/dev/null 2>&1 || rc=$?
  case "$rc" in
    0) return 0 ;;   # clean
    1) return 1 ;;   # findings
    *) return 2 ;;   # exec error → caller falls back to the builtin floor
  esac
}

# Public: scan a base..head range (used by --range and --prepush new-commit math).
scan_range() {
  local base="$1" head="$2" hit=0
  _load_allow
  if _use_gitleaks; then
    local gl=0; _gitleaks_range "$base" "$head" || gl=$?
    if [[ $gl -eq 1 ]]; then hit=1
    elif [[ $gl -eq 2 ]]; then
      warn "gitleaks errored on ${base}..${head}; falling back to the builtin floor"
      _builtin_scan_range "$base" "$head" || hit=1
    fi
  else
    _builtin_scan_range "$base" "$head" || hit=1
  fi
  return $hit
}

scan_commit() {
  local sha="$1" hit=0
  _load_allow
  if _use_gitleaks; then
    local gl=0; _gitleaks_range "${sha}~1" "$sha" 2>/dev/null || gl=$?
    if [[ $gl -eq 1 ]]; then hit=1
    elif [[ $gl -eq 2 ]]; then _builtin_scan_commit "$sha" || hit=1; fi
  else
    _builtin_scan_commit "$sha" || hit=1
  fi
  return $hit
}

# --prepush: read stdin lines, scan the NEW commits each ref pushes.
do_prepush() {
  local local_ref local_oid remote_ref remote_oid
  local zero="0000000000000000000000000000000000000000"
  local any_hit=0 findings=""
  # git feeds the pre-push hook "<local_ref> <local_oid> <remote_ref> <remote_oid>"
  # per line; only the oids are scanned, but the refs must be read as positional
  # placeholders to land the oids in the right vars.
  # shellcheck disable=SC2034  # local_ref/remote_ref are positional placeholders
  while read -r local_ref local_oid remote_ref remote_oid; do
    [[ -z "${local_oid:-}" ]] && continue
    # Deleting a remote ref (local oid all-zero): nothing to scan.
    [[ "$local_oid" == "$zero" ]] && continue
    local commits=""
    if [[ "$remote_oid" == "$zero" ]]; then
      # New branch/ref: only the commits not already on any remote — bounds the
      # scan to what this push actually adds (not the whole history).
      commits="$(git rev-list "$local_oid" --not --remotes 2>/dev/null || true)"
      [[ -z "$commits" ]] && commits="$(git rev-list "$local_oid" 2>/dev/null || true)"
    else
      commits="$(git rev-list "${remote_oid}..${local_oid}" 2>/dev/null || true)"
    fi
    local c out
    while IFS= read -r c; do
      [[ -z "$c" ]] && continue
      out="$(scan_commit "$c" 2>/dev/null)"; local rc=$?
      if [[ $rc -ne 0 ]]; then
        any_hit=1
        findings+="commit ${c:0:12}:"$'\n'"${out}"$'\n'
      fi
    done <<< "$commits"
  done
  if [[ $any_hit -ne 0 ]]; then
    {
      printf '\n%s: ❌ PUSH REJECTED — secret-like content detected in commits being pushed:\n\n' "$PROG"
      printf '%s\n' "$findings"
      printf 'Remove the secret (rewrite the offending commit) before pushing. If this is a\n'
      printf 'vetted false positive, add an inline `pragma: allowlist secret` comment or a\n'
      printf 'regex line to .secret-scan-allow (committed), then re-push. docs/secret-scan.md\n\n'
    } >&2
    return 1
  fi
  return 0
}

main() {
  command -v git >/dev/null 2>&1 || { warn "git not found; allowing (fail-open)"; exit 0; }
  local mode="${1:-}"; shift || true
  case "$mode" in
    --prepush) do_prepush ;;
    --range)
      [[ $# -ge 2 ]] || { warn "--range needs BASE HEAD"; exit 0; }
      local out; out="$(scan_range "$1" "$2")"; local rc=$?
      [[ -n "$out" ]] && printf '%s\n' "$out" >&2
      exit $rc ;;
    --commit)
      [[ $# -ge 1 ]] || { warn "--commit needs SHA"; exit 0; }
      local out; out="$(scan_commit "$1")"; local rc=$?
      [[ -n "$out" ]] && printf '%s\n' "$out" >&2
      exit $rc ;;
    --staged)
      _load_allow
      local diff; diff="$(git diff --no-color --cached --unified=0 2>/dev/null || true)"
      printf '%s\n' "$diff" | _scan_added; exit $? ;;
    -h|--help|"")
      sed -n '2,40p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//' ; exit 0 ;;
    *) warn "unknown mode: $mode"; exit 0 ;;
  esac
}

main "$@"
